{
  "name": "travel-package-offer",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#062A2E",
  "outputFormat": "mp4",
  "variables": {
    "brandName": "CORAL & CO. TRAVEL",
    "kicker": "ALL-INCLUSIVE PACKAGE",
    "destination": "Maldives",
    "packageName": "Overwater Escape",
    "nights": "5 nights · 2 guests",
    "includes": "Flights · overwater villa · daily breakfast · sunset cruise",
    "price": "$1,890",
    "pricePrefix": "from",
    "showPrice": true,
    "dates": "Departures: Sep 3 – Nov 28, 2026",
    "disclaimer": "Per person, twin share. Limited villas at this rate.",
    "showDisclaimer": true,
    "ctaText": "Reserve my dates",
    "accentColor": "#FF7E6B",
    "heroImage": "https://images.unsplash.com/photo-1549294413-26f195200c16?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3MDgwMTZ8MHwxfHNlYXJjaHw2fHxyZXNvcnQlMjBzd2ltbWluZyUyMHBvb2wlMjB2YWNhdGlvbnxlbnwwfHx8fDE3ODMyNjg1Njh8MA&ixlib=rb-4.1.0&q=80&w=1080",
    "detailImage": "https://images.pexels.com/photos/1917687/pexels-photo-1917687.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "hero",
      "duration": 4.4,
      "backgroundColor": "#062A2E",
      "transition": "smoothup",
      "transitionId": "offer",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{heroImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='tpoHero' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#062A2E' stop-opacity='0.6'/><stop offset='0.44' stop-color='#062A2E' stop-opacity='0.08'/><stop offset='1' stop-color='#062A2E' stop-opacity='0.95'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#tpoHero)'/><rect x='88' y='1200' width='150' height='7' rx='3.5' fill='#FF7E6B'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 150,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='display:inline-block; border:1.5px solid rgba(240,247,244,0.45); border-radius:999px; padding:14px 36px; color:#F0F7F4; font-size:24px; font-weight:700; letter-spacing:6px;'>{{brandName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 88,
          "y": 1250,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1.05,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='color:{{accentColor}}; font-size:26px; font-weight:800; letter-spacing:5px;'>{{kicker}}</div><div style='margin-top:16px; color:#F0F7F4; font-size:118px; line-height:0.96; font-weight:800; letter-spacing:-3px;'>{{destination}}</div><div style='margin-top:20px; color:#BFE0D6; font-size:38px; font-weight:600;'>{{packageName}}</div>"
        }
      ]
    },
    {
      "id": "offer",
      "duration": 5.4,
      "backgroundColor": "#062A2E",
      "transition": "fade",
      "transitionId": "cta",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 5.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='tpoOffer' cx='0.5' cy='0.3' r='1'><stop offset='0' stop-color='#0A3B41'/><stop offset='1' stop-color='#062A2E'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#tpoOffer)'/><rect x='80' y='760' width='920' height='1000' rx='42' fill='rgba(255,255,255,0.04)' stroke='rgba(255,126,107,0.4)' stroke-width='1.5'/><rect x='80' y='760' width='920' height='10' rx='5' fill='#FF7E6B'/></svg>"
        },
        {
          "type": "IMAGE",
          "src": "{{detailImage}}",
          "x": 540,
          "y": 400,
          "width": 940,
          "height": 620,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "radius": { "tl": 40, "tr": 40, "bl": 40, "br": 40 },
          "track": 1,
          "enterBegin": 0,
          "enterEnd": 0.5,
          "enterAnimation": "fade",
          "exitEnd": 5.4
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 830,
          "width": 820,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='text-align:center; color:#7FD4C4; font-size:29px; font-weight:700; letter-spacing:4px;'>{{nights}}</div><div style='margin-top:22px; text-align:center; color:#F0F7F4; font-size:34px; line-height:1.5; font-weight:400;'>{{includes}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showPrice}}",
          "x": 540,
          "y": 1230,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.2,
          "enterAnimation": "smoothup",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='text-align:center;'><span style='color:#7FD4C4; font-size:34px; font-weight:600; vertical-align:middle;'>{{pricePrefix}} </span><span style='color:{{accentColor}}; font-size:132px; font-weight:800; letter-spacing:-3px; vertical-align:middle;'>{{price}}</span></div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1470,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1,
          "enterEnd": 1.4,
          "enterAnimation": "fade",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='display:inline-block; background:rgba(127,212,196,0.14); border:1.5px solid rgba(127,212,196,0.5); color:#7FD4C4; border-radius:999px; padding:14px 34px; font-size:28px; font-weight:600;'>{{dates}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showDisclaimer}}",
          "x": 540,
          "y": 1650,
          "width": 820,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.3,
          "enterEnd": 1.7,
          "enterAnimation": "fade",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='text-align:center; color:#6E9188; font-size:24px; font-weight:400; line-height:1.4;'>{{disclaimer}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 4,
      "backgroundColor": "#062A2E",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='tpoCta' cx='0.5' cy='0.42' r='0.9'><stop offset='0' stop-color='#0B3F45'/><stop offset='1' stop-color='#062A2E'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#tpoCta)'/><circle cx='540' cy='680' r='150' fill='none' stroke='rgba(255,126,107,0.7)' stroke-width='2'/><circle cx='540' cy='680' r='170' fill='none' stroke='rgba(255,126,107,0.22)' stroke-width='1'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 680,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.7,
          "enterAnimation": "circleopen",
          "exitEnd": 4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='text-align:center; color:#FF7E6B; font-size:96px; font-weight:800;'>✦</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 940,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='text-align:center; color:#F0F7F4; font-size:74px; line-height:1.08; font-weight:800; letter-spacing:-1px;'>Paradise, all<br>sorted for you.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1240,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.95,
          "enterEnd": 1.4,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#062A2E; border-radius:999px; padding:28px 68px; font-size:41px; font-weight:800;'>{{ctaText}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.16
    }
  ]
}
