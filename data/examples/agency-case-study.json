{
  "name": "agency-case-study",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0E0E0E",
  "outputFormat": "mp4",
  "variables": {
    "agencyName": "Northbeam Digital",
    "clientLabel": "DTC skincare brand",
    "problem": "Ad costs doubled in six months. Revenue didn't.",
    "solution": "We rebuilt the creative pipeline: 40 data-driven video variants a month instead of 4 handmade ones.",
    "resultHeadline": "90 days later",
    "resultStat": "3.1×",
    "resultStatLabel": "return on ad spend",
    "resultSupport": "CAC down 38% · revenue up 64%",
    "ctaText": "Want your own case study?",
    "ctaUrl": "northbeam.example/audit",
    "problemImage": "https://images.pexels.com/photos/5466250/pexels-photo-5466250.jpeg?auto=compress&cs=tinysrgb&w=1620",
    "solutionImage": "https://images.pexels.com/photos/8117466/pexels-photo-8117466.jpeg?auto=compress&cs=tinysrgb&w=1620",
    "resultImage": "https://images.pexels.com/photos/6814524/pexels-photo-6814524.jpeg?auto=compress&cs=tinysrgb&w=1620",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "problem",
      "duration": 4.4,
      "backgroundColor": "#0E0E0E",
      "transition": "slideleft",
      "transitionId": "solution",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{problemImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "opacity": 0.3,
          "filter": {
            "saturate": 0.4
          },
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='rgba(14,14,14,0.6)'/><path d='M120 480 L1180 480' stroke='rgba(255,255,255,0.12)' stroke-width='1.5'/><path d='M150 1450 L330 1290 L470 1360 L640 1160 L810 1230 L960 1010' fill='none' stroke='#FF5C5C' stroke-width='7' stroke-linecap='round' stroke-linejoin='round' transform='rotate(180 555 1230)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 260,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='display:inline-block; background:#FF5C5C; color:#0E0E0E; border-radius:8px; padding:12px 28px; font-size:26px; font-weight:700; letter-spacing:3px;'>THE PROBLEM</div><div style='margin-top:30px; color:#FFFFFF; font-size:70px; line-height:1.08; font-weight:700; letter-spacing:-1px;'>{{problem}}</div><div style='margin-top:24px; color:#8F8F8F; font-size:28px; font-weight:500;'>Client: {{clientLabel}}</div>"
        }
      ]
    },
    {
      "id": "solution",
      "duration": 4.8,
      "backgroundColor": "#0E0E0E",
      "transition": "slideleft",
      "transitionId": "result",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{solutionImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "opacity": 0.32,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.8
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='rgba(14,14,14,0.62)'/><rect x='80' y='1280' width='920' height='420' rx='36' fill='rgba(198,241,53,0.06)' stroke='rgba(198,241,53,0.4)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 260,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "smoothup",
          "exitEnd": 4.8,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='display:inline-block; background:#C6F135; color:#0E0E0E; border-radius:8px; padding:12px 28px; font-size:26px; font-weight:700; letter-spacing:3px;'>WHAT WE DID</div><div style='margin-top:30px; color:#FFFFFF; font-size:56px; line-height:1.15; font-weight:700;'>{{solution}}</div>"
        },
        {
          "type": "TEXT",
          "x": 140,
          "y": 1350,
          "width": 800,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.8,
          "enterEnd": 1.25,
          "enterAnimation": "smoothup",
          "exitEnd": 4.8,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='color:#C6F135; font-size:30px; font-weight:700; line-height:1.7;'>✓ Hook-first creative testing<br>✓ Weekly iteration sprints<br>✓ Automated variant production</div>"
        }
      ]
    },
    {
      "id": "result",
      "duration": 5.2,
      "backgroundColor": "#0E0E0E",
      "transition": "fade",
      "transitionId": "pitch",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 5.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='acsGlow' cx='0.5' cy='0.4' r='0.85'><stop offset='0' stop-color='#1B2108'/><stop offset='1' stop-color='#0E0E0E'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#acsGlow)'/><path d='M150 1290 L330 1130 L470 1200 L640 1000 L810 1070 L940 860' fill='none' stroke='#C6F135' stroke-width='8' stroke-linecap='round' stroke-linejoin='round'/><circle cx='940' cy='860' r='14' fill='#C6F135'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 300,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "smoothdown",
          "exitEnd": 5.2,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:#8F8F8F; font-size:32px; font-weight:700; letter-spacing:6px;'>{{resultHeadline}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 420,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1,
          "enterAnimation": "circleopen",
          "exitEnd": 5.2,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:#C6F135; font-size:290px; line-height:1; font-weight:700; letter-spacing:-10px;'>{{resultStat}}</div><div style='margin-top:10px; text-align:center; color:#FFFFFF; font-size:42px; font-weight:700;'>{{resultStatLabel}}</div><div style='margin-top:22px; text-align:center; color:#9F9F9F; font-size:29px; font-weight:600;'>{{resultSupport}}</div>"
        }
      ]
    },
    {
      "id": "pitch",
      "duration": 4,
      "backgroundColor": "#0E0E0E",
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{resultImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "opacity": 0.3,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='rgba(14,14,14,0.68)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 830,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:64px; line-height:1.1; font-weight:700;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1120,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.8,
          "enterEnd": 1.2,
          "enterAnimation": "circleopen",
          "exitEnd": 4,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='display:inline-block; background:#C6F135; color:#0E0E0E; border-radius:999px; padding:26px 64px; font-size:36px; font-weight:700;'>Book a free audit</div><div style='margin-top:16px; text-align:center; color:#8F8F8F; font-size:25px; font-weight:600; letter-spacing:2px;'>{{ctaUrl}} · {{agencyName}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.17
    }
  ]
}
