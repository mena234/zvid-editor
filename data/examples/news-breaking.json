{
  "name": "news-breaking",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0A0A0C",
  "outputFormat": "mp4",
  "variables": {
    "network": "PULSE NEWS",
    "kicker": "BREAKING",
    "headline": "City Council approves landmark climate plan in overnight vote",
    "summary": "The 9-2 decision commits the metro area to net-zero emissions by 2040 and unlocks $2.4B in green infrastructure funding.",
    "sourceName": "Metro Desk",
    "timestamp": "LIVE · 2:14 AM",
    "showLive": true,
    "ticker": "DEVELOPING STORY  ·  MORE UPDATES AS THEY ARRIVE  ·  STAY WITH US",
    "accentColor": "#E4141B",
    "heroVideo": "https://videos.pexels.com/video-files/34504957/14619605_1080_1920_24fps.mp4",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "alert",
      "duration": 3.4,
      "backgroundColor": "#0A0A0C",
      "transition": "wipeup",
      "transitionId": "story",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='alertGlow' cx='0.5' cy='0.42' r='0.85'><stop offset='0' stop-color='#1A0406'/><stop offset='1' stop-color='#0A0A0C'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#alertGlow)'/><rect x='0' y='760' width='1080' height='400' fill='#E4141B'/><rect x='0' y='728' width='1080' height='6' fill='rgba(255,255,255,0.9)'/><rect x='0' y='1160' width='1080' height='6' fill='rgba(255,255,255,0.9)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 560,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.1,
          "enterEnd": 0.45,
          "enterAnimation": "circleopen",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; border:3px solid #E4141B; color:#FFFFFF; padding:14px 40px; font-size:30px; font-weight:900; letter-spacing:10px;'>{{network}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 900,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.75,
          "enterAnimation": "smoothleft",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#FFFFFF; font-size:150px; font-weight:900; letter-spacing:6px; line-height:1;'>{{kicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1280,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.7,
          "enterEnd": 1.1,
          "enterAnimation": "fade",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:rgba(255,255,255,0.55); font-size:30px; font-weight:700; letter-spacing:8px;'>{{timestamp}}</div>"
        }
      ]
    },
    {
      "id": "story",
      "duration": 6,
      "backgroundColor": "#0A0A0C",
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{heroVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='storyShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0A0A0C' stop-opacity='0.85'/><stop offset='0.32' stop-color='#0A0A0C' stop-opacity='0.15'/><stop offset='0.62' stop-color='#0A0A0C' stop-opacity='0.55'/><stop offset='1' stop-color='#0A0A0C' stop-opacity='0.98'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#storyShade)'/><rect x='0' y='1690' width='1080' height='120' fill='#0A0A0C'/><rect x='0' y='1682' width='1080' height='8' fill='#E4141B'/><rect x='0' y='1178' width='120' height='58' fill='#E4141B'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 72,
          "y": 96,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.15,
          "enterEnd": 0.5,
          "enterAnimation": "smoothright",
          "exitEnd": 6,
          "style": { "fontFamily": "Archivo" },
          "html": "<span style='display:inline-block; background:{{accentColor}}; color:#FFFFFF; padding:12px 26px; font-size:28px; font-weight:900; letter-spacing:6px;'>{{kicker}}</span>"
        },
        {
          "type": "TEXT",
          "condition": "{{showLive}}",
          "x": 1008,
          "y": 96,
          "anchor": "top-right",
          "track": 11,
          "enterBegin": 0.3,
          "enterEnd": 0.7,
          "enterAnimation": "fade",
          "exitEnd": 6,
          "style": { "fontFamily": "Archivo" },
          "html": "<span style='display:inline-block; background:rgba(228,20,27,0.15); border:2px solid #E4141B; color:#FF6068; padding:10px 24px; font-size:26px; font-weight:900; letter-spacing:4px;'>● LIVE</span>"
        },
        {
          "type": "TEXT",
          "x": 72,
          "y": 1150,
          "width": 940,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.45,
          "enterEnd": 0.95,
          "enterAnimation": "smoothup",
          "exitEnd": 6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#FFFFFF; font-size:78px; line-height:1.02; font-weight:900; letter-spacing:-2px;'>{{headline}}</div>"
        },
        {
          "type": "TEXT",
          "x": 72,
          "y": 1440,
          "width": 940,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.85,
          "enterEnd": 1.3,
          "enterAnimation": "fade",
          "exitEnd": 6,
          "style": { "fontFamily": "Archivo" },
