        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1750,
          "anchor": "center-center",
          "track": 12,
          "enterBegin": 0.6,
          "enterEnd": 1,
          "enterAnimation": "smoothleft",
          "exitEnd": 6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#FFFFFF; font-size:26px; font-weight:800; letter-spacing:5px;'>{{ticker}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.16
    }
  ]
}
