          "type": "TEXT",
          "x": 118,
          "y": 1244,
          "width": 880,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.45,
          "enterEnd": 0.95,
          "enterAnimation": "smoothup",
          "exitEnd": 5.2,
          "style": {
            "fontFamily": "Sora"
