{
  "name": "social-meme-text",
  "resolution": "tiktok",
  "frameRate": 30,
  "backgroundColor": "#0B0B0B",
  "outputFormat": "mp4",
  "variables": {
    "handle": "@relatable.daily",
    "setupTop": "ME:",
    "setupBottom": "gonna be so productive today",
    "punchTop": "ALSO ME:",
    "punchBottom": "reorganizing my apps for the 4th time",
    "reactionVideo": "https://videos.pexels.com/video-files/8627757/8627757-hd_1080_1920_25fps.mp4",
    "punchVideo": "https://videos.pexels.com/video-files/8628284/8628284-hd_1080_1920_25fps.mp4",
    "accent": "#FF2E88",
    "showWatermark": true,
    "ctaLine": "SEND THIS TO YOUR<br>PROCRASTINATION BUDDY",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "setup",
      "duration": 3,
      "backgroundColor": "#0B0B0B",
      "transition": "wipeleft",
      "transitionId": "punch",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{reactionVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='memeA' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0B0B0B' stop-opacity='0.72'/><stop offset='0.3' stop-color='#0B0B0B' stop-opacity='0.1'/><stop offset='0.7' stop-color='#0B0B0B' stop-opacity='0.1'/><stop offset='1' stop-color='#0B0B0B' stop-opacity='0.8'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#memeA)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 170,
          "width": 980,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.1,
          "enterEnd": 0.45,
          "enterAnimation": "smoothdown",
          "exitEnd": 3,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:64px; line-height:1; font-weight:800; letter-spacing:2px; text-transform:uppercase; text-shadow:0 4px 20px rgba(0,0,0,0.9);'>{{setupTop}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1520,
          "width": 980,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:70px; line-height:1.02; font-weight:800; letter-spacing:-1px; text-transform:uppercase; text-shadow:0 4px 20px rgba(0,0,0,0.95);'>{{setupBottom}}</div>"
        }
      ]
    },
    {
      "id": "punch",
      "duration": 3.4,
      "backgroundColor": "#0B0B0B",
      "transition": "smoothup",
      "transitionId": "cta",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{punchVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='memeB' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0B0B0B' stop-opacity='0.75'/><stop offset='0.32' stop-color='#0B0B0B' stop-opacity='0.1'/><stop offset='0.68' stop-color='#0B0B0B' stop-opacity='0.1'/><stop offset='1' stop-color='#0B0B0B' stop-opacity='0.82'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#memeB)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 170,
          "width": 980,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.05,
          "enterEnd": 0.4,
          "enterAnimation": "smoothdown",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:{{accent}}; color:#0B0B0B; padding:12px 34px; border-radius:12px; font-size:64px; line-height:1; font-weight:800; letter-spacing:1px; text-transform:uppercase;'>{{punchTop}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1460,
          "width": 980,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.65,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:74px; line-height:1.04; font-weight:800; letter-spacing:-1px; text-transform:uppercase; text-shadow:0 4px 20px rgba(0,0,0,0.95);'>{{punchBottom}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showWatermark}}",
          "x": 540,
          "y": 940,
          "anchor": "center-center",
          "track": 11,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:rgba(255,255,255,0.28); font-size:40px; font-weight:800; letter-spacing:8px; transform:rotate(-8deg);'>{{handle}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 3.6,
      "backgroundColor": "#0B0B0B",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='memeCta' cx='0.5' cy='0.42' r='0.95'><stop offset='0' stop-color='#2A0A1C'/><stop offset='1' stop-color='#0B0B0B'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#memeCta)'/><path d='M360 620 h360 a40 40 0 0 1 40 40 v170 a40 40 0 0 1 -40 40 h-250 l-90 80 v-80 h-20 a40 40 0 0 1 -40 -40 v-170 a40 40 0 0 1 40 -40 z' fill='none' stroke='#FF2E88' stroke-width='5' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1080,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:72px; line-height:1.06; font-weight:800; letter-spacing:-1px; text-transform:uppercase;'>{{ctaLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1440,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.1,
          "enterAnimation": "circleopen",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:{{accent}}; color:#0B0B0B; border-radius:999px; padding:24px 60px; font-size:38px; font-weight:800;'>{{handle}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.2
    }
  ]
}
