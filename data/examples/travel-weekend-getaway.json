        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1350,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.05,
          "enterEnd": 1.45,
          "enterAnimation": "fade",
          "exitEnd": 3.8,
