{
  "name": "travel-weekend-getaway",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0A2540",
  "outputFormat": "mp4",
  "variables": {
    "brandName": "48H TRIPS",
    "hookTop": "Out of office",
    "hookBottom": "by Friday 5pm.",
    "place": "Lisbon",
    "distanceLine": "2h 40m flight · no visa · pack light",
    "perk1": "Fri night arrival",
    "perk2": "Sun sunset return",
    "perk3": "3 nights, one carry-on",
    "ctaText": "Grab the weekend",
    "ctaHandle": "48htrips.co",
    "accentColor": "#39D3E0",
    "heroImage": "https://images.pexels.com/photos/26851069/pexels-photo-26851069.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "placeImage": "https://images.pexels.com/photos/37474458/pexels-photo-37474458.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
