        {
          "type": "IMAGE",
          "src": "{{heroImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.6,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='twgHook' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0A2540' stop-opacity='0.72'/><stop offset='0.5' stop-color='#0A2540' stop-opacity='0.4'/><stop offset='1' stop-color='#0A2540' stop-opacity='0.92'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#twgHook)'/><path d='M-40 560 L1120 500 L1120 528 L-40 588 Z' fill='#39D3E0' opacity='0.9'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 150,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='display:inline-block; background:#39D3E0; color:#0A2540; border-radius:999px; padding:13px 34px; font-size:25px; font-weight:800; letter-spacing:4px;'>{{brandName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 760,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.95,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:104px; line-height:1; font-weight:800; letter-spacing:-3px;'>{{hookTop}}<br><span style='color:{{accentColor}};'>{{hookBottom}}</span></div>"
