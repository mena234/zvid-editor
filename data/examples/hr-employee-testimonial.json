{
  "name": "hr-employee-testimonial",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#2A1020",
  "outputFormat": "mp4",
  "variables": {
    "companyName": "LANTERN",
    "kicker": "WHY I STAYED",
    "quote": "I came for the role. I stayed for the people who genuinely want me to grow.",
    "employeeName": "Priya Nair",
    "employeeRole": "Senior Data Scientist · 3 years",
    "stars": "★★★★★",
    "ratingLabel": "4.8 / 5 · Glassdoor",
    "showRating": true,
    "ctaText": "See open roles",
    "ctaUrl": "lantern.io/careers",
    "accentColor": "#F2C14E",
    "employeePhoto": "https://images.pexels.com/photos/17049768/pexels-photo-17049768.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "quote",
      "duration": 5.4,
      "backgroundColor": "#2A1020",
      "transition": "fade",
      "transitionId": "who",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 5.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='etQuote' cx='0.4' cy='0.32' r='1'><stop offset='0' stop-color='#43182F'/><stop offset='1' stop-color='#2A1020'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#etQuote)'/><text x='120' y='560' font-family='Georgia' font-size='420' fill='rgba(242,193,78,0.22)'>“</text><rect x='120' y='1360' width='140' height='7' rx='3.5' fill='#F2C14E'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 130,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:{{accentColor}}; font-size:26px; font-weight:700; letter-spacing:8px;'>{{kicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 110,
          "y": 720,
          "width": 880,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1.1,
          "enterAnimation": "smoothup",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Playfair Display" },
          "html": "<div style='color:#FBEFDD; font-size:72px; line-height:1.24; font-weight:700;'>{{quote}}</div>"
        },
        {
          "type": "TEXT",
          "x": 110,
          "y": 1410,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 1.1,
          "enterEnd": 1.55,
          "enterAnimation": "fade",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:#F2C14E; font-size:60px; letter-spacing:6px;'>{{stars}}</div><div style='margin-top:20px; color:#FFFFFF; font-size:40px; font-weight:700;'>{{employeeName}}</div><div style='margin-top:8px; color:#C9A6B6; font-size:30px; font-weight:500;'>{{employeeRole}}</div>"
        }
      ]
    },
    {
      "id": "who",
      "duration": 4.4,
      "backgroundColor": "#2A1020",
      "transition": "smoothleft",
      "transitionId": "cta",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{employeePhoto}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='etWho' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#2A1020' stop-opacity='0.5'/><stop offset='0.5' stop-color='#2A1020' stop-opacity='0.15'/><stop offset='1' stop-color='#2A1020' stop-opacity='0.95'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#etWho)'/><rect x='90' y='1300' width='7' height='340' rx='3.5' fill='#F2C14E'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 132,
          "y": 1300,
          "width": 860,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:{{accentColor}}; font-size:26px; font-weight:800; letter-spacing:5px;'>MEET {{employeeName}}</div><div style='margin-top:14px; color:#FFFFFF; font-size:62px; line-height:1.1; font-weight:800; letter-spacing:-1px;'>Real people.<br>Real growth.</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showRating}}",
          "x": 132,
          "y": 1580,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.85,
          "enterEnd": 1.3,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='display:inline-block; background:rgba(242,193,78,0.16); border:1.5px solid rgba(242,193,78,0.5); color:{{accentColor}}; border-radius:999px; padding:14px 34px; font-size:30px; font-weight:700;'>★ {{ratingLabel}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 3.8,
      "backgroundColor": "#2A1020",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='etCta' cx='0.5' cy='0.4' r='0.95'><stop offset='0' stop-color='#43182F'/><stop offset='1' stop-color='#2A1020'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#etCta)'/><path d='M540 540 l24 74 h78 l-63 46 l24 74 l-63 -46 l-63 46 l24 -74 l-63 -46 h78 z' fill='#F2C14E'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 860,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.75,
          "enterAnimation": "smoothup",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Playfair Display" },
          "html": "<div style='text-align:center; color:#FBEFDD; font-size:76px; line-height:1.12; font-weight:700;'>Your story<br>could be next.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1180,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "smoothup",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#2A1020; border-radius:999px; padding:26px 66px; font-size:40px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1360,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.1,
          "enterEnd": 1.5,
          "enterAnimation": "fade",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:#B78C9C; font-size:28px; font-weight:600; letter-spacing:2px;'>{{companyName}} · {{ctaUrl}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.15
    }
  ]
}
