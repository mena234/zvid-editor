{
  "name": "localservice-appointment-reminder",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#F1FAF9",
  "outputFormat": "mp4",
  "variables": {
    "clinicName": "BRIGHTSMILE DENTAL",
    "kicker": "APPOINTMENT REMINDER",
    "patientLine": "See you soon,<br>Jordan!",
    "serviceName": "Routine Cleaning & Check-up",
    "dateValue": "Thu · Aug 14",
    "timeValue": "10:30 AM",
    "durationValue": "≈ 45 min",
    "showLocation": true,
    "locationName": "Brightsmile — Downtown",
    "locationAddress": "24 Elm Street, Suite 3",
    "prepNote": "Please arrive 10 min early. Reply RESCHEDULE to change.",
    "ctaText": "Confirm my visit",
    "ctaPhone": "(555) 204-8890",
    "accentColor": "#0EA5A4",
    "clinicImage": "https://images.pexels.com/photos/7800666/pexels-photo-7800666.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "intro",
      "duration": 3.8,
      "backgroundColor": "#F1FAF9",
      "transition": "smoothleft",
      "transitionId": "details",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{clinicImage}}",
          "x": 540,
          "y": 620,
          "width": 1080,
          "height": 980,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.8
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='arIntro' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0B3B3A' stop-opacity='0.4'/><stop offset='0.5' stop-color='#0B3B3A' stop-opacity='0'/><stop offset='0.6' stop-color='#F1FAF9' stop-opacity='0'/><stop offset='0.72' stop-color='#F1FAF9' stop-opacity='1'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#arIntro)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 150,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "smoothdown",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#FFFFFF; border-radius:999px; padding:14px 34px; font-size:24px; font-weight:800; letter-spacing:4px;'>{{kicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1180,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:28px; font-weight:800; letter-spacing:5px;'>{{clinicName}}</div><div style='margin-top:14px; text-align:center; color:#0C2E2D; font-size:92px; line-height:1.02; font-weight:800; letter-spacing:-2px;'>{{patientLine}}</div>"
        }
      ]
    },
    {
      "id": "details",
      "duration": 5,
      "backgroundColor": "#F1FAF9",
      "transition": "smoothleft",
      "transitionId": "cta",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 5,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#F1FAF9'/><circle cx='900' cy='250' r='240' fill='rgba(14,165,164,0.08)'/><circle cx='160' cy='1680' r='200' fill='rgba(14,165,164,0.06)'/><rect x='90' y='470' width='900' height='240' rx='30' fill='#FFFFFF' stroke='rgba(14,165,164,0.25)' stroke-width='1.5'/><rect x='90' y='740' width='435' height='240' rx='30' fill='#FFFFFF' stroke='rgba(14,165,164,0.25)' stroke-width='1.5'/><rect x='555' y='740' width='435' height='240' rx='30' fill='#FFFFFF' stroke='rgba(14,165,164,0.25)' stroke-width='1.5'/><rect x='90' y='470' width='14' height='240' rx='7' fill='#0EA5A4'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 250,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 5,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:#0C2E2D; font-size:56px; font-weight:800; letter-spacing:-1px;'>{{serviceName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 140,
          "y": 512,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.4,
          "enterEnd": 0.85,
          "enterAnimation": "smoothleft",
          "exitEnd": 5,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:{{accentColor}}; font-size:24px; font-weight:800; letter-spacing:4px;'>DATE</div><div style='margin-top:8px; color:#0C2E2D; font-size:82px; font-weight:800; letter-spacing:-2px;'>{{dateValue}}</div>"
        },
        {
          "type": "TEXT",
          "x": 140,
          "y": 800,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.6,
          "enterEnd": 1.05,
          "enterAnimation": "smoothup",
          "exitEnd": 5,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:{{accentColor}}; font-size:24px; font-weight:800; letter-spacing:4px;'>TIME</div><div style='margin-top:8px; color:#0C2E2D; font-size:66px; font-weight:800; letter-spacing:-1px;'>{{timeValue}}</div>"
        },
        {
          "type": "TEXT",
          "x": 605,
          "y": 800,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "smoothup",
          "exitEnd": 5,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:{{accentColor}}; font-size:24px; font-weight:800; letter-spacing:4px;'>DURATION</div><div style='margin-top:8px; color:#0C2E2D; font-size:66px; font-weight:800; letter-spacing:-1px;'>{{durationValue}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showLocation}}",
          "x": 540,
          "y": 1050,
          "width": 900,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.95,
          "enterEnd": 1.4,
          "enterAnimation": "smoothup",
          "exitEnd": 5,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:#0C2E2D; font-size:44px; font-weight:800;'>📍 {{locationName}}</div><div style='margin-top:8px; color:#4E6E6C; font-size:32px; font-weight:500;'>{{locationAddress}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1280,
          "width": 860,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.15,
          "enterEnd": 1.6,
          "enterAnimation": "fade",
          "exitEnd": 5,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:#4E6E6C; font-size:30px; line-height:1.45; font-weight:500;'>{{prepNote}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 3.8,
      "backgroundColor": "#0B3B3A",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='arCta' cx='0.5' cy='0.42' r='0.95'><stop offset='0' stop-color='#0F4E4C'/><stop offset='1' stop-color='#0B3B3A'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#arCta)'/><circle cx='540' cy='650' r='140' fill='none' stroke='#3FE3D6' stroke-width='3'/><path d='M486 650 l34 34 l70 -78' fill='none' stroke='#3FE3D6' stroke-width='14' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 900,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:70px; line-height:1.08; font-weight:800; letter-spacing:-1px;'>All set for<br>your visit?</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1180,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.65,
          "enterEnd": 1.1,
          "enterAnimation": "smoothup",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='display:inline-block; background:#3FE3D6; color:#043332; border-radius:999px; padding:26px 60px; font-size:38px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1360,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1,
          "enterEnd": 1.45,
          "enterAnimation": "fade",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:#9FCECB; font-size:32px; font-weight:700; letter-spacing:2px;'>Call {{ctaPhone}}</div>"
        }
      ]
    }
  ],
  "audios": [
    { "src": "{{musicUrl}}", "volume": 0.14 }
  ]
}
