{
  "name": "edu-lesson-recap",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#132029",
  "outputFormat": "mp4",
  "variables": {
    "courseName": "Data Storytelling",
    "moduleName": "Module 3 — Charts that persuade",
    "progressLabel": "You're 60% through the course",
    "nextUp": "Next up: Module 4 — Presenting under pressure",
    "ctaText": "Continue learning",
    "recapPoints": [
      {
        "point": "Every chart needs one sentence it exists to prove"
      },
      {
        "point": "Cut axes honestly — truncation is how trust dies"
      },
      {
        "point": "Annotate the takeaway on the chart, not in your speech"
      }
    ],
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "header",
      "duration": 3.4,
      "backgroundColor": "#132029",
      "transition": "smoothup",
      "transitionId": "recap",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4,
