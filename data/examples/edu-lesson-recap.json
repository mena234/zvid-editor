        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 700,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Manrope" },
          "html": "<div style='text-align:center; color:#57C4A3; font-size:26px; font-weight:800; letter-spacing:5px;'>LESSON RECAP</div><div style='margin-top:16px; text-align:center; color:#F0F5F3; font-size:62px; line-height:1.1; font-weight:800;'>{{moduleName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1130,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.8,
          "enterEnd": 1.2,
          "enterAnimation": "fade",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Manrope" },
          "html": "<div style='text-align:center; color:#9DB4AC; font-size:27px; font-weight:600;'>{{progressLabel}}</div>"
