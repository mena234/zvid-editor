{
  "name": "market-item-compare",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0D1418",
  "outputFormat": "mp4",
  "variables": {
    "marketName": "PICKALYST",
    "introKicker": "HEAD TO HEAD",
    "introLine": "Two great listings. One better buy.",
    "leftName": "Toyota RAV4 '19",
    "leftPrice": "$21,900",
    "leftSpec1": "68k miles",
    "leftSpec2": "Clean title",
    "leftSpec3": "1 owner",
    "leftImage": "https://images.pexels.com/photos/20131971/pexels-photo-20131971.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "rightName": "Honda CR-V '20",
    "rightPrice": "$23,400",
    "rightSpec1": "54k miles",
    "rightSpec2": "Clean title",
    "rightSpec3": "Certified",
    "rightImage": "https://images.pexels.com/photos/28837090/pexels-photo-28837090.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "showWinner": true,
    "winnerName": "Honda CR-V '20",
    "winnerReason": "Fewer miles + certified for $1.5k more",
    "ctaText": "Compare more listings",
    "ctaHandle": "pickalyst.market/compare",
    "leftColor": "#22D3B0",
    "rightColor": "#FF7A3D",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "intro",
      "duration": 3,
      "backgroundColor": "#0D1418",
      "transition": "smoothup",
      "transitionId": "versus",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='cmBg' cx='0.5' cy='0.4' r='0.95'><stop offset='0' stop-color='#16232A'/><stop offset='1' stop-color='#0D1418'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#cmBg)'/><circle cx='380' cy='620' r='150' fill='none' stroke='#22D3B0' stroke-width='4'/><circle cx='700' cy='620' r='150' fill='none' stroke='#FF7A3D' stroke-width='4'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 590,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "circleopen",
          "exitEnd": 3,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#FFFFFF; font-size:70px; font-weight:800; letter-spacing:2px;'>VS</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 130,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "fade",
          "exitEnd": 3,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#7C93A0; font-size:26px; font-weight:800; letter-spacing:8px;'>{{marketName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 900,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 3,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFB020; font-size:28px; font-weight:800; letter-spacing:7px;'>{{introKicker}}</div><div style='margin-top:20px; text-align:center; color:#FFFFFF; font-size:76px; line-height:1.08; font-weight:800; letter-spacing:-2px;'>{{introLine}}</div>"
        }
      ]
    },
    {
      "id": "versus",
      "duration": 5.2,
      "backgroundColor": "#0D1418",
      "transition": "smoothup",
      "transitionId": "verdict",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{leftImage}}",
          "x": 270,
          "y": 560,
          "width": 480,
          "height": 620,
          "anchor": "center-center",
          "resize": "cover",
          "radius": { "tl": 30, "tr": 30, "bl": 30, "br": 30 },
          "track": 1,
          "enterBegin": 0,
          "enterEnd": 0.5,
          "enterAnimation": "smoothright",
          "exitEnd": 5.2
        },
        {
          "type": "IMAGE",
          "src": "{{rightImage}}",
          "x": 810,
          "y": 560,
          "width": 480,
          "height": 620,
          "anchor": "center-center",
          "resize": "cover",
          "radius": { "tl": 30, "tr": 30, "bl": 30, "br": 30 },
          "track": 1,
          "enterBegin": 0,
          "enterEnd": 0.5,
          "enterAnimation": "smoothleft",
          "exitEnd": 5.2
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 5.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#0D1418'/><rect x='60' y='920' width='480' height='800' rx='30' fill='rgba(34,211,176,0.06)' stroke='rgba(34,211,176,0.4)' stroke-width='1.5'/><rect x='540' y='920' width='480' height='800' rx='30' fill='rgba(255,122,61,0.06)' stroke='rgba(255,122,61,0.4)' stroke-width='1.5'/><rect x='534' y='260' width='12' height='1420' rx='6' fill='rgba(255,255,255,0.1)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 300,
          "y": 960,
          "width": 420,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 5.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:{{leftColor}}; font-size:26px; font-weight:800; letter-spacing:3px;'>OPTION A</div><div style='margin-top:12px; text-align:center; color:#FFFFFF; font-size:44px; line-height:1.05; font-weight:800; letter-spacing:-1px;'>{{leftName}}</div><div style='margin-top:14px; text-align:center; color:{{leftColor}}; font-size:56px; font-weight:800; letter-spacing:-1px;'>{{leftPrice}}</div><div style='margin-top:22px; text-align:center; color:#B4C4CC; font-size:30px; line-height:1.7; font-weight:500;'>{{leftSpec1}}<br>{{leftSpec2}}<br>{{leftSpec3}}</div>"
        },
        {
          "type": "TEXT",
          "x": 780,
          "y": 960,
          "width": 420,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.55,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 5.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:{{rightColor}}; font-size:26px; font-weight:800; letter-spacing:3px;'>OPTION B</div><div style='margin-top:12px; text-align:center; color:#FFFFFF; font-size:44px; line-height:1.05; font-weight:800; letter-spacing:-1px;'>{{rightName}}</div><div style='margin-top:14px; text-align:center; color:{{rightColor}}; font-size:56px; font-weight:800; letter-spacing:-1px;'>{{rightPrice}}</div><div style='margin-top:22px; text-align:center; color:#B4C4CC; font-size:30px; line-height:1.7; font-weight:500;'>{{rightSpec1}}<br>{{rightSpec2}}<br>{{rightSpec3}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 130,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 5.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#7C93A0; font-size:24px; font-weight:800; letter-spacing:6px;'>{{marketName}} · SIDE BY SIDE</div>"
        }
      ]
    },
    {
      "id": "verdict",
      "duration": 4.2,
      "backgroundColor": "#0D1418",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='cmEnd' cx='0.5' cy='0.4' r='0.9'><stop offset='0' stop-color='#1A2A1E'/><stop offset='1' stop-color='#0D1418'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#cmEnd)'/><circle cx='540' cy='620' r='150' fill='none' stroke='rgba(34,211,176,0.7)' stroke-width='2.5'/><path d='M480 620 l40 42 l100 -100' fill='none' stroke='#22D3B0' stroke-width='14' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "condition": "{{showWinner}}",
          "x": 540,
          "y": 860,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:{{leftColor}}; font-size:28px; font-weight:800; letter-spacing:6px;'>OUR PICK</div><div style='margin-top:16px; text-align:center; color:#FFFFFF; font-size:78px; line-height:1.05; font-weight:800; letter-spacing:-2px;'>{{winnerName}}</div><div style='margin-top:24px; text-align:center; color:#B4C4CC; font-size:34px; line-height:1.4; font-weight:500;'>{{winnerReason}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1280,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.75,
          "enterEnd": 1.2,
          "enterAnimation": "circleopen",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:{{leftColor}}; color:#0D1418; border-radius:999px; padding:26px 60px; font-size:36px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1440,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.05,
          "enterEnd": 1.45,
          "enterAnimation": "fade",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#7C93A0; font-size:27px; font-weight:600; letter-spacing:1px;'>{{ctaHandle}}</div>"
        }
      ]
    }
  ],
  "audios": [
    { "src": "{{musicUrl}}", "volume": 0.15 }
  ]
}
