{
  "name": "sports-bracket",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0D1117",
  "outputFormat": "mp4",
  "variables": {
    "kicker": "KNOCKOUT UPDATE",
    "tournamentName": "WORLD CUP · ROAD TO THE FINAL",
    "roundLabel": "SEMI-FINALS SET",
    "accentColor": "#E5B84B",
    "sfaHome": "ARGENTINA",
    "sfaAway": "CROATIA",
    "sfbHome": "FRANCE",
    "sfbAway": "MOROCCO",
    "qfLine": "Quarter-finals delivered four instant classics.",
    "finalNote": "Winners meet in Sunday's final.",
    "showFinalHype": true,
    "finalHypeText": "ONE MATCH FROM GLORY",
    "channelLine": "@wc.bracket",
    "bgImage": "https://images.pexels.com/photos/6250975/pexels-photo-6250975.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "intro",
      "duration": 3.6,
      "backgroundColor": "#0D1117",
      "transition": "smoothup",
      "transitionId": "bracket",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{bgImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.38,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.6,
