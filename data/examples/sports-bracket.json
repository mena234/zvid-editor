          "x": 905,
          "y": 1160,
          "anchor": "top-center",
          "track": 12,
          "enterBegin": 1.0,
          "enterEnd": 1.45,
          "enterAnimation": "circleopen",
          "exitEnd": 6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:26px; font-weight:900; letter-spacing:3px;'>FINAL</div>"
        },
