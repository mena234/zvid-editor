          "type": "TEXT",
          "x": 540,
          "y": 1560,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 1.2,
          "enterEnd": 1.65,
          "enterAnimation": "smoothup",
          "exitEnd": 6,
