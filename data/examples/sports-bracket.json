          "exitEnd": 6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#9FB0C0; font-size:24px; font-weight:800; letter-spacing:4px;'>VS</div><div style='margin-top:4px; color:#FFFFFF; font-size:44px; font-weight:900; letter-spacing:-1px;'>{{sfbAway}}</div>"
