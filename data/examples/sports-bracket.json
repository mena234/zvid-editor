        },
        {
          "type": "TEXT",
          "x": 120,
          "y": 780,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.75,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:{{accentColor}}; font-size:30px; font-weight:900; letter-spacing:8px;'>{{kicker}}</div><div style='margin-top:18px; color:#FFFFFF; font-size:96px; line-height:0.96; font-weight:900; letter-spacing:-3px;'>{{tournamentName}}</div><div style='margin-top:32px; color:#9FB0C0; font-size:34px; font-weight:700; letter-spacing:3px;'>{{roundLabel}}</div>"
        }
      ]
    },
    {
      "id": "bracket",
      "duration": 6,
      "backgroundColor": "#0D1117",
      "transition": "fade",
      "transitionId": "outro",
