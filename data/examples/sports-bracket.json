          "x": 540,
          "y": 1120,
          "width": 880,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.55,
          "enterEnd": 1.0,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:60px; line-height:1.15; font-weight:900; letter-spacing:-1px;'>{{finalNote}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1380,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.9,
          "enterEnd": 1.3,
          "enterAnimation": "fade",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; border:1.5px solid rgba(229,184,75,0.6); color:{{accentColor}}; border-radius:999px; padding:16px 44px; font-size:30px; font-weight:700; letter-spacing:2px;'>{{channelLine}}</div>"
