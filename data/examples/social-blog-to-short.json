{
  "name": "social-blog-to-short",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#17130E",
  "outputFormat": "mp4",
  "variables": {
    "blogName": "The Slow Web",
    "articleTitle": "Why the best writers publish before they're ready",
    "readTime": "4 min read",
    "authorName": "by Amira Solomon",
    "ctaText": "Read the full article",
    "articleUrl": "theslowweb.example/publish-before-ready",
    "bgImage": "https://images.pexels.com/photos/11208030/pexels-photo-11208030.jpeg?auto=compress&cs=tinysrgb&w=1620",
    "typingVideo": "https://videos.pexels.com/video-files/8480685/8480685-hd_1080_1920_25fps.mp4",
    "keyPoints": [
      {
        "point": "Perfectionism is fear wearing a productivity costume."
      },
      {
        "point": "A published 80% beats an unpublished 100% every single week."
      },
      {
        "point": "Your archive is your résumé — and archives are built by shipping."
      }
    ],
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "title",
      "duration": 4.4,
      "backgroundColor": "#17130E",
      "transition": "smoothleft",
      "transitionId": "point",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{typingVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='sbsShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#17130E' stop-opacity='0.6'/><stop offset='0.45' stop-color='#17130E' stop-opacity='0.3'/><stop offset='1' stop-color='#17130E' stop-opacity='0.92'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#sbsShade)'/><path d='M80 1210 H260' stroke='#E7A84C' stroke-width='5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 160,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Lora" },
          "html": "<div style='display:inline-block; border:1.5px solid rgba(231,168,76,0.6); color:#E7A84C; border-radius:999px; padding:12px 32px; font-size:24px; letter-spacing:4px;'>{{blogName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 1260,
          "width": 920,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Lora" },
          "html": "<div style='color:#F5EFE4; font-size:72px; line-height:1.15; font-weight:700;'>{{articleTitle}}</div><div style='margin-top:18px; color:#B3A489; font-size:27px;'>{{authorName}} · {{readTime}}</div>"
        }
      ]
    },
    {
      "id": "point",
      "iterate": "keyPoints",
      "iterateAs": "kp",
      "duration": 3.6,
      "backgroundColor": "#17130E",
      "transition": "smoothleft",
      "transitionId": "cta",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{bgImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "opacity": 0.22,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='rgba(23,19,14,0.62)'/><text x='110' y='800' font-family='Georgia' font-size='200' fill='rgba(231,168,76,0.5)'>&#8220;</text><path d='M110 1210 H970' stroke='rgba(231,168,76,0.3)' stroke-width='1'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 830,
          "width": 820,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Lora" },
          "html": "<div style='color:#F5EFE4; font-size:54px; line-height:1.35; font-style:italic;'>{{kp.point}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 96,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "style": { "fontFamily": "Lora" },
          "html": "<div style='color:rgba(245,239,228,0.65); font-size:22px; letter-spacing:5px;'>{{blogName}} — {{articleTitle}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 3.8,
      "backgroundColor": "#17130E",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='sbsEnd' cx='0.5' cy='0.4' r='0.9'><stop offset='0' stop-color='#241D13'/><stop offset='1' stop-color='#17130E'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#sbsEnd)'/><path d='M400 620 H680 M400 680 H680 M400 740 H600' stroke='rgba(231,168,76,0.5)' stroke-width='10' stroke-linecap='round'/><rect x='350' y='540' width='380' height='280' rx='20' fill='none' stroke='rgba(231,168,76,0.6)' stroke-width='3'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 940,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Lora" },
          "html": "<div style='text-align:center; color:#F5EFE4; font-size:58px; line-height:1.2; font-weight:700;'>The full essay goes deeper.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1220,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.8,
          "enterEnd": 1.2,
          "enterAnimation": "circleopen",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='display:inline-block; background:#E7A84C; color:#17130E; border-radius:999px; padding:24px 60px; font-size:32px; font-weight:800;'>{{ctaText}} →</div><div style='margin-top:16px; text-align:center; color:#8C7F68; font-size:23px; letter-spacing:1px;'>{{articleUrl}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.14
    }
  ]
}
