          "y": 380,
          "width": 936,
          "height": 560,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "radius": { "tl": 40, "tr": 40, "bl": 40, "br": 40 },
          "track": 1,
          "enterBegin": 0,
          "enterEnd": 0.55,
          "enterAnimation": "smoothdown",
          "exitEnd": 5.6
        },
        {
          "type": "TEXT",
          "x": 120,
          "y": 760,
          "anchor": "top-left",
          "track": 10,
