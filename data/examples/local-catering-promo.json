        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1620,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.1,
          "enterEnd": 1.55,
          "enterAnimation": "fade",
          "exitEnd": 5.6,
          "style": { "fontFamily": "DM Sans" },
