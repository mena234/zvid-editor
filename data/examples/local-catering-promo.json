        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 800,
          "width": 920,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Fraunces" },
          "html": "<div style='text-align:center; color:#F0F3E9; font-size:78px; line-height:1.05; font-weight:600; font-style:italic;'>Let's plan<br>your table.</div>"
