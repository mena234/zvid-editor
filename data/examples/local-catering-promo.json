        {
          "type": "TEXT",
          "x": 540,
          "y": 1290,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.05,
          "enterEnd": 1.45,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "DM Sans" },
