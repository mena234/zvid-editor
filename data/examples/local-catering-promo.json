{
  "name": "local-catering-promo",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#10160F",
  "outputFormat": "mp4",
  "variables": {
    "brandName": "GARDEN & GRAIN",
    "kicker": "EVENTS & CORPORATE CATERING",
    "headline": "We bring the whole table to you.",
    "subLine": "Weddings, office lunches, launch parties — fresh, seasonal spreads plated by our team.",
    "badgeText": "NOW BOOKING Q3",
    "showBadge": true,
    "featuresLabel": "WHAT YOU GET",
    "features": [
      { "title": "Seasonal menus", "desc": "Built around your headcount & dietary needs" },
      { "title": "Full setup & staff", "desc": "We plate, serve and clear — you host" },
      { "title": "Zero-waste packing", "desc": "Compostable ware, leftovers boxed to give" }
    ],
    "minGuests": "Minimum 20 guests · 72h notice",
    "ctaText": "Request a quote",
    "ctaUrl": "gardenandgrain.co / catering",
    "accentColor": "#8FB56A",
    "spreadImage": "https://images.unsplash.com/photo-1623428187969-5da2dcea5ebf?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3MDgwMTZ8MHwxfHNlYXJjaHw0fHxoZWFsdGh5JTIwZm9vZCUyMHNhbGFkJTIwYm93bCUyMGZyZXNofGVufDB8fHx8MTc4MzI2ODU4MHww&ixlib=rb-4.1.0&q=80&w=1080",
    "detailImage": "https://images.unsplash.com/photo-1600335895229-6e75511892c8?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3MDgwMTZ8MHwxfHNlYXJjaHwzfHxoZWFsdGh5JTIwZm9vZCUyMHNhbGFkJTIwYm93bCUyMGZyZXNofGVufDB8fHx8MTc4MzI2ODU4MHww&ixlib=rb-4.1.0&q=80&w=1080",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "hook",
      "duration": 4.2,
      "backgroundColor": "#10160F",
      "transition": "smoothleft",
      "transitionId": "offer",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{spreadImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.2
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='catShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#10160F' stop-opacity='0.62'/><stop offset='0.42' stop-color='#10160F' stop-opacity='0.08'/><stop offset='0.72' stop-color='#10160F' stop-opacity='0.4'/><stop offset='1' stop-color='#10160F' stop-opacity='0.96'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#catShade)'/></svg>"
        },
        {
          "type": "TEXT",
          "condition": "{{showBadge}}",
          "x": 540,
          "y": 140,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.7,
          "enterAnimation": "smoothdown",
          "exitEnd": 4.2,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#10160F; border-radius:999px; padding:14px 34px; font-size:24px; font-weight:700; letter-spacing:5px;'>{{badgeText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1230,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.55,
          "enterEnd": 1.05,
          "enterAnimation": "smoothup",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Fraunces" },
          "html": "<div style='color:{{accentColor}}; font-size:26px; font-weight:700; letter-spacing:5px; font-family:DM Sans, sans-serif;'>{{kicker}}</div><div style='margin-top:16px; color:#F0F3E9; font-size:90px; line-height:1.02; font-weight:600; font-style:italic;'>{{headline}}</div><div style='margin-top:22px; color:#BBC6AE; font-size:32px; line-height:1.45; font-weight:400; font-family:DM Sans, sans-serif;'>{{subLine}}</div>"
        }
      ]
