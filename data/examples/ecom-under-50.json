{
  "name": "ecom-under-50",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#FBF4EC",
  "outputFormat": "mp4",
  "variables": {
    "brandName": "GOODFIND",
    "priceCap": "$50",
    "introLine": "5 finds under $50 you'll actually use",
    "introSub": "No filler. Everything ships free this week.",
    "accentColor": "#F0552B",
    "inkColor": "#1E140E",
    "ctaText": "Shop under $50",
    "ctaHandle": "goodfind.example/under50",
    "picks": [
      { "name": "Ribbed knit beanie", "meta": "Merino blend · 6 colors", "price": "$28", "image": "https://images.pexels.com/photos/14534753/pexels-photo-14534753.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" },
      { "name": "Canvas crossbody", "meta": "Water-resistant · fits a 13\"", "price": "$44", "image": "https://images.pexels.com/photos/32549949/pexels-photo-32549949.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" },
      { "name": "Ceramic pour-over", "meta": "Makes 2 cups · no filter waste", "price": "$36", "image": "https://images.pexels.com/photos/32549955/pexels-photo-32549955.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" },
      { "name": "Linen table runner", "meta": "Stonewashed · machine wash", "price": "$32", "image": "https://images.pexels.com/photos/18699687/pexels-photo-18699687.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" },
      { "name": "Everyday tumbler", "meta": "24oz · keeps cold 18 hrs", "price": "$29", "image": "https://images.pexels.com/photos/18699686/pexels-photo-18699686.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" }
    ],
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "intro",
      "duration": 3.2,
      "backgroundColor": "#FBF4EC",
      "transition": "slideleft",
      "transitionId": "pick",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#FBF4EC'/><circle cx='540' cy='560' r='260' fill='#F0552B'/><circle cx='540' cy='560' r='260' fill='none' stroke='#1E140E' stroke-width='4'/><path d='M120 1040 H960' stroke='rgba(30,20,14,0.14)' stroke-width='3'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 560,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "circleopen",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FBF4EC; font-size:44px; font-weight:800; letter-spacing:2px;'>UNDER</div><div style='text-align:center; color:#FBF4EC; font-size:180px; line-height:0.9; font-weight:800; letter-spacing:-6px;'>{{priceCap}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1120,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:{{inkColor}}; font-size:76px; line-height:1.08; font-weight:800; letter-spacing:-2px;'>{{introLine}}</div><div style='margin-top:20px; text-align:center; color:#8A7B6E; font-size:30px; font-weight:500;'>{{introSub}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 130,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.1,
          "enterEnd": 0.5,
          "enterAnimation": "fade",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:{{accentColor}}; font-size:26px; font-weight:800; letter-spacing:8px;'>{{brandName}}</div>"
        }
      ]
    },
    {
      "id": "pick",
      "iterate": "picks",
      "iterateAs": "p",
      "duration": 3,
      "backgroundColor": "#FBF4EC",
      "transition": "slideleft",
      "transitionId": "cta",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#FBF4EC'/><rect x='72' y='1140' width='936' height='640' rx='40' fill='#FFFFFF' stroke='rgba(30,20,14,0.12)' stroke-width='1.5'/><rect x='72' y='1140' width='936' height='10' rx='5' fill='#F0552B'/></svg>"
        },
        {
          "type": "IMAGE",
          "src": "{{p.image}}",
          "x": 540,
          "y": 560,
          "width": 936,
          "height": 1000,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "radius": { "tl": 40, "tr": 40, "bl": 40, "br": 40 },
          "track": 1,
          "enterBegin": 0,
          "enterEnd": 0.45,
          "enterAnimation": "smoothright",
          "exitEnd": 3
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 1210,
          "width": 620,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 3,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:{{inkColor}}; font-size:60px; line-height:1.04; font-weight:800; letter-spacing:-1px;'>{{p.name}}</div><div style='margin-top:14px; color:#8A7B6E; font-size:30px; font-weight:500;'>{{p.meta}}</div>"
        },
        {
          "type": "TEXT",
          "x": 950,
          "y": 1230,
          "anchor": "top-right",
          "track": 11,
          "enterBegin": 0.55,
          "enterEnd": 1,
          "enterAnimation": "smoothleft",
          "exitEnd": 3,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#FBF4EC; border-radius:14px; padding:16px 34px; font-size:52px; font-weight:800;'>{{p.price}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 3.8,
      "backgroundColor": "#1E140E",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#1E140E'/><circle cx='540' cy='700' r='210' fill='none' stroke='rgba(240,85,43,0.7)' stroke-width='4'/><circle cx='540' cy='700' r='240' fill='none' stroke='rgba(240,85,43,0.25)' stroke-width='2'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 700,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "circleopen",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:130px; line-height:0.9; font-weight:800; letter-spacing:-4px;'>{{priceCap}}</div><div style='text-align:center; color:#FBF4EC; font-size:36px; font-weight:800; letter-spacing:4px;'>OR LESS</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1080,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.65,
          "enterEnd": 1.1,
          "enterAnimation": "smoothup",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#FBF4EC; border-radius:999px; padding:26px 64px; font-size:42px; font-weight:800;'>{{ctaText}}</div><div style='margin-top:24px; text-align:center; color:#9A8A7C; font-size:26px; font-weight:600; letter-spacing:2px;'>{{ctaHandle}}</div>"
        }
      ]
    }
  ],
  "audios": [
    { "src": "{{musicUrl}}", "volume": 0.16 }
  ]
}
