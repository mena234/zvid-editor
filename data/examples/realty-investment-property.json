          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.7,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='color:#D4AF6A; font-size:26px; font-weight:800; letter-spacing:7px;'>{{fundName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1370,
          "width": 920,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "Sora"
          },
