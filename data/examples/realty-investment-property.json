    "fundName": "MERIDIAN CAPITAL",
    "kicker": "INVESTMENT OPPORTUNITY",
    "propertyName": "Harbourfront Residences",
    "locationLine": "Docklands · Zone 2",
    "priceLine": "£465,000",
    "summaryLine": "A tenanted 2-bed with strong yield in a high-demand rental corridor.",
    "closingHead": "Numbers that<br>compound.",
    "ctaLine": "Request the full investment memo.",
    "handle": "meridiancapital.co / invest",
    "showDisclaimer": true,
    "disclaimer": "Illustrative figures. Past performance is not a guarantee of future returns.",
    "accent": "#D4AF6A",
    "stats": [
      {
        "label": "NET RENTAL YIELD",
        "value": "6.8%",
        "note": "vs 4.1% area average",
        "index": "01"
      },
      {
        "label": "MONTHLY RENT",
        "value": "£2,640",
        "note": "AST in place until 2027",
        "index": "02"
      },
      {
        "label": "5-YR PRICE GROWTH",
        "value": "+34%",
        "note": "Postcode trailing average",
        "index": "03"
      }
    ],
    "heroImage": "https://images.pexels.com/photos/26851069/pexels-photo-26851069.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
