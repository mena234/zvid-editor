{
  "name": "ai-prompt-result",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#07070D",
  "outputFormat": "mp4",
  "variables": {
    "toolName": "NOVA AI",
    "kicker": "PROMPT → RESULT",
    "promptLabel": "YOU TYPED",
    "promptText": "a neon cyberpunk city at night, cinematic, ultra-detailed",
    "resultLabel": "NOVA GENERATED",
    "resultLine1": "One line in.",
    "resultLine2": "A whole world out.",
    "resultSub": "Turn a single sentence into a finished visual in seconds.",
    "showBadge": true,
    "badgeText": "8 SEC RENDER",
    "ctaText": "Try your first prompt free",
    "ctaHandle": "nova.ai/create",
    "accentColor": "#7C5CFF",
    "resultVideo": "https://videos.pexels.com/video-files/7639980/7639980-hd_1080_1920_30fps.mp4",
    "promptImage": "https://images.pexels.com/photos/9665181/pexels-photo-9665181.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "prompt",
      "duration": 4,
      "backgroundColor": "#07070D",
      "transition": "wipeleft",
      "transitionId": "result",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{promptImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "opacity": 0.32,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='pShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#07070D' stop-opacity='0.8'/><stop offset='0.5' stop-color='#07070D' stop-opacity='0.5'/><stop offset='1' stop-color='#07070D' stop-opacity='0.95'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#pShade)'/><rect x='90' y='760' width='900' height='400' rx='28' fill='rgba(124,92,255,0.06)' stroke='rgba(124,92,255,0.45)' stroke-width='1.5'/><circle cx='150' cy='822' r='10' fill='#FF5F56'/><circle cx='188' cy='822' r='10' fill='#FFBD2E'/><circle cx='226' cy='822' r='10' fill='#27C93F'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 150,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; border:1.5px solid rgba(124,92,255,0.6); border-radius:999px; padding:14px 34px; color:#C7BBFF; font-size:24px; font-weight:700; letter-spacing:6px;'>{{kicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 792,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.5,
          "enterEnd": 0.95,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": { "fontFamily": "JetBrains Mono" },
          "html": "<div style='color:#7A7A94; font-size:20px; font-weight:700; letter-spacing:6px; font-family:monospace;'>{{promptLabel}}</div>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 862,
          "width": 820,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.8,
          "enterEnd": 1.3,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "JetBrains Mono" },
          "html": "<div style='color:#F2F0FF; font-size:38px; line-height:1.5; font-weight:500; font-family:monospace;'>{{promptText}}<span style='color:{{accentColor}};'>|</span></div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1300,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 1.1,
          "enterEnd": 1.55,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:#8C86A8; font-size:34px; font-weight:600;'>Watch what happens next</div>"
        }
      ]
    },
    {
      "id": "result",
      "duration": 5,
      "backgroundColor": "#07070D",
      "transition": "fade",
      "transitionId": "cta",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{resultVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 5
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 5,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='rShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#07070D' stop-opacity='0.6'/><stop offset='0.45' stop-color='#07070D' stop-opacity='0.15'/><stop offset='1' stop-color='#07070D' stop-opacity='0.94'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#rShade)'/><rect x='72' y='1170' width='6' height='430' rx='3' fill='#7C5CFF'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 118,
          "y": 1180,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.35,
          "enterEnd": 0.8,
          "enterAnimation": "smoothleft",
          "exitEnd": 5,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:{{accentColor}}; font-size:24px; font-weight:800; letter-spacing:5px;'>{{resultLabel}}</div>"
        },
        {
          "type": "TEXT",
          "x": 118,
          "y": 1230,
          "width": 880,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.55,
          "enterEnd": 1.05,
          "enterAnimation": "smoothup",
          "exitEnd": 5,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:#FFFFFF; font-size:80px; line-height:1.02; font-weight:800; letter-spacing:-2px;'>{{resultLine1}}<br>{{resultLine2}}</div><div style='margin-top:22px; color:#C6C1DE; font-size:31px; line-height:1.4; font-weight:500;'>{{resultSub}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showBadge}}",
          "x": 118,
          "y": 150,
          "anchor": "top-left",
          "track": 12,
          "enterBegin": 0.7,
          "enterEnd": 1.1,
          "enterAnimation": "circleopen",
          "exitEnd": 5,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#0A0714; border-radius:12px; padding:14px 30px; font-size:26px; font-weight:800; letter-spacing:2px;'>{{badgeText}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 4.4,
      "backgroundColor": "#07070D",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='ctaGlow' cx='0.5' cy='0.4' r='0.85'><stop offset='0' stop-color='#1C1440'/><stop offset='1' stop-color='#07070D'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#ctaGlow)'/><circle cx='540' cy='640' r='140' fill='none' stroke='rgba(124,92,255,0.85)' stroke-width='2.5'/><circle cx='540' cy='640' r='164' fill='none' stroke='rgba(124,92,255,0.3)' stroke-width='1'/><path d='M498 640 L528 670 L586 606' fill='none' stroke='#7C5CFF' stroke-width='9' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 870,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#C7BBFF; font-size:24px; font-weight:800; letter-spacing:6px;'>{{toolName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 940,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.45,
          "enterEnd": 0.95,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:70px; line-height:1.05; font-weight:800; letter-spacing:-1px;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1230,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.85,
          "enterEnd": 1.3,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#0A0714; border-radius:999px; padding:28px 68px; font-size:38px; font-weight:800;'>{{ctaHandle}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.16
    }
  ]
}
