{
  "name": "sports-player-stats",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#04120F",
  "outputFormat": "mp4",
  "variables": {
    "kicker": "PLAYER OF THE MATCH",
    "playerName": "ERLING HAALAND",
    "position": "STRIKER · #9",
    "team": "MANCHESTER CITY",
    "accentColor": "#FF7A18",
    "ratingLabel": "MATCH RATING",
    "rating": "9.4",
    "stats": [
      { "label": "GOALS", "value": "2", "note": "Both inside the box" },
      { "label": "SHOTS ON TARGET", "value": "4", "note": "82% conversion" },
      { "label": "TOUCHES", "value": "38", "note": "Led the front line" },
      { "label": "PASS ACCURACY", "value": "91%", "note": "27 of 30 completed" }
    ],
    "footerLine": "A complete centre-forward display.",
    "playerImage": "https://images.pexels.com/photos/159594/soccer-football-player-sport-159594.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "hero",
      "duration": 4,
      "backgroundColor": "#04120F",
      "transition": "smoothleft",
      "transitionId": "stat",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{playerImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.55,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='psHero' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#04120F' stop-opacity='0.72'/><stop offset='0.45' stop-color='#04120F' stop-opacity='0.3'/><stop offset='1' stop-color='#04120F' stop-opacity='0.97'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#psHero)'/><rect x='90' y='1250' width='8' height='420' rx='4' fill='#FF7A18'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 1270,
          "width": 860,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.75,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:{{accentColor}}; font-size:28px; font-weight:700; letter-spacing:6px;'>{{kicker}}</div><div style='margin-top:16px; color:#FFFFFF; font-size:104px; line-height:0.95; font-weight:700; letter-spacing:-3px;'>{{playerName}}</div><div style='margin-top:20px; color:#7FD9C4; font-size:30px; font-weight:600; letter-spacing:3px;'>{{position}} · {{team}}</div>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 1680,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "smoothleft",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#04120F; border-radius:16px; padding:16px 34px; font-size:34px; font-weight:700;'>{{ratingLabel}} {{rating}}</div>"
        }
      ]
    },
    {
      "id": "stat",
      "iterate": "stats",
      "iterateAs": "s",
      "duration": 2.8,
      "backgroundColor": "#04120F",
      "transition": "smoothleft",
      "transitionId": "outro",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 2.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='psStat' cx='0.5' cy='0.38' r='0.9'><stop offset='0' stop-color='#0A2620'/><stop offset='1' stop-color='#04120F'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#psStat)'/><circle cx='540' cy='760' r='320' fill='none' stroke='rgba(255,122,24,0.35)' stroke-width='2'/><circle cx='540' cy='760' r='360' fill='none' stroke='rgba(127,217,196,0.16)' stroke-width='1.5'/><rect x='90' y='1380' width='900' height='4' fill='rgba(255,255,255,0.12)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 470,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "smoothup",
          "exitEnd": 2.8,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#7FD9C4; font-size:32px; font-weight:700; letter-spacing:6px;'>{{s.label}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 600,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.8,
          "enterAnimation": "circleopen",
          "exitEnd": 2.8,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:300px; line-height:0.9; font-weight:700; letter-spacing:-8px;'>{{s.value}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1030,
          "width": 800,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.6,
          "enterEnd": 1.05,
          "enterAnimation": "fade",
          "exitEnd": 2.8,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:rgba(255,122,24,0.14); border:1.5px solid rgba(255,122,24,0.5); color:{{accentColor}}; border-radius:999px; padding:14px 36px; font-size:30px; font-weight:600;'>{{s.note}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1440,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 2.8,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:rgba(255,255,255,0.55); font-size:24px; font-weight:700; letter-spacing:4px;'>{{playerName}} · {{team}}</div>"
        }
      ]
    },
    {
      "id": "outro",
      "duration": 3.6,
      "backgroundColor": "#04120F",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='psOut' cx='0.5' cy='0.42' r='0.9'><stop offset='0' stop-color='#0B2C24'/><stop offset='1' stop-color='#04120F'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#psOut)'/><path d='M470 640 l60 60 l120 -140' fill='none' stroke='#FF7A18' stroke-width='16' stroke-linecap='round' stroke-linejoin='round'/><circle cx='540' cy='700' r='140' fill='none' stroke='rgba(255,122,24,0.5)' stroke-width='3'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 940,
          "width": 880,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:64px; line-height:1.15; font-weight:700;'>{{footerLine}}</div><div style='margin-top:26px; text-align:center; color:{{accentColor}}; font-size:30px; font-weight:700; letter-spacing:5px;'>{{playerName}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.15
    }
  ]
}
