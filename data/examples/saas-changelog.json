{
  "name": "saas-changelog",
  "resolution": "instagram-post",
  "frameRate": 30,
  "backgroundColor": "#0D1117",
  "outputFormat": "mp4",
  "variables": {
    "productName": "shipfast",
    "versionTag": "v2.14.0",
    "releaseDate": "July 5, 2026",
    "summaryLine": "Fresh from the pipeline this week:",
    "ctaText": "Full notes at shipfast.example/changelog",
    "changes": [
      {
        "kind": "NEW",
        "color": "#3FB950",
        "text": "Webhook retries with exponential backoff — no more lost events"
      },
      {
        "kind": "IMPROVED",
        "color": "#58A6FF",
        "text": "Dashboard loads 3× faster on workspaces with 10k+ items"
      },
      {
        "kind": "FIXED",
        "color": "#F0883E",
        "text": "Timezone drift in scheduled exports for UTC+ regions"
      }
    ],
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "header",
      "duration": 3.4,
      "backgroundColor": "#0D1117",
      "transition": "slideup",
      "transitionId": "entry",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1080,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1080' viewBox='0 0 1080 1080' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1080' fill='#0D1117'/><rect x='90' y='300' width='900' height='480' rx='20' fill='#161B22' stroke='rgba(139,148,158,0.3)' stroke-width='1.5'/><rect x='90' y='300' width='900' height='56' rx='20' fill='#21262D'/><circle cx='134' cy='328' r='8' fill='#FF5F56'/><circle cx='162' cy='328' r='8' fill='#FFBD2E'/><circle cx='190' cy='328' r='8' fill='#27C93F'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 150,
          "y": 420,
          "width": 800,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 3.4,
          "style": { "fontFamily": "JetBrains Mono" },
          "html": "<div style='color:#8B949E; font-size:26px;'>$ {{productName}} release --latest</div><div style='margin-top:24px; color:#E6EDF3; font-size:76px; font-weight:700;'>{{versionTag}}</div><div style='margin-top:14px; color:#3FB950; font-size:27px;'>● shipped {{releaseDate}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 880,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.7,
          "enterEnd": 1.1,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": { "fontFamily": "JetBrains Mono" },
          "html": "<div style='text-align:center; color:#8B949E; font-size:28px;'>{{summaryLine}}</div>"
        }
      ]
    },
    {
      "id": "entry",
      "iterate": "changes",
      "iterateAs": "change",
      "duration": 3.2,
      "backgroundColor": "#0D1117",
      "transition": "slideup",
      "transitionId": "footer",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1080,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "svg": "<svg width='1080' height='1080' viewBox='0 0 1080 1080' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1080' fill='#0D1117'/><path d='M120 140 V940' stroke='rgba(139,148,158,0.25)' stroke-width='2'/><circle cx='120' cy='420' r='12' fill='#E6EDF3'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 180,
          "y": 340,
          "width": 800,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "smoothleft",
          "exitEnd": 3.2,
          "style": { "fontFamily": "JetBrains Mono" },
          "html": "<div><span style='display:inline-block; border:2px solid {{change.color}}; color:{{change.color}}; border-radius:10px; padding:8px 24px; font-size:26px; font-weight:700; letter-spacing:3px;'>{{change.kind}}</span></div><div style='margin-top:34px; color:#E6EDF3; font-size:46px; line-height:1.4; font-weight:500;'>{{change.text}}</div>"
        },
        {
          "type": "TEXT",
          "x": 180,
          "y": 940,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "style": { "fontFamily": "JetBrains Mono" },
          "html": "<div style='color:#484F58; font-size:22px;'>{{productName}} {{versionTag}} · changelog</div>"
        }
      ]
    },
    {
      "id": "footer",
      "duration": 3.4,
      "backgroundColor": "#0D1117",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1080,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1080' viewBox='0 0 1080 1080' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1080' fill='#0D1117'/><path d='M470 380 L540 310 L610 380 M540 316 V520' stroke='#3FB950' stroke-width='12' fill='none' stroke-linecap='round' stroke-linejoin='round'/><rect x='400' y='520' width='280' height='20' rx='10' fill='rgba(63,185,80,0.4)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 640,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": { "fontFamily": "JetBrains Mono" },
          "html": "<div style='text-align:center; color:#E6EDF3; font-size:52px; font-weight:700;'>Update now, thank us later.</div><div style='margin-top:24px; text-align:center; color:#8B949E; font-size:26px;'>{{ctaText}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.15
    }
  ]
}
