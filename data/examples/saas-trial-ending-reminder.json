{
  "name": "saas-trial-ending-reminder",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#160A14",
  "outputFormat": "mp4",
  "variables": {
    "firstName": "Jordan",
    "kicker": "YOUR TRIAL",
    "daysLeft": "3",
    "hookLine": "days left on your trial.",
    "recapLine": "Here's what you'd lose access to:",
    "loss1": "Your 14 saved workspaces",
    "loss2": "Automations running in the background",
    "loss3": "Team seats you've invited",
    "showOffer": true,
    "offerText": "Upgrade now — 20% off your first year",
    "ctaText": "Keep my account",
    "handle": "app.getpulse.io/billing",
    "productName": "Pulse",
    "accent": "#FF3D8B",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "hook",
      "duration": 4.2,
      "backgroundColor": "#160A14",
      "transition": "smoothup",
      "transitionId": "recap",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='teHook' cx='0.5' cy='0.36' r='0.95'><stop offset='0' stop-color='#2E1226'/><stop offset='1' stop-color='#160A14'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#teHook)'/><circle cx='540' cy='640' r='240' fill='none' stroke='rgba(255,61,139,0.2)' stroke-width='14'/><circle cx='540' cy='640' r='240' fill='none' stroke='#FF3D8B' stroke-width='14' stroke-linecap='round' stroke-dasharray='1130' stroke-dashoffset='420' transform='rotate(-90 540 640)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 540,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "circleopen",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:220px; line-height:1; font-weight:700; letter-spacing:-6px;'>{{daysLeft}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 700,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.8,
          "enterAnimation": "fade",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:{{accent}}; font-size:34px; font-weight:800; letter-spacing:5px;'>{{kicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1020,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.55,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:70px; line-height:1.1; font-weight:700; letter-spacing:-1px;'>{{firstName}}, only {{daysLeft}}<br>{{hookLine}}</div>"
        }
      ]
    },
    {
      "id": "recap",
      "duration": 5,
      "backgroundColor": "#160A14",
      "transition": "smoothleft",
      "transitionId": "cta",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 5,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#160A14'/><rect x='90' y='620' width='900' height='150' rx='24' fill='rgba(255,61,139,0.05)' stroke='rgba(255,61,139,0.28)' stroke-width='1.5'/><rect x='90' y='800' width='900' height='150' rx='24' fill='rgba(255,61,139,0.05)' stroke='rgba(255,61,139,0.28)' stroke-width='1.5'/><rect x='90' y='980' width='900' height='150' rx='24' fill='rgba(255,61,139,0.05)' stroke='rgba(255,61,139,0.28)' stroke-width='1.5'/><path d='M150 695 L175 720 L215 675 M150 875 L175 900 L215 855 M150 1055 L175 1080 L215 1035' fill='none' stroke='#FF3D8B' stroke-width='6' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 400,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "smoothup",
          "exitEnd": 5,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:56px; line-height:1.15; font-weight:700;'>{{recapLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 250,
          "y": 695,
          "width": 700,
          "anchor": "center-left",
          "track": 11,
          "enterBegin": 0.45,
          "enterEnd": 0.9,
          "enterAnimation": "smoothleft",
          "exitEnd": 5,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='color:#FFFFFF; font-size:36px; font-weight:600;'>{{loss1}}</div>"
        },
        {
          "type": "TEXT",
          "x": 250,
          "y": 875,
          "width": 700,
          "anchor": "center-left",
          "track": 11,
          "enterBegin": 0.65,
          "enterEnd": 1.1,
          "enterAnimation": "smoothleft",
          "exitEnd": 5,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='color:#FFFFFF; font-size:36px; font-weight:600;'>{{loss2}}</div>"
        },
        {
          "type": "TEXT",
          "x": 250,
          "y": 1055,
          "width": 700,
          "anchor": "center-left",
          "track": 11,
          "enterBegin": 0.85,
          "enterEnd": 1.3,
          "enterAnimation": "smoothleft",
          "exitEnd": 5,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='color:#FFFFFF; font-size:36px; font-weight:600;'>{{loss3}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showOffer}}",
          "x": 540,
          "y": 1280,
          "width": 900,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.1,
          "enterEnd": 1.55,
          "enterAnimation": "smoothup",
          "exitEnd": 5,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:rgba(255,61,139,0.16); border:1.5px solid rgba(255,61,139,0.6); color:#FF9DC4; border-radius:20px; padding:20px 40px; font-size:33px; font-weight:700;'>{{offerText}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 4.2,
      "backgroundColor": "#160A14",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='teCta' cx='0.5' cy='0.42' r='0.9'><stop offset='0' stop-color='#2E1226'/><stop offset='1' stop-color='#160A14'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#teCta)'/><rect x='48' y='48' width='984' height='1824' rx='36' fill='none' stroke='rgba(255,61,139,0.35)' stroke-width='1.5'/><path d='M540 560 C540 520 500 500 470 520 C440 540 470 600 540 660 C610 600 640 540 610 520 C580 500 540 520 540 560 Z' fill='#FF3D8B'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 820,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.75,
          "enterAnimation": "smoothup",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:70px; line-height:1.1; font-weight:700; letter-spacing:-1px;'>Don't lose your<br>momentum, {{firstName}}.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1130,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.75,
          "enterEnd": 1.2,
          "enterAnimation": "smoothup",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:{{accent}}; color:#160A14; border-radius:999px; padding:26px 60px; font-size:38px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1300,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.15,
          "enterEnd": 1.55,
          "enterAnimation": "fade",
          "exitEnd": 4.2,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='text-align:center; color:#A66888; font-size:26px; font-weight:600; letter-spacing:2px;'>{{productName}} · {{handle}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.16
    }
  ]
}
