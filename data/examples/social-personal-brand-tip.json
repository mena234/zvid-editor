        {
          "type": "TEXT",
          "x": 90,
          "y": 150,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "smoothleft",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='display:inline-block; background:rgba(255,138,91,0.18); border:1.5px solid rgba(255,138,91,0.6); color:#FF8A5B; border-radius:999px; padding:12px 30px; font-size:26px; font-weight:800; letter-spacing:4px;'>{{kicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1350,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Syne" },
