{
  "name": "social-personal-brand-tip",
  "resolution": "tiktok",
  "frameRate": 30,
  "backgroundColor": "#1A0F1E",
  "outputFormat": "mp4",
  "variables": {
    "creatorName": "MAYA RIVERA",
    "creatorTitle": "personal brand coach",
    "kicker": "BRAND TIP OF THE DAY",
    "tipNumber": "07",
    "tipHeadline": "Be known for<br>one thing first",
    "tipBody": "The fastest way to be forgettable is to post about everything. Pick one lane, own it for 90 days, then expand.",
    "proofLabel": "WHY IT WORKS",
    "proofText": "Specific creators get recommended, quoted and remembered. Generalists get scrolled past.",
    "accent": "#FF8A5B",
    "accent2": "#B06AFF",
    "sunsetImage": "https://images.pexels.com/photos/12963517/pexels-photo-12963517.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "sunsetVideo": "https://videos.pexels.com/video-files/34398523/14572776_1440_2560_30fps.mp4",
    "showOffer": true,
    "offerLabel": "FREE THIS WEEK",
    "offerText": "My 1-page brand clarity worksheet — link in bio",
    "ctaText": "Follow for a brand tip daily",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
