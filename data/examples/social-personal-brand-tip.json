        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 700,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 4.6,
          "style": { "fontFamily": "Syne" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:72px; line-height:1.06; font-weight:800; letter-spacing:-2px;'>Own your lane.<br>Then widen it.</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showOffer}}",
          "x": 540,
          "y": 1050,
          "width": 880,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.6,
          "enterEnd": 1.05,
          "enterAnimation": "circleopen",
          "exitEnd": 4.6,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='display:inline-block; background:rgba(176,106,255,0.18); border:1.5px solid rgba(176,106,255,0.6); color:#D8BBFF; border-radius:20px; padding:22px 40px;'><span style='display:block; color:#B06AFF; font-size:24px; font-weight:800; letter-spacing:4px;'>{{offerLabel}}</span><span style='display:block; margin-top:8px; color:#F1E6FA; font-size:32px; font-weight:600;'>{{offerText}}</span></div>"
        },
        {
