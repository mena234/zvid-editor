      "transitionId": "tip",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{sunsetVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.8
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='brandA' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#1A0F1E' stop-opacity='0.55'/><stop offset='0.45' stop-color='#1A0F1E' stop-opacity='0.15'/><stop offset='1' stop-color='#1A0F1E' stop-opacity='0.95'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#brandA)'/><rect x='90' y='1300' width='130' height='8' rx='4' fill='#FF8A5B'/></svg>"
