        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1560,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.85,
          "enterEnd": 1.3,
          "enterAnimation": "fade",
          "exitEnd": 5,
