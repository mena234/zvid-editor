{
  "name": "realty-agent-branded",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0D2B26",
  "outputFormat": "mp4",
  "variables": {
    "agentName": "Dana Whitfield",
    "agentTitle": "Senior Partner · Grove & Key Realty",
    "personalLine": "I don't sell houses. I negotiate the next chapter of your life.",
    "statSold": "140+",
    "statYears": "12",
    "statRating": "4.9★",
    "showStats": true,
    "agentPhone": "(555) 210-8890",
    "agentInstagram": "@dana.sells.maplewood",
    "ctaText": "Free home valuation this month",
    "agentImage": "https://images.pexels.com/photos/30781748/pexels-photo-30781748.jpeg?auto=compress&cs=tinysrgb&w=1620",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "portrait",
      "duration": 5,
      "backgroundColor": "#0D2B26",
      "transition": "smoothleft",
      "transitionId": "stats",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{agentImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 5
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 5,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='rabShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0D2B26' stop-opacity='0.4'/><stop offset='0.5' stop-color='#0D2B26' stop-opacity='0.05'/><stop offset='1' stop-color='#0D2B26' stop-opacity='0.9'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#rabShade)'/><path d='M80 1420 H360' stroke='#EFB65C' stroke-width='4'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 1460,
          "width": 920,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 5,
          "style": {
            "fontFamily": "Fraunces"
          },
          "html": "<div style='color:#F7F3EA; font-size:82px; line-height:1; font-weight:700; letter-spacing:-1px;'>{{agentName}}</div><div style='margin-top:14px; font-family:Manrope, sans-serif; color:#BFD3C5; font-size:27px; font-weight:600; letter-spacing:1px;'>{{agentTitle}}</div>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 1690,
          "width": 920,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.9,
          "enterEnd": 1.4,
          "enterAnimation": "fade",
          "exitEnd": 5,
          "style": {
            "fontFamily": "Fraunces"
          },
          "html": "<div style='color:#EFB65C; font-size:32px; line-height:1.35; font-style:italic;'>{{personalLine}}</div>"
        }
      ]
    },
    {
      "id": "stats",
      "condition": "{{showStats}}",
      "duration": 4.4,
      "backgroundColor": "#0D2B26",
      "transition": "smoothup",
      "transitionId": "reach-out",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4,
