{
  "name": "social-news-summary",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#101113",
  "outputFormat": "mp4",
  "variables": {
    "outletName": "THE MORNING WIRE",
    "kicker": "TECH · TODAY",
    "headline": "EU approves landmark AI transparency rules",
    "dateLine": "July 5, 2026 · 08:00 CET",
    "point1": "All consumer AI products must disclose training data sources by 2028.",
    "point2": "Fines reach 6% of global revenue for non-compliance.",
    "point3": "Startups under 50 employees get a 2-year grace period.",
    "sourceNote": "Summary of reporting by Reuters & FT",
    "showSource": true,
    "ctaText": "Full story in bio",
    "bgImage": "https://images.pexels.com/photos/14604033/pexels-photo-14604033.jpeg?auto=compress&cs=tinysrgb&w=1620",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "headline",
      "duration": 4.6,
      "backgroundColor": "#101113",
      "transition": "slideup",
      "transitionId": "points",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{bgImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.4,
          "filter": { "saturate": 0.5 },
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='snsShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#101113' stop-opacity='0.7'/><stop offset='0.45' stop-color='#101113' stop-opacity='0.3'/><stop offset='1' stop-color='#101113' stop-opacity='0.94'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#snsShade)'/><rect x='0' y='150' width='1080' height='8' fill='#E4372E'/><rect x='80' y='1210' width='120' height='10' fill='#E4372E'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 210,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.1,
          "enterEnd": 0.45,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#FFFFFF; font-size:30px; font-weight:800; letter-spacing:6px;'>{{outletName}}</div><div style='margin-top:8px; color:#E4372E; font-size:22px; font-weight:800; letter-spacing:4px;'>{{kicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 1270,
          "width": 920,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.45,
          "enterEnd": 0.95,
          "enterAnimation": "smoothup",
          "exitEnd": 4.6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#FFFFFF; font-size:74px; line-height:1.08; font-weight:800; letter-spacing:-1px;'>{{headline}}</div><div style='margin-top:20px; color:#9CA0A8; font-size:26px; font-weight:600;'>{{dateLine}}</div>"
        }
      ]
    },
    {
      "id": "points",
      "duration": 8.4,
      "backgroundColor": "#101113",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 8.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#101113'/><rect x='0' y='150' width='1080' height='8' fill='#E4372E'/><path d='M80 420 H1000' stroke='rgba(255,255,255,0.1)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 220,
          "width": 920,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.1,
          "enterEnd": 0.5,
          "enterAnimation": "fade",
          "exitEnd": 8.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#FFFFFF; font-size:44px; font-weight:800;'>What you need to know</div><div style='margin-top:8px; color:#9CA0A8; font-size:24px; font-weight:600;'>{{outletName}} · 30-second brief</div>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 520,
          "width": 920,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1,
          "enterAnimation": "smoothleft",
          "exitEnd": 8.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='display:flex;'><div style='width:64px; color:#E4372E; font-size:40px; font-weight:800;'>01</div><div style='flex:1; color:#E8E9EC; font-size:34px; line-height:1.45; font-weight:600; padding-left:22px; border-left:3px solid #E4372E;'>{{point1}}</div></div>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 880,
          "width": 920,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 1.6,
          "enterEnd": 2.1,
          "enterAnimation": "smoothleft",
          "exitEnd": 8.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='display:flex;'><div style='width:64px; color:#E4372E; font-size:40px; font-weight:800;'>02</div><div style='flex:1; color:#E8E9EC; font-size:34px; line-height:1.45; font-weight:600; padding-left:22px; border-left:3px solid #E4372E;'>{{point2}}</div></div>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 1200,
          "width": 920,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 2.7,
          "enterEnd": 3.2,
          "enterAnimation": "smoothleft",
          "exitEnd": 8.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='display:flex;'><div style='width:64px; color:#E4372E; font-size:40px; font-weight:800;'>03</div><div style='flex:1; color:#E8E9EC; font-size:34px; line-height:1.45; font-weight:600; padding-left:22px; border-left:3px solid #E4372E;'>{{point3}}</div></div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showSource}}",
          "x": 80,
          "y": 1600,
          "width": 920,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 3.8,
          "enterEnd": 4.2,
          "enterAnimation": "fade",
          "exitEnd": 8.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:#6C7078; font-size:21px; font-weight:600;'>{{sourceNote}}</div>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 1690,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 4.2,
          "enterEnd": 4.6,
          "enterAnimation": "smoothup",
          "exitEnd": 8.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:#E4372E; color:#FFFFFF; border-radius:10px; padding:18px 42px; font-size:30px; font-weight:800;'>{{ctaText}} →</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.14
    }
  ]
}
