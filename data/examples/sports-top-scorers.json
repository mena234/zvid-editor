{
  "name": "sports-top-scorers",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#1A0710",
  "outputFormat": "mp4",
  "variables": {
    "kicker": "GOLDEN BOOT RACE",
    "leagueName": "SERIE A · 2025/26",
    "accentColor": "#E9C46A",
    "subLine": "Who takes the crown this season?",
    "scorers": [
      { "rank": "5", "name": "Rafael Leão", "club": "AC Milan", "goals": "14", "note": "9 with his left" },
      { "rank": "4", "name": "Marcus Thuram", "club": "Inter", "goals": "16", "note": "5 headers" },
      { "rank": "3", "name": "Dušan Vlahović", "club": "Juventus", "goals": "18", "note": "4 penalties" },
      { "rank": "2", "name": "Victor Osimhen", "club": "Napoli", "goals": "21", "note": "Best minutes-per-goal" },
      { "rank": "1", "name": "Lautaro Martínez", "club": "Inter", "goals": "23", "note": "Leads the race" }
    ],
    "footerLine": "The Golden Boot is wide open.",
    "channelLine": "@serieagoals",
    "heroImage": "https://images.pexels.com/photos/6250975/pexels-photo-6250975.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "intro",
      "duration": 3.6,
      "backgroundColor": "#1A0710",
      "transition": "smoothleft",
      "transitionId": "scorer",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{heroImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.4,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='tsIntro' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#1A0710' stop-opacity='0.8'/><stop offset='0.5' stop-color='#1A0710' stop-opacity='0.42'/><stop offset='1' stop-color='#1A0710' stop-opacity='0.97'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#tsIntro)'/><path d='M120 1060 H420' stroke='#E9C46A' stroke-width='6'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 120,
          "y": 760,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.75,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:{{accentColor}}; font-size:30px; font-weight:900; letter-spacing:8px;'>{{leagueName}}</div><div style='margin-top:18px; color:#FFFFFF; font-size:104px; line-height:0.95; font-weight:900; letter-spacing:-3px;'>{{kicker}}</div><div style='margin-top:34px; color:#D9A9B6; font-size:34px; font-weight:600;'>{{subLine}}</div>"
        }
      ]
    },
    {
      "id": "scorer",
      "iterate": "scorers",
      "iterateAs": "s",
      "duration": 2.8,
      "backgroundColor": "#1A0710",
      "transition": "slideup",
      "transitionId": "outro",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 2.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='tsRow' cx='0.5' cy='0.36' r='0.95'><stop offset='0' stop-color='#3A0E1E'/><stop offset='1' stop-color='#1A0710'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#tsRow)'/><circle cx='540' cy='700' r='330' fill='none' stroke='rgba(233,196,106,0.35)' stroke-width='2'/><rect x='120' y='1240' width='840' height='320' rx='36' fill='rgba(255,255,255,0.04)' stroke='rgba(233,196,106,0.4)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 340,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "fade",
          "exitEnd": 2.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:34px; font-weight:900; letter-spacing:8px;'>NO.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 380,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.75,
          "enterAnimation": "circleopen",
          "exitEnd": 2.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:440px; line-height:0.8; font-weight:900; letter-spacing:-16px;'>{{s.rank}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1290,
          "width": 800,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.5,
          "enterEnd": 0.95,
          "enterAnimation": "smoothup",
          "exitEnd": 2.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:74px; line-height:1; font-weight:900; letter-spacing:-2px;'>{{s.name}}</div><div style='margin-top:12px; text-align:center; color:#D9A9B6; font-size:32px; font-weight:700; letter-spacing:3px;'>{{s.club}} · {{s.note}}</div>"
        },
        {
          "type": "TEXT",
          "x": 880,
          "y": 700,
          "anchor": "center-center",
          "track": 12,
          "enterBegin": 0.65,
          "enterEnd": 1.05,
          "enterAnimation": "smoothleft",
          "exitEnd": 2.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#1A0710; border-radius:20px; padding:20px 28px; text-align:center;'><div style='font-size:80px; line-height:0.9; font-weight:900;'>{{s.goals}}</div><div style='font-size:22px; font-weight:900; letter-spacing:3px;'>GOALS</div></div>"
        }
      ]
    },
    {
      "id": "outro",
      "duration": 3.4,
      "backgroundColor": "#1A0710",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='tsOut' cx='0.5' cy='0.4' r='0.9'><stop offset='0' stop-color='#3A0E1E'/><stop offset='1' stop-color='#1A0710'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#tsOut)'/><path d='M470 560 h140 v70 a70 70 0 0 1 -140 0 Z' fill='none' stroke='#E9C46A' stroke-width='6' stroke-linejoin='round'/><path d='M470 590 h-40 a30 30 0 0 0 30 40 M610 590 h40 a30 30 0 0 1 -30 40' fill='none' stroke='#E9C46A' stroke-width='5'/><rect x='512' y='700' width='56' height='60' fill='none' stroke='#E9C46A' stroke-width='6'/><rect x='470' y='760' width='140' height='24' rx='6' fill='#E9C46A'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 920,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:66px; line-height:1.12; font-weight:900; letter-spacing:-2px;'>{{footerLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1220,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.1,
          "enterAnimation": "circleopen",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#1A0710; border-radius:999px; padding:20px 52px; font-size:32px; font-weight:700; letter-spacing:2px;'>{{channelLine}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.16
    }
  ]
}
