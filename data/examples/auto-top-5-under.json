{
  "name": "auto-top-5-under",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0A0A0B",
  "outputFormat": "mp4",
  "variables": {
    "dealerName": "@driveline.motors",
    "priceCap": "$25K",
    "coverTitle": "5 cars under<br>{{priceCap}} right now",
    "coverSub": "Ranked by our sales floor. #1 sells out fast.",
    "ctaText": "DM \"DRIVE\" to reserve",
    "accentColor": "#C6F135",
    "cars": [
      {
        "rank": "5",
        "name": "Civic Sport",
        "detail": "Turbo · 35 mpg · Certified",
        "price": "$22,900",
        "image": "https://images.pexels.com/photos/12565887/pexels-photo-12565887.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"
      },
      {
        "rank": "4",
        "name": "Corolla Hybrid",
        "detail": "50 mpg · One owner · 18k mi",
        "price": "$23,500",
        "image": "https://images.pexels.com/photos/20131971/pexels-photo-20131971.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"
      },
      {
        "rank": "3",
        "name": "Mazda3 Turbo",
        "detail": "250 HP · AWD · Leather",
        "price": "$24,200",
        "image": "https://images.pexels.com/photos/28837090/pexels-photo-28837090.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"
      },
      {
        "rank": "2",
        "name": "Elantra N-Line",
        "detail": "Sport-tuned · CarPlay · 12k mi",
        "price": "$24,750",
        "image": "https://images.pexels.com/photos/37418835/pexels-photo-37418835.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"
      },
      {
        "rank": "1",
        "name": "Model 3 SR",
        "detail": "EV · 272 mi range · Autopilot",
        "price": "$24,990",
        "image": "https://images.pexels.com/photos/24376862/pexels-photo-24376862.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"
      }
    ],
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "cover",
      "duration": 3.2,
      "backgroundColor": "#0A0A0B",
      "transition": "slideleft",
      "transitionId": "car",
      "transitionDuration": 0.4,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='t5cover' cx='0.5' cy='0.35' r='0.95'><stop offset='0' stop-color='#16180E'/><stop offset='1' stop-color='#0A0A0B'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#t5cover)'/><path d='M-60 470 L1140 380 L1140 414 L-60 504 Z' fill='#C6F135' opacity='0.92'/><path d='M-60 1470 L1140 1400 L1140 1420 L-60 1490 Z' fill='rgba(198,241,53,0.35)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 250,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "fade",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:#C6F135; font-size:26px; font-weight:700; letter-spacing:7px;'>{{dealerName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 720,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.75,
          "enterAnimation": "circleopen",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:96px; line-height:1.02; font-weight:700; letter-spacing:-3px;'>{{coverTitle}}</div><div style='margin-top:30px; text-align:center; color:#9AA08A; font-size:31px; font-weight:600;'>{{coverSub}}</div>"
        }
      ]
    },
    {
      "id": "car",
      "iterate": "cars",
      "iterateAs": "c",
      "duration": 3.4,
      "backgroundColor": "#0A0A0B",
      "transition": "slideleft",
      "transitionId": "outro",
      "transitionDuration": 0.4,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{c.image}}",
          "x": 540,
          "y": 560,
          "width": 1080,
          "height": 1040,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='t5car' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0A0A0B' stop-opacity='0.55'/><stop offset='0.4' stop-color='#0A0A0B' stop-opacity='0.1'/><stop offset='0.62' stop-color='#0A0A0B' stop-opacity='0.75'/><stop offset='1' stop-color='#0A0A0B' stop-opacity='1'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#t5car)'/><rect x='90' y='1120' width='900' height='1' fill='rgba(198,241,53,0.5)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 82,
          "y": 90,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.1,
          "enterEnd": 0.5,
          "enterAnimation": "circleopen",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:rgba(198,241,53,0.9); font-size:300px; line-height:0.8; font-weight:700; letter-spacing:-14px;'>{{c.rank}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1180,
          "width": 720,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:#FFFFFF; font-size:78px; line-height:1; font-weight:700; letter-spacing:-2px;'>{{c.name}}</div><div style='margin-top:20px; color:#B9BDA8; font-size:31px; font-weight:500;'>{{c.detail}}</div>"
        },
        {
          "type": "TEXT",
          "x": 990,
          "y": 1200,
          "anchor": "top-right",
          "track": 11,
          "enterBegin": 0.55,
          "enterEnd": 1,
          "enterAnimation": "smoothleft",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:#C6F135; color:#0A0A0B; border-radius:16px; padding:18px 36px; font-size:52px; font-weight:700; letter-spacing:-1px;'>{{c.price}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1820,
          "anchor": "center-center",
          "track": 11,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:rgba(255,255,255,0.55); font-size:23px; font-weight:700; letter-spacing:4px;'>{{dealerName}} · under {{priceCap}}</div>"
        }
      ]
    },
    {
      "id": "outro",
      "duration": 3.4,
      "backgroundColor": "#0A0A0B",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#0A0A0B'/><circle cx='540' cy='640' r='150' fill='none' stroke='#C6F135' stroke-width='5'/><path d='M480 640 L525 690 L610 590' fill='none' stroke='#C6F135' stroke-width='16' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 960,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:74px; line-height:1.08; font-weight:700; letter-spacing:-2px;'>All 5 on the lot.<br>All under {{priceCap}}.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1280,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.75,
          "enterEnd": 1.2,
          "enterAnimation": "circleopen",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:#C6F135; color:#0A0A0B; border-radius:999px; padding:24px 58px; font-size:34px; font-weight:700;'>{{ctaText}}</div>"
        }
      ]
    }
  ],
  "audios": [
    { "src": "{{musicUrl}}", "volume": 0.2 }
  ]
}
