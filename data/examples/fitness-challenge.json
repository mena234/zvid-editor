{
  "name": "fitness-challenge",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#141110",
  "outputFormat": "mp4",
  "variables": {
    "challengeName": "30-DAY MOVE STREAK",
    "dayLabel": "DAY",
    "dayNumber": "14",
    "totalDays": "of 30",
    "taskTitle": "20-Minute Hill Run",
    "taskDetail": "Find any incline. Keep a steady pace you can just barely talk through. No walking on the ups.",
    "focusLabel": "TODAY'S FOCUS",
    "focusValue": "Aerobic base + mental grit",
    "badgeText": "HALFWAY MILESTONE",
    "showBadge": true,
    "ctaHeadline": "You don't need<br>motivation.<br>You need day 15.",
    "ctaSub": "Screenshot · check the box · repeat tomorrow",
    "accent": "#FF6A3D",
    "heroImage": "https://images.unsplash.com/photo-1727094141271-9bea5bc8c757?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3MDgwMTZ8MHwxfHNlYXJjaHwyfHxydW5uaW5nJTIwcnVubmVyJTIwb3V0ZG9vciUyMGF0aGxldGljfGVufDB8fHx8MTc4MzI2ODU5MHww&ixlib=rb-4.1.0&q=80&w=1080",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "hook",
      "duration": 3.6,
      "backgroundColor": "#141110",
      "transition": "wipeup",
      "transitionId": "day",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{heroImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.6,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='chHook' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#141110' stop-opacity='0.85'/><stop offset='0.5' stop-color='#141110' stop-opacity='0.4'/><stop offset='1' stop-color='#141110' stop-opacity='0.92'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#chHook)'/><rect x='0' y='930' width='1080' height='6' fill='#FF6A3D'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 720,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='text-align:center; color:{{accent}}; font-size:30px; font-weight:800; letter-spacing:8px;'>{{challengeName}}</div><div style='margin-top:70px; text-align:center; color:#F4F1EE; font-size:34px; font-weight:600; letter-spacing:2px;'>{{focusLabel}}</div><div style='margin-top:12px; text-align:center; color:#FFFFFF; font-size:52px; line-height:1.2; font-weight:700;'>{{focusValue}}</div>"
        }
      ]
    },
    {
      "id": "day",
      "duration": 4.6,
      "backgroundColor": "#141110",
      "transition": "smoothup",
      "transitionId": "cta",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='chDay' cx='0.5' cy='0.3' r='0.95'><stop offset='0' stop-color='#241713'/><stop offset='1' stop-color='#141110'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#chDay)'/><circle cx='540' cy='540' r='330' fill='none' stroke='rgba(255,106,61,0.35)' stroke-width='3'/><circle cx='540' cy='540' r='330' fill='none' stroke='#FF6A3D' stroke-width='9' stroke-dasharray='967 1108' stroke-linecap='round' transform='rotate(-90 540 540)'/><rect x='90' y='1060' width='900' height='560' rx='38' fill='rgba(255,255,255,0.04)' stroke='rgba(255,106,61,0.35)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 540,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "circleopen",
          "exitEnd": 4.6,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='text-align:center; color:{{accent}}; font-size:30px; font-weight:800; letter-spacing:8px;'>{{dayLabel}}</div><div style='text-align:center; color:#FFFFFF; font-size:240px; line-height:0.9; font-weight:800; letter-spacing:-6px;'>{{dayNumber}}</div><div style='text-align:center; color:#B5ABA4; font-size:34px; font-weight:600;'>{{totalDays}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showBadge}}",
          "x": 540,
          "y": 190,
          "anchor": "top-center",
          "track": 12,
          "enterBegin": 0.5,
          "enterEnd": 0.95,
          "enterAnimation": "smoothdown",
          "exitEnd": 4.6,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='display:inline-block; background:{{accent}}; color:#141110; border-radius:999px; padding:14px 36px; font-size:26px; font-weight:800; letter-spacing:3px;'>{{badgeText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1110,
          "width": 820,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.6,
          "enterEnd": 1.05,
          "enterAnimation": "smoothup",
          "exitEnd": 4.6,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='text-align:center; color:{{accent}}; font-size:24px; font-weight:800; letter-spacing:5px;'>TODAY'S TASK</div><div style='margin-top:16px; text-align:center; color:#FFFFFF; font-size:64px; line-height:1.05; font-weight:700; letter-spacing:-1px;'>{{taskTitle}}</div><div style='margin-top:24px; text-align:center; color:#C6BCB4; font-size:32px; line-height:1.42; font-weight:500;'>{{taskDetail}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 4.2,
      "backgroundColor": "#141110",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='chEnd' cx='0.5' cy='0.42' r='0.95'><stop offset='0' stop-color='#2A1811'/><stop offset='1' stop-color='#141110'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#chEnd)'/><rect x='56' y='56' width='968' height='1808' rx='28' fill='none' stroke='rgba(255,106,61,0.3)' stroke-width='1.5'/><path d='M420 1240 L500 1320 L680 1140' fill='none' stroke='#FF6A3D' stroke-width='14' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 720,
          "width": 920,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 4.2,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:76px; line-height:1.1; font-weight:700; letter-spacing:-1px;'>{{ctaHeadline}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1400,
          "width": 900,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.9,
          "enterEnd": 1.3,
          "enterAnimation": "fade",
          "exitEnd": 4.2,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='text-align:center; color:{{accent}}; font-size:30px; font-weight:700; letter-spacing:2px;'>{{ctaSub}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.17
    }
  ]
}
