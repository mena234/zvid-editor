{
  "name": "local-new-branch",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#12100D",
  "outputFormat": "mp4",
  "variables": {
    "brandName": "CAFÉ SIGLO",
    "announceLine": "We're opening in your neighborhood",
    "branchName": "Café Siglo · Riverside",
    "address": "88 Waterfront Promenade",
    "openingDate": "Grand opening — Saturday, July 19",
    "openingOffer": "First 100 guests get a free signature latte",
    "showOffer": true,
    "ctaText": "See you there",
    "storefrontImage": "https://images.pexels.com/photos/18115967/pexels-photo-18115967.jpeg?auto=compress&cs=tinysrgb&w=1620",
    "latteVideo": "https://videos.pexels.com/video-files/31649914/13484211_1080_1920_30fps.mp4",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "tease",
      "duration": 3.6,
      "backgroundColor": "#12100D",
      "transition": "fade",
      "transitionId": "reveal",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{latteVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='lnbShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#12100D' stop-opacity='0.5'/><stop offset='0.5' stop-color='#12100D' stop-opacity='0.2'/><stop offset='1' stop-color='#12100D' stop-opacity='0.85'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#lnbShade)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1360,
          "width": 920,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Comfortaa" },
          "html": "<div style='text-align:center; color:#EFE3D2; font-size:62px; line-height:1.15; font-weight:700;'>{{announceLine}} ☕</div><div style='margin-top:16px; text-align:center; color:#B7A692; font-size:27px; letter-spacing:6px;'>{{brandName}}</div>"
        }
      ]
    },
    {
      "id": "reveal",
      "duration": 6.2,
      "backgroundColor": "#12100D",
      "transition": "smoothup",
      "transitionId": "invite",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{storefrontImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 6.2
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 6.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='lnrShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#12100D' stop-opacity='0.4'/><stop offset='0.45' stop-color='#12100D' stop-opacity='0.05'/><stop offset='1' stop-color='#12100D' stop-opacity='0.9'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#lnrShade)'/><path d='M540 160 C495 160 460 195 460 238 C460 300 540 380 540 380 C540 380 620 300 620 238 C620 195 585 160 540 160 Z' fill='none' stroke='#F0B451' stroke-width='5'/><circle cx='540' cy='236' r='24' fill='#F0B451'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 1330,
          "width": 920,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 6.2,
          "style": { "fontFamily": "Comfortaa" },
          "html": "<div style='color:#F0B451; font-size:26px; font-weight:700; letter-spacing:4px;'>NOW POURING AT</div><div style='margin-top:14px; color:#FFFFFF; font-size:70px; line-height:1.05; font-weight:700;'>{{branchName}}</div><div style='margin-top:16px; color:#D8C8B4; font-size:30px; font-weight:500;'>📍 {{address}}</div><div style='margin-top:12px; color:#F0B451; font-size:30px; font-weight:700;'>{{openingDate}}</div>"
        }
      ]
    },
    {
      "id": "invite",
      "duration": 4.6,
      "backgroundColor": "#12100D",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='lniEnd' cx='0.5' cy='0.4' r='0.9'><stop offset='0' stop-color='#251D13'/><stop offset='1' stop-color='#12100D'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#lniEnd)'/><path d='M440 560 H600 V700 C600 740 570 760 520 760 C470 760 440 740 440 700 Z M600 590 C640 590 660 610 660 640 C660 670 640 690 600 690' fill='none' stroke='#F0B451' stroke-width='7'/><path d='M480 500 C480 480 495 480 495 460 M530 500 C530 480 545 480 545 460' stroke='rgba(240,180,81,0.7)' stroke-width='6' stroke-linecap='round' fill='none'/></svg>"
        },
        {
          "type": "GIF",
          "src": "https://media.giphy.com/media/TgoPuXFbihKJ54unZH/giphy.gif",
          "x": 540,
          "y": 620,
          "width": 700,
          "height": 700,
          "anchor": "center-center",
          "opacity": 0.5,
          "track": 3,
          "enterBegin": 0.3,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitBegin": 2.6,
          "exitEnd": 3.1,
          "exitAnimation": "fade"
        },
        {
          "type": "TEXT",
          "condition": "{{showOffer}}",
          "x": 540,
          "y": 920,
          "width": 880,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.75,
          "enterAnimation": "smoothup",
          "exitEnd": 4.6,
          "style": { "fontFamily": "Comfortaa" },
          "html": "<div style='text-align:center;'><span style='display:inline-block; background:rgba(240,180,81,0.14); border:1.5px dashed rgba(240,180,81,0.6); color:#F5D9A8; border-radius:20px; padding:22px 42px; font-size:31px; line-height:1.4; font-weight:700;'>🎁 {{openingOffer}}</span></div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1200,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.9,
          "enterEnd": 1.3,
          "enterAnimation": "circleopen",
          "exitEnd": 4.6,
          "style": { "fontFamily": "Comfortaa" },
          "html": "<div style='display:inline-block; background:#F0B451; color:#12100D; border-radius:999px; padding:26px 64px; font-size:34px; font-weight:700;'>{{ctaText}} 👋</div><div style='margin-top:18px; text-align:center; color:#9B8B74; font-size:24px; letter-spacing:4px;'>{{branchName}} · {{openingDate}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.17
    }
  ]
}
