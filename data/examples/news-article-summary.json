{
  "name": "news-article-summary",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#F3EEE4",
  "outputFormat": "mp4",
  "variables": {
    "publication": "THE LONGREAD",
    "readTime": "8 MIN READ · SUMMARIZED",
    "articleTitle": "Why four-day weeks keep beating the five-day office",
    "byline": "Adapted from an essay by J. Okafor",
    "coverImage": "https://images.pexels.com/photos/10004971/pexels-photo-10004971.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "closingLine": "The full piece is worth your coffee.",
    "handle": "@thelongread",
    "accentColor": "#D64545",
    "points": [
      {
        "point": "Output held steady",
        "body": "Across 61 companies, productivity stayed flat or rose even as hours dropped by 20%."
      },
      {
        "point": "Burnout fell sharply",
        "body": "Reported exhaustion dropped 71% and sick days nearly halved within six months."
      },
      {
        "point": "Almost nobody went back",
        "body": "92% of firms kept the four-day week after the trial officially ended."
      }
    ],
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "cover",
      "duration": 3.4,
      "backgroundColor": "#F3EEE4",
      "transition": "smoothleft",
      "transitionId": "point",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{coverImage}}",
          "x": 540,
          "y": 620,
          "width": 900,
          "height": 900,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "radius": { "tl": 32, "tr": 32, "bl": 32, "br": 32 },
          "track": 1,
          "enterBegin": 0,
          "enterEnd": 0.55,
          "enterAnimation": "smoothdown",
          "exitEnd": 3.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#F3EEE4'/><path d='M90 1180 H990' stroke='rgba(30,26,22,0.18)' stroke-width='2'/><rect x='90' y='1220' width='120' height='10' rx='5' fill='#D64545'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1080,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "fade",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:#D64545; font-size:28px; font-weight:800; letter-spacing:6px;'>{{publication}}</div><div style='margin-top:8px; color:#7A7266; font-size:24px; font-weight:600; letter-spacing:3px;'>{{readTime}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1280,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Playfair Display" },
          "html": "<div style='color:#1E1A16; font-size:72px; line-height:1.08; font-weight:700;'>{{articleTitle}}</div><div style='margin-top:24px; color:#8A8072; font-size:28px; font-style:italic; font-family:Playfair Display, serif;'>{{byline}}</div>"
        }
      ]
    },
    {
      "id": "point",
      "iterate": "points",
      "iterateAs": "p",
      "duration": 3.4,
      "backgroundColor": "#F3EEE4",
      "transition": "smoothleft",
      "transitionId": "close",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#F3EEE4'/><rect x='80' y='560' width='920' height='800' rx='36' fill='#FBF8F1' stroke='rgba(30,26,22,0.12)' stroke-width='1.5'/><rect x='80' y='560' width='920' height='12' rx='6' fill='#D64545'/><circle cx='210' cy='740' r='66' fill='none' stroke='#D64545' stroke-width='4'/><path d='M160 1120 H920' stroke='rgba(30,26,22,0.1)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 210,
          "y": 700,
          "anchor": "center-center",
          "track": 11,
          "enterBegin": 0.1,
          "enterEnd": 0.5,
          "enterAnimation": "circleopen",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Playfair Display" },
          "html": "<div style='color:#D64545; font-size:72px; font-weight:700; line-height:1;'>0{{index}}</div>"
        },
        {
          "type": "TEXT",
          "x": 320,
          "y": 660,
          "width": 640,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.3,
          "enterEnd": 0.75,
          "enterAnimation": "smoothright",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Playfair Display" },
          "html": "<div style='color:#1E1A16; font-size:60px; line-height:1.05; font-weight:700;'>{{p.point}}</div>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 1160,
          "width": 820,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.6,
          "enterEnd": 1.05,
          "enterAnimation": "fade",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:#4E463B; font-size:38px; line-height:1.45; font-weight:500;'>{{p.body}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1780,
          "anchor": "center-center",
          "track": 11,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:#9A9080; font-size:24px; font-weight:700; letter-spacing:4px;'>{{publication}} · KEY POINTS</div>"
        }
      ]
    },
    {
      "id": "close",
      "duration": 3,
      "backgroundColor": "#1E1A16",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#1E1A16'/><path d='M420 660 H660 M420 720 H620 M420 780 H660 M420 840 H600' stroke='rgba(243,238,228,0.3)' stroke-width='8' stroke-linecap='round'/><rect x='388' y='600' width='300' height='320' rx='16' fill='none' stroke='#D64545' stroke-width='4'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1020,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3,
          "style": { "fontFamily": "Playfair Display" },
          "html": "<div style='text-align:center; color:#F3EEE4; font-size:64px; line-height:1.15; font-weight:700;'>{{closingLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1280,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.1,
          "enterAnimation": "circleopen",
          "exitEnd": 3,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#F3EEE4; border-radius:999px; padding:20px 52px; font-size:32px; font-weight:800;'>{{handle}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.14
    }
  ]
}
