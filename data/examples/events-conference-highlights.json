{
  "name": "events-conference-highlights",
  "resolution": "full-hd",
  "frameRate": 30,
  "backgroundColor": "#061A1C",
  "outputFormat": "mp4",
  "variables": {
    "eventName": "SUMMIT '26 RECAP",
    "kicker": "THAT'S A WRAP",
    "titleLine": "Three days. One incredible community.",
    "summaryLine": "Thank you to everyone who showed up, spoke, and connected.",
    "stats": [
      {
        "value": "4,200",
        "label": "Attendees",
        "note": "From 38 countries"
      },
      {
        "value": "68",
        "label": "Talks & Workshops",
        "note": "Across 5 stages"
      },
      {
        "value": "24",
        "label": "Sponsors",
        "note": "Powering the experience"
      }
    ],
    "ctaLine": "Recordings drop next week.",
    "ctaText": "Get the replay pass",
    "handle": "summit26.com",
    "accentColor": "#2FE2C0",
    "accent2": "#FF6B5B",
    "heroVideo": "https://videos.pexels.com/video-files/34917491/14791149_1920_1080_60fps.mp4",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "title",
      "duration": 4.4,
      "backgroundColor": "#061A1C",
      "transition": "smoothleft",
      "transitionId": "stat",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{heroVideo}}",
          "width": 1920,
          "height": 1080,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4
        },
        {
          "type": "SVG",
          "width": 1920,
          "height": 1080,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1920' height='1080' viewBox='0 0 1920 1080' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='chShade' x1='0' y1='0' x2='1' y2='0'><stop offset='0' stop-color='#061A1C' stop-opacity='0.95'/><stop offset='0.55' stop-color='#061A1C' stop-opacity='0.6'/><stop offset='1' stop-color='#061A1C' stop-opacity='0.2'/></linearGradient></defs><rect width='1920' height='1080' fill='url(#chShade)'/><rect x='120' y='690' width='170' height='6' rx='3' fill='#2FE2C0'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 120,
          "y": 300,
          "width": 1120,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.75,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='color:#2FE2C0; font-size:28px; font-weight:700; letter-spacing:8px;'>{{kicker}} · {{eventName}}</div><div style='margin-top:24px; color:#FFFFFF; font-size:94px; line-height:1; font-weight:700; letter-spacing:-3px;'>{{titleLine}}</div><div style='margin-top:44px; color:#9CC2BE; font-size:32px; line-height:1.4; font-weight:500; font-family:Sora, sans-serif;'>{{summaryLine}}</div>"
        }
      ]
    },
    {
      "id": "stat",
      "iterate": "stats",
      "iterateAs": "st",
      "duration": 3.4,
      "backgroundColor": "#061A1C",
