{
  "name": "hr-hiring-event",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0A1428",
  "outputFormat": "mp4",
  "variables": {
    "companyName": "NEXUS GROUP",
    "kicker": "YOU'RE INVITED",
    "eventName": "Tech Careers Fair",
    "eventTagline": "Meet the team. Skip the queue. Land the role.",
    "eventDate": "Thu · April 24",
    "eventTime": "6:00 – 9:00 PM",
    "eventPlace": "The Loft, Shoreditch + Livestream",
    "priceLabel": "Free entry",
    "showPrice": true,
    "agenda": [
      { "text": "Live hiring-manager Q&A" },
      { "text": "On-the-spot interviews" },
      { "text": "Food, drinks & networking" }
    ],
    "ctaText": "Reserve your spot",
    "ctaUrl": "nexus.group/careers-fair",
    "accentColor": "#F5A623",
    "heroVideo": "https://videos.pexels.com/video-files/7983988/7983988-hd_1080_1920_25fps.mp4",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "hook",
      "duration": 4.2,
      "backgroundColor": "#0A1428",
      "transition": "smoothup",
      "transitionId": "info",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{heroVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.2
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.2,
