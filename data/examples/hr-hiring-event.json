          "x": 90,
          "y": 1360,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 1.2,
          "enterEnd": 1.65,
          "enterAnimation": "smoothup",
          "exitEnd": 5.2,
          "style": { "fontFamily": "Outfit" },
