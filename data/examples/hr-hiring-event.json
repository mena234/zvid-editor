          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 5.2,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='color:{{accentColor}}; font-size:38px; font-weight:800; letter-spacing:1px;'>📅 {{eventDate}}</div><div style='margin-top:34px; color:#FFFFFF; font-size:38px; font-weight:600;'>🕕 {{eventTime}}</div><div style='margin-top:34px; color:#C6D3E8; font-size:34px; font-weight:600;'>📍 {{eventPlace}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 820,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.55,
          "enterEnd": 1,
          "enterAnimation": "smoothleft",
          "exitEnd": 5.2,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='color:{{accentColor}}; font-size:27px; font-weight:800; letter-spacing:5px;'>ON THE NIGHT</div>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 900,
          "width": 840,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.75,
          "enterEnd": 1.2,
          "enterAnimation": "smoothleft",
          "exitEnd": 5.2,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='color:#FFFFFF; font-size:40px; line-height:1.7; font-weight:600;'>✓ {{agenda.0.text}}<br>✓ {{agenda.1.text}}<br>✓ {{agenda.2.text}}</div>"
        },
        {
