        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 140,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='color:#FFFFFF; font-size:27px; font-weight:700; letter-spacing:9px;'>{{companyName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1120,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='text-align:center;'><span style='display:inline-block; background:{{accentColor}}; color:#0A1428; border-radius:999px; padding:12px 32px; font-size:26px; font-weight:800; letter-spacing:4px;'>{{kicker}}</span></div><div style='margin-top:26px; text-align:center; color:#FFFFFF; font-size:116px; line-height:0.98; font-weight:800; letter-spacing:-4px;'>{{eventName}}</div><div style='margin-top:24px; text-align:center; color:#C6D3E8; font-size:36px; line-height:1.35; font-weight:500;'>{{eventTagline}}</div>"
        }
      ]
    },
    {
      "id": "info",
      "duration": 5.2,
      "backgroundColor": "#0A1428",
      "transition": "fade",
