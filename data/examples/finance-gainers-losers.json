{
  "name": "finance-gainers-losers",
  "resolution": "tiktok",
  "frameRate": 30,
  "backgroundColor": "#0A0A0C",
  "outputFormat": "mp4",
  "variables": {
    "channelName": "@marketmovers",
    "titleLine": "Today's biggest movers",
    "sessionLabel": "US close · Jul 3",
    "accentUp": "#33E29B",
    "accentDown": "#FF4D67",
    "movers": [
      {
        "rank": "1",
        "symbol": "SMCI",
        "name": "Super Micro",
        "move": "+11.4%",
        "reason": "AI server orders surged",
        "dir": "up"
      },
      {
        "rank": "2",
        "symbol": "COIN",
        "name": "Coinbase",
        "move": "+6.8%",
        "reason": "Crypto volumes rebounded",
        "dir": "up"
      },
      {
        "rank": "3",
        "symbol": "NKE",
        "name": "Nike",
        "move": "-7.2%",
        "reason": "Weak guidance spooked buyers",
        "dir": "down"
      },
      {
        "rank": "4",
        "symbol": "INTC",
        "name": "Intel",
        "move": "-4.9%",
        "reason": "Foundry delays weighed",
        "dir": "down"
      }
    ],
    "ctaText": "Follow for the daily close 📈",
    "coverImage": "https://images.pexels.com/photos/9822733/pexels-photo-9822733.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "cover",
      "duration": 3,
      "backgroundColor": "#0A0A0C",
      "transition": "slideleft",
      "transitionId": "mover",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{coverImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.4,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='glCov' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0A0A0C' stop-opacity='0.7'/><stop offset='0.5' stop-color='#0A0A0C' stop-opacity='0.35'/><stop offset='1' stop-color='#0A0A0C' stop-opacity='0.94'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#glCov)'/><rect x='90' y='860' width='430' height='8' rx='4' fill='#33E29B'/><rect x='560' y='860' width='430' height='8' rx='4' fill='#FF4D67'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 720,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "circleopen",
          "exitEnd": 3,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:92px; line-height:1.02; font-weight:700; letter-spacing:-2px;'>{{titleLine}}</div><div style='margin-top:26px; text-align:center; color:#8A8D98; font-size:30px; font-weight:600; letter-spacing:3px;'>{{sessionLabel}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 920,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 0.95,
          "enterAnimation": "fade",
          "exitEnd": 3,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center;'><span style='color:{{accentUp}}; font-size:34px; font-weight:700; letter-spacing:2px;'>▲ GAINERS</span><span style='color:#3B3E46; font-size:34px; font-weight:700;'>   ·   </span><span style='color:{{accentDown}}; font-size:34px; font-weight:700; letter-spacing:2px;'>LOSERS ▼</span></div>"
        }
      ]
    },
    {
      "id": "mover",
      "iterate": "movers",
      "iterateAs": "m",
      "duration": 3.2,
      "backgroundColor": "#0A0A0C",
      "transition": "slideleft",
      "transitionId": "outro",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='glMov' cx='0.5' cy='0.32' r='0.95'><stop offset='0' stop-color='#15161B'/><stop offset='1' stop-color='#0A0A0C'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#glMov)'/><rect x='90' y='700' width='900' height='680' rx='44' fill='rgba(255,255,255,0.035)' stroke='rgba(255,255,255,0.12)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 430,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.1,
          "enterEnd": 0.5,
          "enterAnimation": "circleopen",
          "exitEnd": 3.2,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:rgba(255,255,255,0.14); font-size:230px; line-height:1; font-weight:700; letter-spacing:-8px;'>#{{m.rank}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 770,
          "width": 820,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.3,
          "enterEnd": 0.75,
          "enterAnimation": "smoothup",
          "exitEnd": 3.2,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:104px; line-height:1; font-weight:700; letter-spacing:-2px;'>{{m.symbol}}</div><div style='margin-top:12px; text-align:center; color:#9A9DA8; font-size:36px; font-weight:600;'>{{m.name}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{m.dir}}",
          "x": 540,
          "y": 1050,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.55,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 3.2,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='display:inline-block; background:rgba(51,226,155,0.14); border:2px solid rgba(51,226,155,0.6); color:{{accentUp}}; border-radius:999px; padding:16px 52px; font-size:64px; font-weight:800; letter-spacing:-1px;'>{{m.move}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1230,
          "width": 780,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.8,
          "enterEnd": 1.2,
          "enterAnimation": "fade",
          "exitEnd": 3.2,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:#B0B3BC; font-size:32px; line-height:1.4; font-weight:500;'>{{m.reason}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1800,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='color:rgba(255,255,255,0.55); font-size:23px; font-weight:700; letter-spacing:4px;'>{{channelName}} · {{sessionLabel}}</div>"
        }
      ]
    },
    {
      "id": "outro",
      "duration": 3.2,
      "backgroundColor": "#0A0A0C",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='glOut' cx='0.5' cy='0.4' r='0.9'><stop offset='0' stop-color='#141419'/><stop offset='1' stop-color='#0A0A0C'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#glOut)'/><path d='M420 780 L520 680 L600 740 L720 600' fill='none' stroke='#33E29B' stroke-width='12' stroke-linecap='round' stroke-linejoin='round'/><circle cx='720' cy='600' r='13' fill='#33E29B'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 940,
          "width": 880,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "smoothup",
          "exitEnd": 3.2,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:66px; line-height:1.12; font-weight:700;'>Which mover<br>surprised you?</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1230,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.7,
          "enterEnd": 1.1,
          "enterAnimation": "circleopen",
          "exitEnd": 3.2,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='display:inline-block; background:#33E29B; color:#0A0A0C; border-radius:999px; padding:22px 56px; font-size:32px; font-weight:800;'>{{ctaText}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.2
    }
  ]
}
