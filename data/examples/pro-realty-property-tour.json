        "isLeft": false,
        "isRight": true
      },
      {
        "label": "Primary suite",
        "detail": "Private balcony overlooking the pool terrace",
        "image": "https://images.pexels.com/photos/28962897/pexels-photo-28962897.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
        "isLeft": true,
        "isRight": false
      },
      {
        "label": "Pool & terrace",
        "detail": "Heated infinity edge, outdoor kitchen included",
        "image": "https://images.pexels.com/photos/15526515/pexels-photo-15526515.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
