          "y": 168,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "smoothdown",
          "exitEnd": 3.8,
          "style": {
            "fontFamily": "Fraunces"
          },
          "html": "<div style='display:inline-block; background:rgba(34,26,18,0.75); border:1.5px solid rgba(232,160,117,0.55); color:#E8A075; border-radius:999px; padding:16px 42px; font-size:27px; font-style:italic; font-weight:500;'>{{tourLabel}}</div>"
