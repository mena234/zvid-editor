        },
        {
          "type": "TEXT",
          "x": 160,
          "y": 940,
          "width": 760,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.95,
          "enterAnimation": "smoothup",
          "exitEnd": 7.4,
          "style": { "fontFamily": "Playfair Display" },
          "html": "<div style='color:#F2EDFB; font-size:48px; line-height:1.35; font-style:italic;'>{{pullQuote}}</div><div style='margin-top:30px; font-family:Space Grotesk, sans-serif; font-style:normal; color:#B08CFF; font-size:26px; font-weight:700; letter-spacing:2px;'>{{guestName}} · {{episodeNumber}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1500,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 1.4,
          "enterEnd": 1.85,
          "enterAnimation": "circleopen",
          "exitEnd": 7.4,
          "style": { "fontFamily": "Space Grotesk" },
