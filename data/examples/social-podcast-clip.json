{
  "name": "social-podcast-clip",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#131018",
  "outputFormat": "mp4",
  "variables": {
    "showName": "DEEP WORK RADIO",
    "episodeTitle": "Why your calendar is lying to you",
    "episodeNumber": "Episode 87",
    "guestName": "with Dr. Lena Osei",
    "pullQuote": "Busy is not a badge. Busy is a debt you pay with attention.",
    "listenCta": "New episodes every Tuesday",
    "platformsNote": "Spotify · Apple Podcasts · YouTube",
    "showPlatforms": true,
    "micVideo": "https://videos.pexels.com/video-files/6948559/6948559-hd_1080_1920_24fps.mp4",
    "micImage": "https://images.pexels.com/photos/14195566/pexels-photo-14195566.jpeg?auto=compress&cs=tinysrgb&w=1620",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "studio",
      "duration": 4.4,
      "backgroundColor": "#131018",
      "transition": "fade",
      "transitionId": "wave",
      "transitionDuration": 0.6,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{micVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='spcShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#131018' stop-opacity='0.55'/><stop offset='0.5' stop-color='#131018' stop-opacity='0.2'/><stop offset='1' stop-color='#131018' stop-opacity='0.9'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#spcShade)'/><circle cx='170' cy='176' r='11' fill='#FF4D4D'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 210,
          "y": 176,
          "anchor": "center-left",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:#FFFFFF; font-size:26px; font-weight:700; letter-spacing:5px;'>{{showName}} · ON AIR</div>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 1430,
          "width": 920,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:#B08CFF; font-size:26px; font-weight:700; letter-spacing:4px;'>{{episodeNumber}}</div><div style='margin-top:12px; color:#FFFFFF; font-size:68px; line-height:1.06; font-weight:700; letter-spacing:-1px;'>{{episodeTitle}}</div><div style='margin-top:14px; color:#9E93B8; font-size:29px; font-weight:600;'>{{guestName}}</div>"
        }
      ]
    },
    {
      "id": "wave",
      "duration": 7.4,
      "backgroundColor": "#131018",
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{micImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "opacity": 0.3,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 7.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 7.4,
