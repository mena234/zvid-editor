        },
        {
          "type": "TEXT",
          "condition": "{{showPlatforms}}",
          "x": 540,
          "y": 1650,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 1.9,
          "enterEnd": 2.3,
          "enterAnimation": "fade",
          "exitEnd": 7.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#8B819F; font-size:24px; font-weight:600; letter-spacing:2px;'>{{platformsNote}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.16
    }
  ]
}
