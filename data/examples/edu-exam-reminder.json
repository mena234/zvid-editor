{
  "name": "edu-exam-reminder",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#1A1206",
  "outputFormat": "mp4",
  "variables": {
    "courseName": "BIO 201 · Cell Biology",
    "kicker": "EXAM ALERT",
    "examTitle": "Midterm Exam",
    "examDate": "Fri · July 18",
    "examTime": "9:00 AM · Room B14",
    "daysLeft": "3",
    "daysLabel": "days to go",
    "checklist": [
      {
        "text": "Re-read Chapters 4–6 & lecture notes"
      },
      {
        "text": "Redo the two practice quizzes"
      },
      {
        "text": "Sleep early — no all-nighters"
      }
    ],
    "disclaimer": "Bring your student ID and a non-programmable calculator.",
    "showDisclaimer": true,
    "ctaText": "Set a reminder now",
    "accentColor": "#FFB020",
    "bgImage": "https://images.pexels.com/photos/4260481/pexels-photo-4260481.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "alert",
      "duration": 4.4,
      "backgroundColor": "#1A1206",
      "transition": "smoothleft",
      "transitionId": "checklist",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{bgImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "opacity": 0.32,
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='erAlert' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#160F05' stop-opacity='0.78'/><stop offset='0.5' stop-color='#1A1206' stop-opacity='0.82'/><stop offset='1' stop-color='#0F0A03' stop-opacity='0.96'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#erAlert)'/><circle cx='540' cy='640' r='210' fill='none' stroke='rgba(255,176,32,0.9)' stroke-width='4'/><circle cx='540' cy='640' r='240' fill='none' stroke='rgba(255,176,32,0.3)' stroke-width='2'/><line x1='540' y1='540' x2='540' y2='660' stroke='#FFB020' stroke-width='16' stroke-linecap='round'/><circle cx='540' cy='720' r='11' fill='#FFB020'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 220,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#1A1206; border-radius:999px; padding:14px 40px; font-size:28px; font-weight:800; letter-spacing:6px;'>{{kicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 950,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.85,
          "enterAnimation": "circleopen",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:150px; line-height:1; font-weight:800; letter-spacing:-4px;'>{{daysLeft}}</div><div style='text-align:center; color:#FFB020; font-size:40px; font-weight:800; letter-spacing:4px;'>{{daysLabel}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1300,
          "width": 880,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:64px; line-height:1.08; font-weight:800;'>{{examTitle}}</div><div style='margin-top:18px; text-align:center; color:#D8C4A2; font-size:38px; font-weight:600;'>{{examDate}} · {{examTime}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1620,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 1,
          "enterEnd": 1.4,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='color:#A99873; font-size:28px; font-weight:700; letter-spacing:4px;'>{{courseName}}</div>"
        }
      ]
    },
    {
      "id": "checklist",
      "duration": 4.8,
      "backgroundColor": "#1A1206",
      "transition": "smoothup",
      "transitionId": "cta",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='erList' cx='0.3' cy='0.3' r='0.95'><stop offset='0' stop-color='#2A1D08'/><stop offset='1' stop-color='#120C04'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#erList)'/><rect x='80' y='560' width='920' height='840' rx='38' fill='rgba(255,255,255,0.03)' stroke='rgba(255,176,32,0.3)' stroke-width='1.5'/><circle cx='190' cy='700' r='30' fill='none' stroke='#FFB020' stroke-width='5'/><path d='M176 700 L188 714 L206 690' fill='none' stroke='#FFB020' stroke-width='6' stroke-linecap='round' stroke-linejoin='round'/><circle cx='190' cy='930' r='30' fill='none' stroke='#FFB020' stroke-width='5'/><path d='M176 930 L188 944 L206 920' fill='none' stroke='#FFB020' stroke-width='6' stroke-linecap='round' stroke-linejoin='round'/><circle cx='190' cy='1160' r='30' fill='none' stroke='#FFB020' stroke-width='5'/><path d='M176 1160 L188 1174 L206 1150' fill='none' stroke='#FFB020' stroke-width='6' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 120,
          "y": 300,
          "width": 850,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "smoothup",
          "exitEnd": 4.8,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='color:{{accentColor}}; font-size:28px; font-weight:800; letter-spacing:6px;'>BEFORE THE EXAM</div><div style='margin-top:14px; color:#FFFFFF; font-size:72px; line-height:1.02; font-weight:800;'>Your study checklist</div>"
        },
        {
          "type": "TEXT",
          "x": 260,
          "y": 670,
          "width": 700,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.5,
          "enterEnd": 0.9,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.8,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='color:#EBDCC4; font-size:40px; line-height:1.3; font-weight:600;'>{{checklist.0.text}}</div>"
        },
        {
          "type": "TEXT",
          "x": 260,
          "y": 900,
          "width": 700,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.1,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.8,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='color:#EBDCC4; font-size:40px; line-height:1.3; font-weight:600;'>{{checklist.1.text}}</div>"
        },
        {
          "type": "TEXT",
          "x": 260,
          "y": 1130,
          "width": 700,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.9,
          "enterEnd": 1.3,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.8,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='color:#EBDCC4; font-size:40px; line-height:1.3; font-weight:600;'>{{checklist.2.text}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showDisclaimer}}",
          "x": 540,
          "y": 1480,
          "width": 880,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 1.1,
          "enterEnd": 1.5,
          "enterAnimation": "fade",
          "exitEnd": 4.8,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='text-align:center; color:#A99873; font-size:30px; line-height:1.4; font-weight:600;'>{{disclaimer}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 3.4,
      "backgroundColor": "#0F0A03",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='erCta' cx='0.5' cy='0.42' r='0.9'><stop offset='0' stop-color='#2E2008'/><stop offset='1' stop-color='#0F0A03'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#erCta)'/><rect x='60' y='60' width='960' height='1800' rx='44' fill='none' stroke='rgba(255,176,32,0.4)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 820,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:74px; line-height:1.08; font-weight:800;'>You've got<br>this. Show up<br>ready.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1200,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.75,
          "enterEnd": 1.15,
          "enterAnimation": "circleopen",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#0F0A03; border-radius:999px; padding:26px 64px; font-size:34px; font-weight:800;'>{{ctaText}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.16
    }
  ]
}
