          "type": "TEXT",
          "x": 540,
          "y": 1320,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.05,
          "enterEnd": 1.5,
          "enterAnimation": "circleopen",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "DM Sans"
          },
          "html": "<div style='display:inline-block; background:{{accent}}; color:#FBF4EC; border-radius:999px; padding:26px 62px; font-size:36px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1490,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.35,
          "enterEnd": 1.75,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "DM Sans"
          },
