          "track": 10,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "DM Sans"
          },
          "html": "<div style='text-align:center; color:#C7A896; font-size:34px; line-height:1.4; font-weight:500;'>{{summaryLine}}</div>"
