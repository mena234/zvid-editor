{
  "name": "realty-apartment-tour",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#FBF4EC",
  "outputFormat": "mp4",
  "variables": {
    "agentName": "CLARA · Terracotta Realty",
    "kicker": "STEP INSIDE",
    "propertyName": "Apartment 5B",
    "addressLine": "Juniper Court · Old Town",
    "priceLine": "£389,000",
    "summaryLine": "2 bed · 2 bath · 74 m² · south-facing",
    "closingHead": "Want the full<br>tour in person?",
    "ctaText": "Book a viewing",
    "handle": "terracottarealty.co / 5b",
    "showBadge": true,
    "badgeText": "JUST RENOVATED",
    "accent": "#C15B32",
    "ink": "#3A2419",
    "rooms": [
      {
        "index": "01",
        "room": "Living Room",
        "detail": "Open-plan with oak floors & full-height windows",
        "image": "https://images.unsplash.com/photo-1738168279272-c08d6dd22002?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3MDgwMTZ8MHwxfHNlYXJjaHw1fHxhcGFydG1lbnQlMjBsaXZpbmclMjByb29tJTIwaW50ZXJpb3J8ZW58MHx8fHwxNzgzMjY4NjEyfDA&ixlib=rb-4.1.0&q=80&w=1080"
      },
      {
        "index": "02",
        "room": "Kitchen",
        "detail": "Handleless units, quartz worktops, island seating",
        "image": "https://images.unsplash.com/photo-1556593825-c11de986cb0b?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3MDgwMTZ8MHwxfHNlYXJjaHw2fHxhcGFydG1lbnQlMjBsaXZpbmclMjByb29tJTIwaW50ZXJpb3J8ZW58MHx8fHwxNzgzMjY4NjEyfDA&ixlib=rb-4.1.0&q=80&w=1080"
      },
      {
        "index": "03",
        "room": "Primary Bedroom",
        "detail": "King suite with walk-in wardrobe & ensuite",
        "image": "https://images.unsplash.com/photo-1737233459465-8eaf6c7d8856?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3MDgwMTZ8MHwxfHNlYXJjaHw4fHxhcGFydG1lbnQlMjBsaXZpbmclMjByb29tJTIwaW50ZXJpb3J8ZW58MHx8fHwxNzgzMjY4NjEyfDA&ixlib=rb-4.1.0&q=80&w=1080"
      }
    ],
    "coverImage": "https://images.pexels.com/photos/33537442/pexels-photo-33537442.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "cover",
      "duration": 4,
      "backgroundColor": "#FBF4EC",
      "transition": "smoothleft",
      "transitionId": "room",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{coverImage}}",
          "x": 540,
          "y": 700,
          "width": 900,
          "height": 1120,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "radius": {
            "tl": 400,
            "tr": 400,
            "bl": 40,
            "br": 40
          },
          "track": 1,
          "enterBegin": 0,
          "enterEnd": 0.55,
          "enterAnimation": "smoothup",
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#FBF4EC'/><circle cx='540' cy='560' r='470' fill='rgba(193,91,50,0.08)'/><path d='M120 1740 H960' stroke='rgba(58,36,25,0.15)' stroke-width='2'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 128,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.7,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": {
            "fontFamily": "DM Sans"
          },
          "html": "<div style='color:#8A6B58; font-size:24px; font-weight:700; letter-spacing:6px;'>{{agentName}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showBadge}}",
          "x": 540,
          "y": 300,
          "anchor": "center-center",
          "track": 12,
          "enterBegin": 0.5,
          "enterEnd": 0.95,
          "enterAnimation": "smoothdown",
          "exitEnd": 4,
          "style": {
            "fontFamily": "DM Sans"
          },
          "html": "<div style='display:inline-block; background:{{accent}}; color:#FBF4EC; border-radius:999px; padding:14px 34px; font-size:24px; font-weight:800; letter-spacing:3px;'>{{badgeText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1470,
          "width": 920,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.6,
          "enterEnd": 1.1,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": {
            "fontFamily": "Fraunces"
          },
          "html": "<div style='text-align:center; color:{{accent}}; font-size:25px; font-weight:700; letter-spacing:5px; font-family:DM Sans, sans-serif;'>{{kicker}}</div><div style='margin-top:14px; text-align:center; color:#3A2419; font-size:96px; line-height:1; font-weight:600; letter-spacing:-2px;'>{{propertyName}}</div><div style='margin-top:16px; text-align:center; color:#7A5C4A; font-size:32px; font-weight:500; font-family:DM Sans, sans-serif;'>{{addressLine}} · {{priceLine}}</div>"
        }
      ]
    },
    {
      "id": "room",
      "iterate": "rooms",
      "iterateAs": "room",
      "duration": 4,
      "backgroundColor": "#FBF4EC",
      "transition": "smoothleft",
      "transitionId": "close",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{room.image}}",
          "x": 540,
          "y": 620,
          "width": 960,
          "height": 1080,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "radius": {
            "tl": 40,
            "tr": 40,
            "bl": 40,
            "br": 40
          },
          "track": 1,
          "enterBegin": 0,
          "enterEnd": 0.55,
          "enterAnimation": "smoothright",
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#FBF4EC'/></svg>"
