        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect x='60' y='80' width='960' height='1080' rx='40' fill='none' stroke='rgba(58,36,25,0.14)' stroke-width='1.5'/><rect x='120' y='1270' width='84' height='8' rx='4' fill='#C15B32'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 120,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "circleopen",
          "exitEnd": 4,
          "style": {
            "fontFamily": "Fraunces"
          },
          "html": "<div style='display:inline-block; background:{{accent}}; color:#FBF4EC; border-radius:20px; padding:14px 30px; font-size:40px; font-weight:600;'>{{room.index}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1300,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": {
            "fontFamily": "Fraunces"
          },
          "html": "<div style='color:#3A2419; font-size:82px; line-height:1; font-weight:600; letter-spacing:-1px;'>{{room.room}}</div><div style='margin-top:18px; color:#7A5C4A; font-size:34px; line-height:1.4; font-weight:500; font-family:DM Sans, sans-serif;'>{{room.detail}}</div>"
        },
        {
          "type": "TEXT",
          "x": 990,
          "y": 1810,
          "anchor": "center-right",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 4,
          "style": {
            "fontFamily": "DM Sans"
          },
          "html": "<div style='color:#8A6B58; font-size:24px; font-weight:600; letter-spacing:3px;'>{{propertyName}} · {{summaryLine}}</div>"
        }
      ]
