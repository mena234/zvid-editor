{
  "name": "ecom-bogo",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0E0E0E",
  "outputFormat": "mp4",
  "variables": {
    "brandName": "REFILL RITUAL",
    "promoKicker": "THIS WEEK ONLY",
    "bogoBig": "BUY 1<br>GET 1",
    "bogoFree": "FREE",
    "productName": "Whole-home cleaning kit",
    "subLine": "Mix and match any two. The second one's on us.",
    "codeLabel": "USE CODE",
    "promoCode": "DOUBLE",
    "showCode": true,
    "ctaText": "Claim the deal",
    "ctaHandle": "refillritual.example",
    "accentColor": "#F5D029",
    "productImage": "https://images.pexels.com/photos/4440789/pexels-photo-4440789.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "offer",
      "duration": 4.4,
      "backgroundColor": "#0E0E0E",
      "transition": "slideup",
      "transitionId": "product",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#0E0E0E'/><rect x='0' y='0' width='1080' height='1920' fill='#F5D029'/><rect x='0' y='0' width='1080' height='960' fill='#0E0E0E'/><path d='M0 960 H1080' stroke='#0E0E0E' stroke-width='3'/><circle cx='540' cy='960' r='120' fill='#0E0E0E'/><circle cx='540' cy='960' r='120' fill='none' stroke='#F5D029' stroke-width='4'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 150,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; border:2px solid {{accentColor}}; color:{{accentColor}}; border-radius:999px; padding:14px 34px; font-size:26px; font-weight:800; letter-spacing:6px;'>{{promoKicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 380,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:150px; line-height:0.94; font-weight:800; letter-spacing:-4px;'>{{bogoBig}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 960,
          "anchor": "center-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "circleopen",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:64px; line-height:1; font-weight:800; letter-spacing:-1px;'>{{bogoFree}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1300,
          "width": 860,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.9,
          "enterEnd": 1.35,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#0E0E0E; font-size:44px; line-height:1.1; font-weight:800; letter-spacing:-1px;'>{{productName}}</div><div style='margin-top:18px; text-align:center; color:#3A3A2A; font-size:30px; line-height:1.35; font-weight:600;'>{{subLine}}</div>"
        }
      ]
    },
    {
      "id": "product",
      "duration": 4.6,
      "backgroundColor": "#0E0E0E",
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{productImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='bgShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0E0E0E' stop-opacity='0.4'/><stop offset='0.5' stop-color='#0E0E0E' stop-opacity='0.15'/><stop offset='1' stop-color='#0E0E0E' stop-opacity='0.96'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#bgShade)'/><rect x='72' y='1130' width='936' height='4' fill='#F5D029'/></svg>"
        },
        {
          "type": "TEXT",
          "condition": "{{showCode}}",
          "x": 540,
          "y": 220,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.35,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 4.6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#DADAC8; font-size:26px; font-weight:700; letter-spacing:5px;'>{{codeLabel}}</div><div style='margin-top:12px; display:inline-block; background:{{accentColor}}; color:#0E0E0E; border-radius:14px; padding:16px 44px; font-size:54px; font-weight:800; letter-spacing:6px;'>{{promoCode}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1220,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.55,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 4.6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:70px; line-height:1.06; font-weight:800; letter-spacing:-2px;'>Two for the<br>price of one.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1520,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.95,
          "enterEnd": 1.4,
          "enterAnimation": "circleopen",
          "exitEnd": 4.6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#0E0E0E; border-radius:999px; padding:26px 64px; font-size:42px; font-weight:800;'>{{ctaText}}</div><div style='margin-top:22px; text-align:center; color:#9A9A8C; font-size:26px; font-weight:600; letter-spacing:2px;'>{{ctaHandle}} · {{brandName}}</div>"
        }
      ]
    }
  ],
  "audios": [
    { "src": "{{musicUrl}}", "volume": 0.16 }
  ]
}
