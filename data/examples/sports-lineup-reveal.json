{
  "name": "sports-lineup-reveal",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#052E1B",
  "outputFormat": "mp4",
  "variables": {
    "kicker": "STARTING XI",
    "teamName": "LIVERPOOL FC",
    "formation": "4 - 3 - 3",
    "matchLabel": "vs Chelsea · Anfield",
    "accentColor": "#F5C542",
    "manager": "Manager: Arne Slot",
    "players": [
      { "num": "1", "name": "Alisson", "role": "GK" },
      { "num": "66", "name": "Alexander-Arnold", "role": "RB" },
      { "num": "4", "name": "Van Dijk", "role": "CB · CAPTAIN" },
      { "num": "10", "name": "Mac Allister", "role": "CM" },
      { "num": "8", "name": "Szoboszlai", "role": "CM" },
      { "num": "11", "name": "Salah", "role": "RW" },
      { "num": "9", "name": "Núñez", "role": "ST" }
    ],
    "bgImage": "https://images.pexels.com/photos/159594/soccer-football-player-sport-159594.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "intro",
      "duration": 3.6,
      "backgroundColor": "#052E1B",
      "transition": "smoothup",
      "transitionId": "player",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{bgImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.42,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='lrIntro' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#052E1B' stop-opacity='0.8'/><stop offset='0.5' stop-color='#052E1B' stop-opacity='0.4'/><stop offset='1' stop-color='#052E1B' stop-opacity='0.95'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#lrIntro)'/><path d='M120 1120 H960' stroke='#F5C542' stroke-width='5'/><circle cx='540' cy='620' r='150' fill='none' stroke='rgba(245,197,66,0.4)' stroke-width='2'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 800,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.75,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:32px; font-weight:900; letter-spacing:10px;'>{{kicker}}</div><div style='margin-top:20px; text-align:center; color:#FFFFFF; font-size:104px; line-height:0.95; font-weight:900; letter-spacing:-3px;'>{{teamName}}</div><div style='margin-top:22px; text-align:center; color:#8FD6AE; font-size:32px; font-weight:700; letter-spacing:4px;'>{{formation}} · {{matchLabel}}</div>"
        }
      ]
    },
    {
      "id": "player",
      "iterate": "players",
      "iterateAs": "p",
      "duration": 2.4,
      "backgroundColor": "#052E1B",
      "transition": "slideleft",
      "transitionId": "outro",
      "transitionDuration": 0.4,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 2.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='lrP' x1='0' y1='0' x2='1' y2='1'><stop offset='0' stop-color='#0A4429'/><stop offset='1' stop-color='#052E1B'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#lrP)'/><rect x='0' y='0' width='1080' height='1920' fill='none'/><path d='M0 780 H1080' stroke='rgba(245,197,66,0.25)' stroke-width='2'/><path d='M0 1140 H1080' stroke='rgba(245,197,66,0.25)' stroke-width='2'/><rect x='90' y='840' width='900' height='240' rx='28' fill='rgba(255,255,255,0.04)' stroke='rgba(245,197,66,0.4)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 300,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "smoothright",
          "exitEnd": 2.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:rgba(245,197,66,0.9); font-size:400px; line-height:0.8; font-weight:900; letter-spacing:-14px;'>{{p.num}}</div>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 890,
          "width": 820,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.35,
          "enterEnd": 0.8,
          "enterAnimation": "smoothleft",
          "exitEnd": 2.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#FFFFFF; font-size:84px; line-height:0.95; font-weight:900; letter-spacing:-2px;'>{{p.name}}</div><div style='margin-top:14px; color:{{accentColor}}; font-size:30px; font-weight:800; letter-spacing:5px;'>{{p.role}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1620,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 2.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:rgba(255,255,255,0.6); font-size:26px; font-weight:800; letter-spacing:6px;'>{{teamName}} · {{formation}}</div>"
        }
      ]
    },
    {
      "id": "outro",
      "duration": 3.4,
      "backgroundColor": "#052E1B",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='lrOut' cx='0.5' cy='0.4' r='0.9'><stop offset='0' stop-color='#0A4429'/><stop offset='1' stop-color='#052E1B'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#lrOut)'/><circle cx='540' cy='720' r='170' fill='none' stroke='#F5C542' stroke-width='4'/><path d='M470 720 l50 50 l120 -130' fill='none' stroke='#F5C542' stroke-width='14' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 970,
          "width": 880,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:70px; line-height:1.05; font-weight:900; letter-spacing:-2px;'>THIS IS<br>ANFIELD.</div><div style='margin-top:26px; text-align:center; color:{{accentColor}}; font-size:30px; font-weight:700; letter-spacing:3px;'>{{manager}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.16
    }
  ]
}
