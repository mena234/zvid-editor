          "y": 470,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Fraunces" },
