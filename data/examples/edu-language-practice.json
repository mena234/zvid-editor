{
  "name": "edu-language-practice",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#FBF3E7",
  "outputFormat": "mp4",
  "variables": {
    "channelName": "PARLONS · everyday French",
    "kicker": "SAY IT LIKE A LOCAL",
    "introLine": "5 café phrases you'll use on day one",
    "languagePair": "French → English",
    "phrases": [
      {
        "index": "01",
        "phrase": "Un café, s'il vous plaît.",
        "pronounce": "uhn ka-FAY seel voo PLEH",
        "translation": "A coffee, please."
      },
      {
        "index": "02",
        "phrase": "L'addition, s'il vous plaît.",
        "pronounce": "la-dee-SYON seel voo PLEH",
        "translation": "The bill, please."
      },
      {
        "index": "03",
        "phrase": "C'était délicieux !",
        "pronounce": "say-TAY day-lee-SYUH",
        "translation": "That was delicious!"
      }
    ],
    "ctaText": "Practice out loud — then save",
    "accentColor": "#E8613C",
    "inkColor": "#2A211A",
    "bgImage": "https://images.pexels.com/photos/6152745/pexels-photo-6152745.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "intro",
      "duration": 3.4,
      "backgroundColor": "#FBF3E7",
      "transition": "smoothleft",
      "transitionId": "phrase",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{bgImage}}",
          "x": 540,
          "y": 460,
          "width": 1080,
          "height": 760,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='lpIntro' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#FBF3E7' stop-opacity='0'/><stop offset='0.62' stop-color='#FBF3E7' stop-opacity='0.85'/><stop offset='0.75' stop-color='#FBF3E7' stop-opacity='1'/><stop offset='1' stop-color='#FBF3E7' stop-opacity='1'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#lpIntro)'/><path d='M120 1000 H420' stroke='#E8613C' stroke-width='6' stroke-linecap='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 120,
          "y": 1060,
          "width": 850,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='color:{{accentColor}}; font-size:26px; font-weight:800; letter-spacing:6px;'>{{kicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 120,
          "y": 1130,
          "width": 850,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Fraunces" },
          "html": "<div style='color:{{inkColor}}; font-size:82px; line-height:1.08; font-weight:700;'>{{introLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 120,
          "y": 1500,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.75,
          "enterEnd": 1.15,
          "enterAnimation": "fade",
          "exitEnd": 3.4,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='color:#8A7A68; font-size:30px; font-weight:700; letter-spacing:2px;'>{{languagePair}}</div>"
        }
      ]
    },
    {
      "id": "phrase",
      "iterate": "phrases",
      "iterateAs": "p",
      "duration": 4.2,
      "backgroundColor": "#FBF3E7",
      "transition": "smoothleft",
      "transitionId": "outro",
      "transitionDuration": 0.5,
      "visuals": [
