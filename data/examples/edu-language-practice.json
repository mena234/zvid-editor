        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1200,
          "width": 780,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.85,
          "enterEnd": 1.3,
          "enterAnimation": "smoothup",
          "exitEnd": 4.2,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='text-align:center; color:#6B5D4E; font-size:40px; line-height:1.35; font-weight:500;'>{{p.translation}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1740,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 4.2,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='color:#A2917E; font-size:24px; font-weight:700; letter-spacing:5px;'>{{channelName}}</div>"
