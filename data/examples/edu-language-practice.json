        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 980,
          "width": 880,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Fraunces" },
          "html": "<div style='text-align:center; color:#FBF3E7; font-size:64px; line-height:1.15; font-weight:700;'>Now say all three<br>without looking.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1260,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.75,
