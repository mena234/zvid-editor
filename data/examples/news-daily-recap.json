{
  "name": "news-daily-recap",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0E1524",
  "outputFormat": "mp4",
  "variables": {
    "showName": "THE MORNING BRIEF",
    "dateLine": "Tuesday · May 14",
    "introLine": "Everything you missed while you slept — in 60 seconds.",
    "coverImage": "https://images.pexels.com/photos/14604033/pexels-photo-14604033.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "outroLine": "That's your brief.",
    "handle": "@themorningbrief",
    "accentColor": "#4E8CFF",
    "headlines": [
      {
        "tag": "POLITICS",
        "title": "Senate passes sweeping infrastructure bill after marathon session",
        "detail": "The $1.2T package heads to the President's desk this week."
      },
      {
        "tag": "WORLD",
        "title": "Historic climate accord signed by 40 nations at summit",
        "detail": "Binding targets take effect January 2027."
      },
      {
        "tag": "BUSINESS",
        "title": "Tech giant unveils AI chip, shares jump 8% pre-market",
        "detail": "Analysts call it the biggest leap in a decade."
      },
      {
        "tag": "SCIENCE",
        "title": "Astronomers confirm water plumes on distant exomoon",
        "detail": "The discovery reshapes the search for life."
      }
    ],
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "cover",
      "duration": 3.2,
      "backgroundColor": "#0E1524",
      "transition": "smoothup",
      "transitionId": "story",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{coverImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.5,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.2
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='dncShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0E1524' stop-opacity='0.7'/><stop offset='0.5' stop-color='#0E1524' stop-opacity='0.55'/><stop offset='1' stop-color='#0E1524' stop-opacity='0.94'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#dncShade)'/><rect x='90' y='860' width='150' height='10' rx='5' fill='#4E8CFF'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 720,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "smoothright",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:#4E8CFF; font-size:30px; font-weight:700; letter-spacing:8px;'>{{showName}}</div><div style='margin-top:12px; color:rgba(255,255,255,0.6); font-size:26px; font-weight:600; letter-spacing:4px;'>{{dateLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 920,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.45,
          "enterEnd": 0.95,
          "enterAnimation": "smoothup",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#FFFFFF; font-size:66px; line-height:1.1; font-weight:800; letter-spacing:-1px;'>{{introLine}}</div>"
        }
      ]
    },
    {
      "id": "story",
      "iterate": "headlines",
      "iterateAs": "story",
      "duration": 3.1,
      "backgroundColor": "#0E1524",
      "transition": "smoothup",
      "transitionId": "outro",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.1,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='dncBg' cx='0.3' cy='0.32' r='1'><stop offset='0' stop-color='#16223A'/><stop offset='1' stop-color='#0E1524'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#dncBg)'/><rect x='80' y='560' width='920' height='800' rx='36' fill='rgba(255,255,255,0.04)' stroke='rgba(78,140,255,0.35)' stroke-width='1.5'/><rect x='80' y='560' width='920' height='12' rx='6' fill='#4E8CFF'/><path d='M140 1210 H940' stroke='rgba(255,255,255,0.12)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 300,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.1,
          "enterEnd": 0.5,
          "enterAnimation": "smoothright",
          "exitEnd": 3.1,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:rgba(78,140,255,0.55); font-size:220px; font-weight:700; letter-spacing:-8px; line-height:1;'>0{{index}}</div>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 620,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.3,
          "enterEnd": 0.7,
          "enterAnimation": "fade",
          "exitEnd": 3.1,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<span style='display:inline-block; background:rgba(78,140,255,0.16); border:1.5px solid rgba(78,140,255,0.5); color:#8FB6FF; border-radius:999px; padding:10px 26px; font-size:26px; font-weight:700; letter-spacing:4px;'>{{story.tag}}</span>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 720,
          "width": 820,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.45,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 3.1,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#FFFFFF; font-size:62px; line-height:1.08; font-weight:800; letter-spacing:-1px;'>{{story.title}}</div>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 1250,
          "width": 820,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.75,
          "enterEnd": 1.15,
          "enterAnimation": "fade",
          "exitEnd": 3.1,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:#A9B4C6; font-size:32px; line-height:1.4; font-weight:500;'>{{story.detail}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1780,
          "anchor": "center-center",
          "track": 11,
          "enterBegin": 0,
          "exitEnd": 3.1,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:rgba(255,255,255,0.4); font-size:24px; font-weight:700; letter-spacing:5px;'>{{showName}} · {{dateLine}}</div>"
        }
      ]
    },
    {
      "id": "outro",
      "duration": 3,
      "backgroundColor": "#0E1524",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='dncEnd' cx='0.5' cy='0.4' r='0.9'><stop offset='0' stop-color='#16233E'/><stop offset='1' stop-color='#0E1524'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#dncEnd)'/><circle cx='540' cy='760' r='120' fill='none' stroke='rgba(78,140,255,0.6)' stroke-width='2.5'/><path d='M492 760 L528 796 L596 720' fill='none' stroke='#4E8CFF' stroke-width='12' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 980,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:80px; font-weight:800; letter-spacing:-1px;'>{{outroLine}}</div><div style='margin-top:20px; text-align:center; color:#A9B4C6; font-size:32px; font-weight:500;'>Follow for tomorrow's brief.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1240,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.1,
          "enterAnimation": "circleopen",
          "exitEnd": 3,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#0E1524; border-radius:999px; padding:22px 54px; font-size:32px; font-weight:800;'>{{handle}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.15
    }
  ]
}
