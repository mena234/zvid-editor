{
  "name": "localservice-trust-badges",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0C2C24",
  "outputFormat": "mp4",
  "variables": {
    "brandName": "EVERGREEN HOME SERVICES",
    "kicker": "WHY LOCALS TRUST US",
    "hookLine": "The numbers<br>speak for us.",
    "hookSub": "Two decades of neighbours served right.",
    "stats": [
      {
        "value": "20+",
        "label": "YEARS IN BUSINESS",
        "note": "Family-owned since 2004"
      },
      {
        "value": "12,000+",
        "label": "HAPPY CUSTOMERS",
        "note": "And still counting every week"
      },
      {
        "value": "4.9★",
        "label": "AVERAGE RATING",
        "note": "Across 2,400+ verified reviews"
      }
    ],
    "ctaText": "Join our happy clients",
    "ctaSite": "evergreenhome.co",
    "accentColor": "#D4A24E",
    "handshakeImage": "https://images.pexels.com/photos/6773517/pexels-photo-6773517.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "hook",
      "duration": 3.8,
      "backgroundColor": "#0C2C24",
      "transition": "smoothup",
      "transitionId": "stat",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{handshakeImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.4,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.8
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='tbHook' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0C2C24' stop-opacity='0.82'/><stop offset='0.5' stop-color='#0C2C24' stop-opacity='0.5'/><stop offset='1' stop-color='#0C2C24' stop-opacity='0.94'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#tbHook)'/><rect x='48' y='48' width='984' height='1824' rx='40' fill='none' stroke='rgba(212,162,78,0.5)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 700,
          "width": 920,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:26px; font-weight:700; letter-spacing:6px;'>{{kicker}}</div><div style='margin-top:22px; text-align:center; color:#FFFFFF; font-size:98px; line-height:1.02; font-weight:800; letter-spacing:-2px;'>{{hookLine}}</div><div style='margin-top:24px; text-align:center; color:#BDD4C9; font-size:34px; font-weight:500;'>{{hookSub}}</div>"
        }
      ]
    },
    {
      "id": "stat",
      "iterate": "stats",
      "iterateAs": "s",
      "duration": 3.2,
      "backgroundColor": "#0C2C24",
      "transition": "smoothleft",
      "transitionId": "cta",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='tbStat' cx='0.5' cy='0.4' r='0.95'><stop offset='0' stop-color='#134034'/><stop offset='1' stop-color='#0C2C24'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#tbStat)'/><rect x='120' y='620' width='840' height='680' rx='44' fill='rgba(212,162,78,0.06)' stroke='rgba(212,162,78,0.5)' stroke-width='1.5'/><path d='M360 780 h360' stroke='rgba(212,162,78,0.6)' stroke-width='3' stroke-linecap='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 700,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:28px; font-weight:800; letter-spacing:5px;'>{{s.label}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 830,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.85,
          "enterAnimation": "circleopen",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:170px; line-height:1; font-weight:800; letter-spacing:-5px;'>{{s.value}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1140,
          "width": 760,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "smoothup",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='text-align:center; color:#BDD4C9; font-size:34px; font-weight:500;'>{{s.note}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1760,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='color:rgba(189,212,201,0.7); font-size:23px; font-weight:700; letter-spacing:4px;'>{{brandName}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 4.2,
      "backgroundColor": "#0C2C24",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='tbCta' cx='0.5' cy='0.42' r='0.95'><stop offset='0' stop-color='#164536'/><stop offset='1' stop-color='#0C2C24'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#tbCta)'/><rect x='48' y='48' width='984' height='1824' rx='40' fill='none' stroke='rgba(212,162,78,0.5)' stroke-width='1.5'/><circle cx='540' cy='620' r='150' fill='none' stroke='#D4A24E' stroke-width='3'/><path d='M486 620 l34 34 l70 -78' fill='none' stroke='#D4A24E' stroke-width='14' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 880,
          "width": 920,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:74px; line-height:1.08; font-weight:800; letter-spacing:-1px;'>Trusted by<br>your neighbours.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1200,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "smoothup",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#0C2C24; border-radius:999px; padding:26px 60px; font-size:40px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1380,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.05,
          "enterEnd": 1.5,
          "enterAnimation": "fade",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='text-align:center; color:#A9C4B7; font-size:30px; font-weight:700; letter-spacing:2px;'>{{ctaSite}}</div>"
        }
      ]
    }
  ],
  "audios": [
    { "src": "{{musicUrl}}", "volume": 0.16 }
  ]
}
