{
  "name": "events-countdown",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#04070F",
  "outputFormat": "mp4",
  "variables": {
    "eventName": "NEON NIGHTS FEST",
    "kicker": "THE COUNTDOWN IS ON",
    "dateLine": "Aug 30 · Harbor Grounds",
    "urgencyNote": "Gates lock the moment we hit capacity.",
    "showUrgency": true,
    "ctaText": "Grab your pass",
    "handle": "neonnights.live",
    "accentColor": "#22E0D6",
    "stages": [
      {
        "num": "7",
        "unit": "DAYS TO GO",
        "line": "Line-up drops this Friday."
      },
      {
        "num": "3",
        "unit": "DAYS TO GO",
        "line": "Final release tickets are live."
      },
      {
        "num": "1",
        "unit": "TOMORROW",
        "line": "This is your last call to lock a spot."
      }
    ],
    "heroVideo": "https://videos.pexels.com/video-files/34576602/14651995_1080_1920_30fps.mp4",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "intro",
      "duration": 3.4,
      "backgroundColor": "#04070F",
      "transition": "fade",
      "transitionId": "stage",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{heroVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='cdIntro' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#04070F' stop-opacity='0.75'/><stop offset='0.5' stop-color='#04070F' stop-opacity='0.45'/><stop offset='1' stop-color='#04070F' stop-opacity='0.95'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#cdIntro)'/><rect x='44' y='44' width='992' height='1832' rx='36' fill='none' stroke='rgba(34,224,214,0.3)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 820,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "circleopen",
          "exitEnd": 3.4,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='text-align:center; color:#22E0D6; font-size:28px; font-weight:800; letter-spacing:8px;'>{{kicker}}</div><div style='margin-top:22px; text-align:center; color:#FFFFFF; font-size:104px; line-height:0.98; font-weight:800; letter-spacing:-3px; font-family:Space Grotesk, sans-serif;'>{{eventName}}</div><div style='margin-top:28px; text-align:center; color:#8DA0B8; font-size:34px; font-weight:600;'>{{dateLine}}</div>"
        }
      ]
    },
    {
      "id": "stage",
      "iterate": "stages",
      "iterateAs": "s",
      "duration": 3,
      "backgroundColor": "#04070F",
      "transition": "smoothleft",
      "transitionId": "cta",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='cdStage' cx='0.5' cy='0.42' r='0.85'><stop offset='0' stop-color='#0A1730'/><stop offset='1' stop-color='#04070F'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#cdStage)'/><circle cx='540' cy='760' r='400' fill='none' stroke='rgba(34,224,214,0.7)' stroke-width='3'/><circle cx='540' cy='760' r='432' fill='none' stroke='rgba(34,224,214,0.25)' stroke-width='1.5'/><circle cx='540' cy='760' r='466' fill='none' stroke='rgba(34,224,214,0.12)' stroke-width='1'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 590,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "circleopen",
          "exitEnd": 3,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:#22E0D6; font-size:340px; line-height:0.9; font-weight:700; letter-spacing:-14px;'>{{s.num}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 800,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.75,
          "enterAnimation": "fade",
          "exitEnd": 3,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:44px; font-weight:800; letter-spacing:8px;'>{{s.unit}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1330,
          "width": 860,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.55,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 3,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='text-align:center; color:#9FB2C8; font-size:38px; line-height:1.35; font-weight:500;'>{{s.line}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 130,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 3,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='text-align:center; color:rgba(141,160,184,0.75); font-size:24px; font-weight:700; letter-spacing:5px;'>{{eventName}} · {{dateLine}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 4.2,
      "backgroundColor": "#04070F",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='cdCta' cx='0.5' cy='0.38' r='0.95'><stop offset='0' stop-color='#0D2140'/><stop offset='1' stop-color='#04070F'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#cdCta)'/><path d='M300 560 H780' stroke='#22E0D6' stroke-width='6' stroke-linecap='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 680,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 4.2,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:92px; line-height:1; font-weight:700; letter-spacing:-3px;'>The wait<br>is almost over.</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showUrgency}}",
          "x": 540,
          "y": 1010,
          "width": 860,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.6,
          "enterEnd": 1,
          "enterAnimation": "fade",
          "exitEnd": 4.2,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='text-align:center; color:#8DA0B8; font-size:36px; line-height:1.4; font-weight:500;'>{{urgencyNote}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1250,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.9,
          "enterEnd": 1.35,
          "enterAnimation": "smoothup",
          "exitEnd": 4.2,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#04070F; border-radius:999px; padding:30px 74px; font-size:44px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1440,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.3,
          "enterEnd": 1.7,
          "enterAnimation": "fade",
          "exitEnd": 4.2,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='text-align:center; color:#5E7088; font-size:30px; font-weight:600; letter-spacing:2px;'>{{handle}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.17
    }
  ]
}
