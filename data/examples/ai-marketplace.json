          "type": "IMAGE",
          "src": "{{t.image}}",
          "x": 540,
          "y": 620,
          "width": 900,
          "height": 940,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "radius": { "tl": 40, "tr": 40, "bl": 40, "br": 40 },
          "track": 1,
          "enterBegin": 0,
          "enterEnd": 0.5,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4,
