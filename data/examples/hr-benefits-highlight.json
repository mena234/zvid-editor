{
  "name": "hr-benefits-highlight",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0F2A22",
  "outputFormat": "mp4",
  "variables": {
    "companyName": "EVERGREEN CO.",
    "introKicker": "WHY WORK WITH US",
    "introTitle": "Perks that actually matter.",
    "salary": "Top 10% of market pay",
    "showSalary": true,
    "perks": [
      { "num": "01", "title": "Unlimited PTO", "desc": "Take the time you need — we mean it.", "icon": "🌴" },
      { "num": "02", "title": "Full health cover", "desc": "Medical, dental & vision for you and family.", "icon": "❤️" },
      { "num": "03", "title": "Learning budget", "desc": "$2,000 a year for courses and conferences.", "icon": "📚" },
      { "num": "04", "title": "Equity for all", "desc": "Everyone owns a real piece of the company.", "icon": "📈" }
    ],
    "ctaText": "See all benefits",
    "ctaUrl": "evergreen.co/careers",
    "accentColor": "#E5B94E",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "intro",
      "duration": 3.6,
      "backgroundColor": "#0F2A22",
      "transition": "smoothleft",
      "transitionId": "perk",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='bhIntro' cx='0.5' cy='0.4' r='0.95'><stop offset='0' stop-color='#164636'/><stop offset='1' stop-color='#0F2A22'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#bhIntro)'/><path d='M540 640 C520 560 560 480 620 470 C580 540 600 610 560 700 C600 660 660 660 680 610 C680 700 620 760 560 760 C560 810 555 850 555 890' fill='none' stroke='#E5B94E' stroke-width='10' stroke-linecap='round' stroke-linejoin='round'/><path d='M120 1000 H960' stroke='rgba(229,185,78,0.4)' stroke-width='3'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 96,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:#9BC4B4; font-size:26px; font-weight:700; letter-spacing:8px;'>{{companyName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1080,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:26px; font-weight:800; letter-spacing:6px;'>{{introKicker}}</div><div style='margin-top:22px; text-align:center; color:#FFFFFF; font-size:96px; line-height:1.02; font-weight:800; letter-spacing:-3px;'>{{introTitle}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showSalary}}",
          "x": 540,
          "y": 1500,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.9,
          "enterEnd": 1.35,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='display:inline-block; background:rgba(229,185,78,0.16); border:1.5px solid rgba(229,185,78,0.5); color:{{accentColor}}; border-radius:999px; padding:16px 38px; font-size:32px; font-weight:700;'>💰 {{salary}}</div>"
        }
      ]
    },
    {
      "id": "perk",
      "iterate": "perks",
      "iterateAs": "perk",
      "duration": 3.2,
      "backgroundColor": "#0F2A22",
      "transition": "smoothleft",
      "transitionId": "cta",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='bhPerk' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#123529'/><stop offset='1' stop-color='#0F2A22'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#bhPerk)'/><rect x='90' y='640' width='900' height='640' rx='44' fill='rgba(255,255,255,0.04)' stroke='rgba(229,185,78,0.4)' stroke-width='1.5'/><rect x='90' y='640' width='900' height='14' rx='7' fill='#E5B94E'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 420,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.6,
          "enterAnimation": "circleopen",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:rgba(229,185,78,0.35); font-size:150px; line-height:1; font-weight:800; letter-spacing:-4px;'>{{perk.num}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 720,
          "anchor": "center-center",
          "track": 11,
          "enterBegin": 0.3,
          "enterEnd": 0.75,
          "enterAnimation": "smoothup",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; font-size:96px;'>{{perk.icon}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 900,
          "width": 820,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.5,
          "enterEnd": 0.95,
          "enterAnimation": "smoothup",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:66px; line-height:1.04; font-weight:800; letter-spacing:-1px;'>{{perk.title}}</div><div style='margin-top:24px; text-align:center; color:#B7D3C7; font-size:36px; line-height:1.4; font-weight:500;'>{{perk.desc}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1780,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:rgba(255,255,255,0.45); font-size:24px; font-weight:700; letter-spacing:5px;'>{{companyName}} · BENEFITS</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 4,
      "backgroundColor": "#E5B94E",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='bhCta' cx='0.5' cy='0.4' r='1'><stop offset='0' stop-color='#EDC968'/><stop offset='1' stop-color='#E5B94E'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#bhCta)'/><circle cx='540' cy='660' r='150' fill='none' stroke='rgba(15,42,34,0.55)' stroke-width='3'/><path d='M492 660 L528 696 L596 616' fill='none' stroke='#0F2A22' stroke-width='10' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 900,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.75,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:#0F2A22; font-size:78px; line-height:1.05; font-weight:800; letter-spacing:-2px;'>People-first,<br>always.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1200,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='display:inline-block; background:#0F2A22; color:{{accentColor}}; border-radius:999px; padding:26px 66px; font-size:40px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1380,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.1,
          "enterEnd": 1.5,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:rgba(15,42,34,0.75); font-size:28px; font-weight:700; letter-spacing:2px;'>{{ctaUrl}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.15
    }
  ]
}
