{
  "name": "social-tips-carousel",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#FBF7F0",
  "outputFormat": "mp4",
  "variables": {
    "channelName": "@worksmarter.club",
    "topic": "3 tiny habits that save 5 hours a week",
    "ctaText": "Follow for one tip a day",
    "coverImage": "https://images.pexels.com/photos/5185154/pexels-photo-5185154.jpeg?auto=compress&cs=tinysrgb&w=1620",
    "tips": [
      {
        "num": "1",
        "title": "Touch it once",
        "detail": "Open an email? Answer it, archive it, or schedule it. Never just read and leave."
      },
      {
        "num": "2",
        "title": "Two-minute rule",
        "detail": "If a task takes under two minutes, do it now — the reminder costs more than the task."
      },
      {
        "num": "3",
        "title": "Theme your days",
        "detail": "Meetings Tuesday, deep work Wednesday. Context switching is the silent time thief."
      }
    ],
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "cover",
      "duration": 3.4,
      "backgroundColor": "#FBF7F0",
      "transition": "smoothleft",
      "transitionId": "tip",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{coverImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.35,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='rgba(251,247,240,0.8)'/><circle cx='900' cy='260' r='190' fill='rgba(240,113,74,0.14)'/><circle cx='170' cy='1650' r='150' fill='rgba(240,113,74,0.1)'/><path d='M80 1010 H320' stroke='#F0714A' stroke-width='6' stroke-linecap='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 700,
          "width": 920,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='color:#F0714A; font-size:26px; font-weight:800; letter-spacing:5px;'>QUICK TIPS</div><div style='margin-top:18px; color:#231F1A; font-size:84px; line-height:1.05; font-weight:800; letter-spacing:-2px;'>{{topic}}</div>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 1080,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.7,
          "enterEnd": 1.1,
          "enterAnimation": "fade",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='color:#8B8378; font-size:28px; font-weight:600;'>Keep watching — number 3 is the sneaky one 👀</div>"
        }
      ]
    },
    {
      "id": "tip",
      "iterate": "tips",
      "iterateAs": "tip",
      "duration": 3.8,
      "backgroundColor": "#FBF7F0",
      "transition": "smoothleft",
      "transitionId": "outro",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#FBF7F0'/><circle cx='540' cy='560' r='170' fill='#F0714A'/><circle cx='540' cy='560' r='200' fill='none' stroke='rgba(240,113,74,0.35)' stroke-width='2'/><path d='M120 1620 H960' stroke='rgba(35,31,26,0.12)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 560,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.5,
          "enterAnimation": "circleopen",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='text-align:center; color:#FBF7F0; font-size:150px; font-weight:800;'>{{tip.num}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 860,
          "width": 880,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='text-align:center; color:#231F1A; font-size:66px; line-height:1.05; font-weight:800; letter-spacing:-1px;'>{{tip.title}}</div><div style='margin-top:26px; text-align:center; color:#5E574C; font-size:31px; line-height:1.5; font-weight:500;'>{{tip.detail}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1680,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 3.8,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='text-align:center; color:#A39B8E; font-size:23px; font-weight:600; letter-spacing:4px;'>{{channelName}}</div>"
        }
      ]
    },
    {
      "id": "outro",
      "duration": 3.6,
      "backgroundColor": "#231F1A",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#231F1A'/><circle cx='540' cy='700' r='120' fill='rgba(240,113,74,0.16)' stroke='rgba(240,113,74,0.6)' stroke-width='2.5'/><path d='M496 700 L528 734 L590 664' stroke='#F0714A' stroke-width='13' fill='none' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 900,
          "width": 880,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='text-align:center; color:#FBF7F0; font-size:62px; line-height:1.1; font-weight:800;'>Which one are you<br>trying first?</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1220,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.8,
          "enterEnd": 1.2,
          "enterAnimation": "circleopen",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='display:inline-block; background:#F0714A; color:#231F1A; border-radius:999px; padding:24px 60px; font-size:34px; font-weight:800;'>{{ctaText}}</div><div style='margin-top:16px; text-align:center; color:#8B8378; font-size:24px; letter-spacing:4px;'>{{channelName}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.18
    }
  ]
}
