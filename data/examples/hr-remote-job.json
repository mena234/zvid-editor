    "timezone": "Overlap 4h with CET",
    "perks": [
      { "icon": "🌍", "text": "Work from any country" },
      { "icon": "🕒", "text": "Async-first, flexible hours" },
      { "icon": "✈️", "text": "2 team retreats a year" }
