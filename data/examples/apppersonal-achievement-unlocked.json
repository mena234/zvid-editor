{
  "name": "apppersonal-achievement-unlocked",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#050B14",
  "outputFormat": "mp4",
  "variables": {
    "appName": "SUMMIT",
    "userName": "Alex",
    "kicker": "Achievement unlocked",
    "badgeTitle": "Trailblazer",
    "badgeSub": "Logged 100 workouts",
    "flavorLine": "Only 3% of members ever reach this. You earned it.",
    "ctaText": "Show off your badge",
    "showReward": true,
    "rewardText": "Reward: 1 month of Summit Pro, on us",
    "accent": "#38E1FF",
    "accent2": "#F5C542",
    "bgVideo": "https://videos.pexels.com/video-files/19732710/19732710-uhd_1440_2560_60fps.mp4",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "reveal",
      "duration": 4.6,
      "backgroundColor": "#050B14",
      "transition": "fade",
      "transitionId": "detail",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{bgVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "opacity": 0.6,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.6,
