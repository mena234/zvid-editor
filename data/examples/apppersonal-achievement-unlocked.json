        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 780,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.75,
          "enterAnimation": "smoothup",
          "exitEnd": 5,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#8AA8C4; font-size:30px; font-weight:700; letter-spacing:5px;'>{{userName}}, YOU DID IT</div><div style='margin-top:24px; text-align:center; color:#FFFFFF; font-size:52px; line-height:1.3; font-weight:600;'>{{flavorLine}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showReward}}",
          "x": 540,
          "y": 1584,
          "width": 760,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.9,
          "enterEnd": 1.35,
          "enterAnimation": "fade",
          "exitEnd": 5,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#38E1FF; font-size:32px; font-weight:700; padding-top:14px;'>{{rewardText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1200,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "circleopen",
          "exitEnd": 5,
          "style": { "fontFamily": "Bricolage Grotesque" },
          "html": "<div style='display:inline-block; background:#F5C542; color:#3A2A00; border-radius:999px; padding:28px 66px; font-size:40px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1360,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.05,
          "enterEnd": 1.45,
          "enterAnimation": "fade",
          "exitEnd": 5,
          "style": { "fontFamily": "Space Grotesk" },
