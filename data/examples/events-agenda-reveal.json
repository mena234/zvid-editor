{
  "name": "events-agenda-reveal",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#FBF3E7",
  "outputFormat": "mp4",
  "variables": {
    "eventName": "GROWTH SUMMIT",
    "introKicker": "THE FULL AGENDA",
    "introTitle": "One day. Five sessions. Zero fluff.",
    "introSub": "Here's everything on the schedule for Sept 20.",
    "outroLine": "Doors open 9:00 AM.<br>See you there.",
    "ctaText": "Get the full schedule",
    "handle": "growthsummit.co",
    "accentColor": "#F26B21",
    "inkColor": "#211A12",
    "agenda": [
      {
        "time": "09:30",
        "title": "Opening Keynote",
        "speaker": "The year in growth — what actually changed",
        "track": "Main Stage"
      },
      {
        "time": "11:00",
        "title": "Paid Acquisition Deep Dive",
        "speaker": "Building a $0.10/lead funnel from scratch",
        "track": "Workshop A"
      },
      {
        "time": "13:30",
        "title": "Retention Panel",
        "speaker": "Four operators on keeping users past day 30",
        "track": "Main Stage"
      },
      {
        "time": "15:00",
        "title": "Automation Lab",
        "speaker": "Ship 40 videos a week without an editor",
        "track": "Workshop B"
      },
      {
        "time": "16:30",
        "title": "Fireside & Networking",
        "speaker": "Closing chat + drinks on the rooftop",
        "track": "Rooftop"
      }
    ],
    "bgImage": "https://images.pexels.com/photos/6985132/pexels-photo-6985132.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "intro",
      "duration": 3.6,
      "backgroundColor": "#FBF3E7",
      "transition": "smoothleft",
      "transitionId": "item",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{bgImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.22,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='arIntro' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#FBF3E7' stop-opacity='0.7'/><stop offset='0.5' stop-color='#FBF3E7' stop-opacity='0.88'/><stop offset='1' stop-color='#FBF3E7' stop-opacity='0.98'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#arIntro)'/><rect x='90' y='1120' width='170' height='8' rx='4' fill='#F26B21'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 200,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 3.6,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:#F26B21; font-size:28px; font-weight:700; letter-spacing:8px;'>{{eventName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 780,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='color:#F26B21; font-size:26px; font-weight:700; letter-spacing:6px;'>{{introKicker}}</div><div style='margin-top:18px; color:#211A12; font-size:92px; line-height:1; font-weight:700; letter-spacing:-3px;'>{{introTitle}}</div><div style='margin-top:150px; color:#6B5F4E; font-size:34px; line-height:1.4; font-weight:500; font-family:Sora, sans-serif;'>{{introSub}}</div>"
        }
      ]
    },
    {
      "id": "item",
      "iterate": "agenda",
      "iterateAs": "row",
      "duration": 3.2,
      "backgroundColor": "#FBF3E7",
      "transition": "smoothup",
      "transitionId": "outro",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#FBF3E7'/><rect x='70' y='560' width='940' height='800' rx='44' fill='#FFFFFF' stroke='rgba(33,26,18,0.1)' stroke-width='1.5'/><rect x='70' y='560' width='940' height='14' rx='7' fill='#F26B21'/><path d='M150 940 H930' stroke='rgba(33,26,18,0.1)' stroke-width='1.5'/><circle cx='860' cy='680' r='54' fill='rgba(242,107,33,0.12)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 210,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:#B4A794; font-size:24px; font-weight:700; letter-spacing:6px;'>{{eventName}} · SCHEDULE</div>"
        },
        {
          "type": "TEXT",
          "x": 150,
          "y": 640,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "smoothleft",
          "exitEnd": 3.2,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='color:#F26B21; font-size:88px; line-height:1; font-weight:700; letter-spacing:-3px;'>{{row.time}}</div>"
        },
        {
          "type": "TEXT",
          "x": 150,
          "y": 800,
          "width": 780,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 3.2,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='color:#211A12; font-size:64px; line-height:1.02; font-weight:700; letter-spacing:-1px;'>{{row.title}}</div><div style='margin-top:26px; color:#6B5F4E; font-size:34px; line-height:1.4; font-weight:500; font-family:Sora, sans-serif;'>{{row.speaker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 150,
          "y": 1230,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.6,
          "enterEnd": 1,
          "enterAnimation": "fade",
          "exitEnd": 3.2,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='display:inline-block; background:{{inkColor}}; color:#FBF3E7; border-radius:999px; padding:14px 32px; font-size:28px; font-weight:700; letter-spacing:1px;'>{{row.track}}</div>"
        }
      ]
    },
    {
      "id": "outro",
      "duration": 3.6,
      "backgroundColor": "#211A12",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='arOut' cx='0.5' cy='0.4' r='0.9'><stop offset='0' stop-color='#3A2E1E'/><stop offset='1' stop-color='#211A12'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#arOut)'/><circle cx='540' cy='640' r='120' fill='none' stroke='rgba(242,107,33,0.7)' stroke-width='2.5'/><path d='M500 640 L528 668 L582 604' fill='none' stroke='#F26B21' stroke-width='12' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 880,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:#FBF3E7; font-size:74px; line-height:1.12; font-weight:700; letter-spacing:-1px;'>{{outroLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1200,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "circleopen",
          "exitEnd": 3.6,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#211A12; border-radius:999px; padding:26px 62px; font-size:38px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1400,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.1,
          "enterEnd": 1.5,
          "enterAnimation": "fade",
          "exitEnd": 3.6,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='text-align:center; color:#9C8E78; font-size:30px; font-weight:600; letter-spacing:3px;'>{{handle}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.16
    }
  ]
}
