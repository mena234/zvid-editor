{
  "name": "events-session-reminder",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0C1030",
  "outputFormat": "mp4",
  "variables": {
    "eventName": "DEVWORLD 2026",
    "greeting": "Hi Jordan,",
    "reminderLabel": "YOUR SESSION STARTS SOON",
    "sessionTitle": "Building Agents That Actually Ship",
    "speaker": "with Priya Nair",
    "startsIn": "Starts in 30 minutes",
    "whenLine": "Today · 2:00 PM · Room C4",
    "joinNote": "Your seat is saved — just walk in.",
    "linkChip": "Add to calendar",
    "showLink": true,
    "ctaText": "View my schedule",
    "handle": "devworld.app",
    "accentColor": "#6EE7B7",
    "accent2": "#8B7BFF",
    "bgImage": "https://images.pexels.com/photos/6152745/pexels-photo-6152745.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "ping",
      "duration": 4.4,
      "backgroundColor": "#0C1030",
      "transition": "smoothup",
      "transitionId": "detail",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{bgImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.35,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='srShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0C1030' stop-opacity='0.85'/><stop offset='0.45' stop-color='#0C1030' stop-opacity='0.55'/><stop offset='1' stop-color='#0C1030' stop-opacity='0.96'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#srShade)'/><rect x='90' y='620' width='900' height='2' fill='rgba(110,231,183,0.5)'/><circle cx='150' cy='300' r='16' fill='#6EE7B7'/><circle cx='150' cy='300' r='30' fill='none' stroke='rgba(110,231,183,0.4)' stroke-width='2'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 210,
          "y": 278,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.6,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='color:#6EE7B7; font-size:26px; font-weight:800; letter-spacing:6px;'>{{reminderLabel}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 700,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='color:#B9C0E8; font-size:44px; font-weight:600; font-family:Sora, sans-serif;'>{{greeting}}</div><div style='margin-top:22px; color:#FFFFFF; font-size:88px; line-height:1.02; font-weight:700; letter-spacing:-2px;'>{{sessionTitle}}</div><div style='margin-top:24px; color:{{accent2}}; font-size:38px; font-weight:600; font-family:Sora, sans-serif;'>{{speaker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1620,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.95,
          "enterEnd": 1.4,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#0C1030; border-radius:999px; padding:16px 38px; font-size:32px; font-weight:800;'>{{startsIn}}</div>"
        }
      ]
    },
    {
      "id": "detail",
      "duration": 4.4,
      "backgroundColor": "#0C1030",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='srDetail' cx='0.5' cy='0.36' r='0.95'><stop offset='0' stop-color='#161B48'/><stop offset='1' stop-color='#0C1030'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#srDetail)'/><rect x='80' y='560' width='920' height='560' rx='44' fill='rgba(255,255,255,0.03)' stroke='rgba(139,123,255,0.4)' stroke-width='1.5'/><rect x='80' y='560' width='12' height='560' rx='6' fill='#8B7BFF'/><circle cx='540' cy='320' r='96' fill='none' stroke='rgba(110,231,183,0.6)' stroke-width='2.5'/><path d='M540 260 V320 L586 344' fill='none' stroke='#6EE7B7' stroke-width='10' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 140,
          "y": 620,
          "width": 820,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='color:#8B7BFF; font-size:26px; font-weight:700; letter-spacing:5px;'>WHERE & WHEN</div><div style='margin-top:16px; color:#FFFFFF; font-size:62px; line-height:1.05; font-weight:700; letter-spacing:-1px;'>{{whenLine}}</div><div style='margin-top:24px; color:#B9C0E8; font-size:34px; line-height:1.4; font-weight:500; font-family:Sora, sans-serif;'>{{joinNote}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showLink}}",
          "x": 140,
          "y": 1220,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='display:inline-block; background:rgba(139,123,255,0.16); border:1.5px solid rgba(139,123,255,0.6); color:#B7AEFF; border-radius:16px; padding:16px 36px; font-size:30px; font-weight:700;'>{{linkChip}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1440,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1,
          "enterEnd": 1.45,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='display:inline-block; background:#6EE7B7; color:#0C1030; border-radius:999px; padding:26px 62px; font-size:38px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1620,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.35,
          "enterEnd": 1.75,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='text-align:center; color:#6C74A0; font-size:28px; font-weight:600; letter-spacing:3px;'>{{eventName}} · {{handle}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.15
    }
  ]
}
