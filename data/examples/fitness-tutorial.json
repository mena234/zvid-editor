{
  "name": "fitness-tutorial",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#050B14",
  "outputFormat": "mp4",
  "variables": {
    "coachHandle": "@coach.nadia",
    "moveLabel": "PERFECT YOUR FORM",
    "moveName": "The Goblet Squat",
    "moveSummary": "Build bulletproof legs and a braced core — the safest squat to master first.",
    "heroImage": "https://images.unsplash.com/photo-1548690312-e3b507d8c110?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3MDgwMTZ8MHwxfHNlYXJjaHw3fHxneW0lMjB3b3Jrb3V0JTIwZml0bmVzcyUyMHRyYWluaW5nfGVufDB8fHx8MTc4MzI2ODU4Nnww&ixlib=rb-4.1.0&q=80&w=1080",
    "outroHeadline": "Reps that build.<br>Not reps that break.",
    "outroSub": "Save this before your next leg day.",
    "accent": "#38E1FF",
    "steps": [
      {
        "step": "Set up",
        "cue": "Hold the bell at chest height",
        "tip": "Elbows tucked, ribs down — brace like you're about to be poked."
      },
      {
        "step": "Descend",
        "cue": "Sit back and down between the hips",
        "tip": "Knees track over toes. Keep the whole foot planted, weight mid-heel."
      },
      {
        "step": "Depth",
        "cue": "Hip crease below the knee",
        "tip": "Only go as low as you can keep a flat, neutral spine. Depth is earned."
      },
      {
        "step": "Drive",
        "cue": "Push the floor away, squeeze glutes",
        "tip": "Exhale on the way up. Stand tall — don't let the knees cave in."
      }
    ],
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "intro",
      "duration": 4,
      "backgroundColor": "#050B14",
      "transition": "smoothleft",
      "transitionId": "step",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{heroImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='tutHook' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#050B14' stop-opacity='0.68'/><stop offset='0.45' stop-color='#050B14' stop-opacity='0.12'/><stop offset='1' stop-color='#050B14' stop-opacity='0.95'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#tutHook)'/><rect x='90' y='1290' width='120' height='7' rx='3' fill='#38E1FF'/></svg>"
