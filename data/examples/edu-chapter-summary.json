{
  "name": "edu-chapter-summary",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#12241C",
  "outputFormat": "mp4",
  "variables": {
    "courseName": "Atomic Habits · Study Notes",
    "kicker": "CHAPTER RECAP",
    "chapterNumber": "Chapter 2",
    "chapterTitle": "How Your Habits Shape Your Identity",
    "readTime": "4-min recap",
    "points": [
      {
        "num": "1",
        "heading": "Identity beats outcomes",
        "body": "Don't chase a goal — become the type of person who reaches it."
      },
      {
        "num": "2",
        "heading": "Every action is a vote",
        "body": "Each habit is evidence of the identity you're building, one rep at a time."
      },
      {
        "num": "3",
        "heading": "Start with two words",
        "body": "Decide who you want to be, then prove it with small wins daily."
      }
    ],
    "closingLine": "You don't rise to your goals. You fall to your systems.",
    "showBadge": true,
    "badgeText": "★ Book Club Pick",
    "ctaText": "Save the whole summary",
    "accentColor": "#E7C15A",
    "bgImage": "https://images.pexels.com/photos/28337835/pexels-photo-28337835.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "cover",
      "duration": 4.4,
      "backgroundColor": "#12241C",
      "transition": "fade",
      "transitionId": "point",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{bgImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "opacity": 0.5,
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='csCover' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0C1912' stop-opacity='0.82'/><stop offset='0.5' stop-color='#12241C' stop-opacity='0.7'/><stop offset='1' stop-color='#0C1912' stop-opacity='0.95'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#csCover)'/><rect x='56' y='56' width='968' height='1808' rx='40' fill='none' stroke='rgba(231,193,90,0.32)' stroke-width='1.5'/><path d='M120 1180 H360' stroke='#E7C15A' stroke-width='5' stroke-linecap='round'/></svg>"
        },
        {
          "type": "TEXT",
          "condition": "{{showBadge}}",
          "x": 120,
          "y": 160,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='display:inline-block; border:1.5px solid rgba(231,193,90,0.7); color:#E7C15A; border-radius:999px; padding:12px 32px; font-size:26px; font-weight:700; letter-spacing:3px;'>{{badgeText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 120,
          "y": 1000,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:#E7C15A; font-size:30px; font-weight:800; letter-spacing:7px;'>{{kicker}} · {{chapterNumber}}</div>"
        },
        {
          "type": "TEXT",
          "x": 120,
          "y": 1240,
          "width": 860,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.55,
          "enterEnd": 1.05,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Fraunces" },
          "html": "<div style='color:#F4EFE1; font-size:80px; line-height:1.08; font-weight:700;'>{{chapterTitle}}</div>"
        },
        {
          "type": "TEXT",
          "x": 120,
          "y": 1680,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.9,
          "enterEnd": 1.3,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:#9DB0A2; font-size:28px; font-weight:700; letter-spacing:2px;'>{{courseName}} · {{readTime}}</div>"
        }
      ]
    },
    {
      "id": "point",
      "iterate": "points",
      "iterateAs": "pt",
      "duration": 3.6,
      "backgroundColor": "#12241C",
      "transition": "smoothleft",
      "transitionId": "closing",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='csPt' cx='0.3' cy='0.32' r='0.95'><stop offset='0' stop-color='#193226'/><stop offset='1' stop-color='#0E1D16'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#csPt)'/><rect x='80' y='620' width='920' height='700' rx='38' fill='rgba(255,255,255,0.03)' stroke='rgba(231,193,90,0.3)' stroke-width='1.5'/><line x1='150' y1='700' x2='150' y2='1240' stroke='#E7C15A' stroke-width='5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 96,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:rgba(157,176,162,0.75); font-size:24px; font-weight:700; letter-spacing:5px;'>{{chapterNumber}} · KEY TAKEAWAYS</div>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 360,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.6,
          "enterAnimation": "smoothright",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Fraunces" },
          "html": "<div style='color:{{accentColor}}; font-size:180px; line-height:1; font-weight:700;'>{{pt.num}}</div>"
        },
        {
          "type": "TEXT",
          "x": 210,
          "y": 720,
          "width": 720,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Fraunces" },
          "html": "<div style='color:#F4EFE1; font-size:64px; line-height:1.08; font-weight:700;'>{{pt.heading}}</div>"
        },
        {
          "type": "TEXT",
          "x": 210,
          "y": 980,
          "width": 720,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.6,
          "enterEnd": 1.05,
          "enterAnimation": "fade",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:#B7C8BC; font-size:40px; line-height:1.4; font-weight:500;'>{{pt.body}}</div>"
        }
      ]
    },
    {
      "id": "closing",
      "duration": 4.4,
      "backgroundColor": "#0C1912",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='csEnd' cx='0.5' cy='0.4' r='0.95'><stop offset='0' stop-color='#1B3327'/><stop offset='1' stop-color='#0C1912'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#csEnd)'/><text x='540' y='620' text-anchor='middle' font-family='Georgia' font-size='240' fill='rgba(231,193,90,0.25)'>&#8220;</text><path d='M410 1520 H670' stroke='#E7C15A' stroke-width='5' stroke-linecap='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 800,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.75,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Fraunces" },
          "html": "<div style='text-align:center; color:#F4EFE1; font-size:62px; line-height:1.28; font-weight:700; font-style:italic;'>{{closingLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1580,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.8,
          "enterEnd": 1.2,
          "enterAnimation": "circleopen",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#12241C; border-radius:999px; padding:24px 58px; font-size:32px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1740,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.1,
          "enterEnd": 1.5,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='color:#7C9083; font-size:26px; font-weight:700; letter-spacing:4px;'>{{courseName}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.15
    }
  ]
}
