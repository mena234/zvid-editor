{
  "name": "agency-cta-testing-pack",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0B0718",
  "outputFormat": "mp4",
  "variables": {
    "brandName": "FLOWSTATE",
    "hookKicker": "SAME AD · 3 ENDINGS",
    "hookLine": "One product.<br>Three ways to close.",
    "hookSub": "Ship every variant, let the data pick the winner.",
    "hookImage": "https://images.unsplash.com/photo-1664277497095-424e085175e8?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3MDgwMTZ8MHwxfHNlYXJjaHwxfHxjb250ZW50JTIwY3JlYXRvciUyMHZsb2dnZXIlMjBjYW1lcmF8ZW58MHx8fHwxNzgzMjY4NjMxfDA&ixlib=rb-4.1.0&q=80&w=1080",
    "ctas": [
      {
        "tag": "VARIANT A · URGENCY",
        "headline": "Only 40 spots left this week.",
        "button": "Grab your spot",
        "note": "Best for warm, ready-to-buy traffic."
      },
      {
        "tag": "VARIANT B · CURIOSITY",
        "headline": "See the 3-step system inside.",
        "button": "Show me how",
        "note": "Best for cold audiences discovering you."
      },
      {
        "tag": "VARIANT C · RISK-FREE",
        "headline": "Try it free for 14 days.",
        "button": "Start free trial",
        "note": "Best for skeptics on the fence."
      }
    ],
    "outroLine": "Same creative. Different close. Let the numbers decide.",
    "handle": "flowstate.example",
    "accentColor": "#A46BFF",
    "accent2": "#22E3D6",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "hook",
      "duration": 4,
      "backgroundColor": "#0B0718",
      "transition": "slideleft",
      "transitionId": "variant",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{hookImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.55,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='ctpShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0B0718' stop-opacity='0.7'/><stop offset='0.45' stop-color='#0B0718' stop-opacity='0.35'/><stop offset='1' stop-color='#0B0718' stop-opacity='0.95'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#ctpShade)'/><path d='M-60 470 L1140 400 L1140 424 L-60 494 Z' fill='#A46BFF' opacity='0.9'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 180,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; border:1.5px solid rgba(164,107,255,0.6); color:{{accentColor}}; border-radius:999px; padding:12px 30px; font-size:24px; font-weight:700; letter-spacing:5px;'>{{hookKicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 800,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.45,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:92px; line-height:1.02; font-weight:700; letter-spacing:-2px;'>{{hookLine}}</div><div style='margin-top:28px; text-align:center; color:#B7A8D6; font-size:32px; line-height:1.4; font-weight:500;'>{{hookSub}}</div>"
        }
      ]
    },
    {
      "id": "variant",
      "iterate": "ctas",
      "iterateAs": "cta",
      "duration": 3.6,
      "backgroundColor": "#0B0718",
      "transition": "slideleft",
      "transitionId": "outro",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='ctpVar' cx='0.5' cy='0.34' r='0.95'><stop offset='0' stop-color='#170E2E'/><stop offset='1' stop-color='#0B0718'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#ctpVar)'/><rect x='90' y='640' width='900' height='700' rx='44' fill='rgba(164,107,255,0.06)' stroke='rgba(164,107,255,0.4)' stroke-width='1.5'/><path d='M90 760 H990' stroke='rgba(34,227,214,0.35)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 700,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "smoothleft",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:{{accent2}}; font-size:28px; font-weight:700; letter-spacing:5px;'>{{cta.tag}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 850,
          "width": 800,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:72px; line-height:1.08; font-weight:700; letter-spacing:-1px;'>{{cta.headline}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1130,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.6,
          "enterEnd": 1.05,
          "enterAnimation": "circleopen",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#0B0718; border-radius:999px; padding:24px 60px; font-size:38px; font-weight:800;'>{{cta.button}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1420,
          "width": 820,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.85,
          "enterEnd": 1.25,
          "enterAnimation": "fade",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#8E80AE; font-size:28px; line-height:1.4; font-weight:500;'>{{cta.note}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 120,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:rgba(183,168,214,0.7); font-size:24px; font-weight:700; letter-spacing:6px;'>{{brandName}}</div>"
        }
      ]
    },
    {
      "id": "outro",
      "duration": 4,
      "backgroundColor": "#0B0718",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='ctpOut' cx='0.5' cy='0.4' r='0.95'><stop offset='0' stop-color='#180F30'/><stop offset='1' stop-color='#0B0718'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#ctpOut)'/><circle cx='400' cy='700' r='40' fill='none' stroke='#A46BFF' stroke-width='4'/><circle cx='540' cy='700' r='40' fill='none' stroke='#22E3D6' stroke-width='4'/><circle cx='680' cy='700' r='40' fill='#A46BFF'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 850,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:58px; line-height:1.2; font-weight:700;'>{{outroLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1180,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.8,
          "enterEnd": 1.2,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; border:1.5px solid rgba(34,227,214,0.6); color:{{accent2}}; border-radius:999px; padding:18px 44px; font-size:30px; font-weight:700; letter-spacing:2px;'>{{handle}}</div>"
        }
      ]
    }
  ],
  "audios": [
    { "src": "{{musicUrl}}", "volume": 0.18 }
  ]
}
