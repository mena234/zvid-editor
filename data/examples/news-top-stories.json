{
  "name": "news-top-stories",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0C0810",
  "outputFormat": "mp4",
  "variables": {
    "brand": "THE RUNDOWN",
    "dateLine": "Top Stories · Today",
    "introHeadline": "The 5 stories everyone's talking about.",
    "coverImage": "https://images.pexels.com/photos/6985132/pexels-photo-6985132.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "outroLine": "Now you're caught up.",
    "handle": "@therundown",
    "accentColor": "#FF3D9A",
    "stories": [
      {
        "cat": "TOP STORY",
        "title": "Central bank holds rates, signals first cut by autumn",
        "flag": true
      },
      {
        "cat": "WORLD",
        "title": "Ceasefire talks resume as both sides return to the table",
        "flag": false
      },
      {
        "cat": "TECH",
        "title": "Landmark AI safety law clears its final committee vote",
        "flag": false
      },
      {
        "cat": "HEALTH",
        "title": "New study links short daily walks to sharper memory",
        "flag": false
      },
      {
        "cat": "CULTURE",
        "title": "Streaming series breaks every record in its debut week",
        "flag": false
      }
    ],
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "cover",
      "duration": 3,
      "backgroundColor": "#0C0810",
      "transition": "wipeleft",
      "transitionId": "story",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{coverImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.55,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='topShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0C0810' stop-opacity='0.72'/><stop offset='0.5' stop-color='#0C0810' stop-opacity='0.45'/><stop offset='1' stop-color='#0C0810' stop-opacity='0.95'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#topShade)'/><rect x='90' y='1030' width='150' height='10' rx='5' fill='#FF3D9A'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 880,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.12,
          "enterEnd": 0.52,
          "enterAnimation": "smoothright",
          "exitEnd": 3,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#FF3D9A; font-size:32px; font-weight:900; letter-spacing:10px;'>{{brand}}</div><div style='margin-top:10px; color:rgba(255,255,255,0.65); font-size:26px; font-weight:600; letter-spacing:4px;'>{{dateLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1090,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.42,
          "enterEnd": 0.92,
          "enterAnimation": "smoothup",
          "exitEnd": 3,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#FFFFFF; font-size:74px; line-height:1.06; font-weight:900; letter-spacing:-2px;'>{{introHeadline}}</div>"
        }
      ]
    },
    {
      "id": "story",
      "iterate": "stories",
      "iterateAs": "s",
      "duration": 2.8,
      "backgroundColor": "#0C0810",
      "transition": "wipeleft",
      "transitionId": "outro",
      "transitionDuration": 0.4,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 2.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='topBg' cx='0.7' cy='0.3' r='1'><stop offset='0' stop-color='#1A0E1C'/><stop offset='1' stop-color='#0C0810'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#topBg)'/><path d='M90 1120 H990' stroke='rgba(255,61,154,0.4)' stroke-width='3'/><rect x='90' y='700' width='10' height='300' rx='5' fill='#FF3D9A'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 560,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.1,
          "enterEnd": 0.45,
          "enterAnimation": "smoothright",
          "exitEnd": 2.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:rgba(255,61,154,0.5); font-size:190px; font-weight:900; line-height:1; letter-spacing:-6px;'>0{{index}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{s.flag}}",
          "x": 560,
          "y": 600,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.25,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 2.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<span style='display:inline-block; background:#FF3D9A; color:#0C0810; padding:10px 26px; font-size:26px; font-weight:900; letter-spacing:4px;'>★ {{s.cat}}</span>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 1160,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.35,
          "enterEnd": 0.75,
          "enterAnimation": "smoothleft",
          "exitEnd": 2.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#FF3D9A; font-size:28px; font-weight:900; letter-spacing:5px;'>{{s.cat}}</div>"
        },
        {
          "type": "TEXT",
          "x": 130,
          "y": 1240,
          "width": 860,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.45,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 2.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#FFFFFF; font-size:64px; line-height:1.08; font-weight:900; letter-spacing:-1px;'>{{s.title}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1800,
          "anchor": "center-center",
          "track": 11,
          "enterBegin": 0,
          "exitEnd": 2.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:rgba(255,255,255,0.4); font-size:24px; font-weight:800; letter-spacing:5px;'>{{brand}} · {{dateLine}}</div>"
        }
      ]
    },
    {
      "id": "outro",
      "duration": 3,
      "backgroundColor": "#0C0810",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='topEnd' cx='0.5' cy='0.4' r='0.9'><stop offset='0' stop-color='#20102A'/><stop offset='1' stop-color='#0C0810'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#topEnd)'/><circle cx='540' cy='740' r='120' fill='none' stroke='#FF3D9A' stroke-width='3'/><path d='M494 740 L528 776 L594 700' fill='none' stroke='#FF3D9A' stroke-width='12' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 960,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:84px; line-height:1.05; font-weight:900; letter-spacing:-2px;'>{{outroLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1220,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.1,
          "enterAnimation": "circleopen",
          "exitEnd": 3,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#0C0810; border-radius:999px; padding:22px 56px; font-size:32px; font-weight:900;'>{{handle}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.18
    }
  ]
}
