{
  "name": "ai-tool-demo",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#07070C",
  "outputFormat": "mp4",
  "variables": {
    "toolName": "Nova AI",
    "kicker": "TEXT → IMAGE IN SECONDS",
    "headline": "Type a prompt.\nShip a visual.",
    "promptLabel": "YOUR PROMPT",
    "promptText": "a neon cyberpunk fox, volumetric fog, cinematic 85mm, ultra-detailed",
    "resultKicker": "GENERATED OUTPUT",
    "resultLine": "One line of text. A studio-grade render — no designer, no waiting.",
    "cta": "Try Nova free",
    "ctaUrl": "nova.ai/start",
    "accentColor": "#8B5CF6",
    "brandColor": "#22D3EE",
    "heroVideo": "https://videos.pexels.com/video-files/34576602/14651995_1080_1920_30fps.mp4",
    "resultImage": "https://pixabay.com/get/ge85d1f2751fdd4bc283af986480c64f3dc4924a3bfd863bc3fc323b8389bdf57701414c1768060c6ac5b2ce057cb918dfa76794f16f9fb23dd98139a9ed4d4dc_1280.jpg",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "hook",
      "duration": 4,
      "backgroundColor": "#07070C",
      "transition": "smoothup",
      "transitionId": "prompt",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{heroVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='hookShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#07070C' stop-opacity='0.72'/><stop offset='0.42' stop-color='#07070C' stop-opacity='0.15'/><stop offset='0.72' stop-color='#07070C' stop-opacity='0.4'/><stop offset='1' stop-color='#07070C' stop-opacity='0.94'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#hookShade)'/><rect x='44' y='44' width='992' height='1832' rx='44' fill='none' stroke='rgba(139,92,246,0.35)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 150,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.7,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='display:inline-block; border:1.5px solid rgba(34,211,238,0.6); border-radius:999px; padding:14px 34px; color:#22D3EE; font-size:26px; font-weight:700; letter-spacing:6px;'>{{toolName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 88,
          "y": 1210,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='color:{{brandColor}}; font-size:26px; font-weight:800; letter-spacing:5px;'>{{kicker}}</div><div style='margin-top:22px; color:#FFFFFF; font-size:100px; line-height:1.02; font-weight:700; letter-spacing:-3px;'>Type a prompt.<br>Ship a visual.</div><div style='margin-top:30px; width:150px; height:8px; border-radius:4px; background:{{accentColor}};'></div>"
        }
      ]
    },
    {
      "id": "prompt",
      "duration": 4.6,
      "backgroundColor": "#07070C",
      "transition": "smoothup",
      "transitionId": "result",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
