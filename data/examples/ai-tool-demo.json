        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 300,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "smoothup",
          "exitEnd": 4.6,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:#8A8FA6; font-size:26px; font-weight:800; letter-spacing:6px;'>STEP 01</div><div style='margin-top:16px; text-align:center; color:#FFFFFF; font-size:70px; line-height:1.05; font-weight:700; letter-spacing:-2px;'>You write the idea.</div>"
        },
        {
          "type": "TEXT",
          "x": 690,
          "y": 662,
          "anchor": "center-center",
          "track": 11,
          "enterBegin": 0.4,
          "enterEnd": 0.8,
          "enterAnimation": "fade",
          "exitEnd": 4.6,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='color:rgba(255,255,255,0.55); font-size:24px; font-weight:700; letter-spacing:4px;'>{{promptLabel}}</div>"
        },
        {
          "type": "TEXT",
          "x": 138,
          "y": 786,
          "width": 806,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.2,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.6,
          "style": {
            "fontFamily": "JetBrains Mono"
          },
          "html": "<div style='color:#22D3EE; font-size:34px; font-weight:700;'>&gt;_ <span style='color:#EDEBFF; font-weight:500;'>{{promptText}}</span></div><div style='margin-top:26px; display:inline-block; background:{{accentColor}}; color:#0A0A12; border-radius:14px; padding:14px 34px; font-size:28px; font-weight:800; letter-spacing:1px;'>Generate ↵</div>"
        }
      ]
    },
    {
      "id": "result",
      "duration": 4.8,
      "backgroundColor": "#07070C",
      "transition": "circleopen",
      "transitionId": "cta",
      "transitionDuration": 0.55,
