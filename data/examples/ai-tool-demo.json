          "type": "TEXT",
          "x": 540,
          "y": 168,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 4.8,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='display:inline-block; background:rgba(34,211,238,0.14); border:1.5px solid rgba(34,211,238,0.55); color:#22D3EE; border-radius:999px; padding:12px 30px; font-size:24px; font-weight:800; letter-spacing:5px;'>{{resultKicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1400,
          "width": 900,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.55,
          "enterEnd": 1.05,
          "enterAnimation": "smoothup",
