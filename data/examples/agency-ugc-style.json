{
  "name": "agency-ugc-style",
  "resolution": "tiktok",
  "frameRate": 30,
  "backgroundColor": "#000000",
  "outputFormat": "mp4",
  "variables": {
    "creatorHandle": "@mia.tries.stuff",
    "hookCaption": "I was NOT ready for this 😳",
    "caption2": "no filter. no edit. just the serum.",
    "caption3": "week two and my skin is glowing ✨",
    "productName": "Glow Serum by Lumière",
    "discount": "MIA15 = 15% off",
    "showDiscount": true,
    "ugcVideo": "https://videos.pexels.com/video-files/7677021/7677021-hd_1080_1920_25fps.mp4",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "ugc",
      "duration": 12,
      "backgroundColor": "#000000",
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{ugcVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 12
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 12,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='ugcShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#000000' stop-opacity='0.35'/><stop offset='0.35' stop-color='#000000' stop-opacity='0'/><stop offset='0.75' stop-color='#000000' stop-opacity='0'/><stop offset='1' stop-color='#000000' stop-opacity='0.6'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#ugcShade)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 200,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.5,
          "enterAnimation": "smoothdown",
          "exitEnd": 12,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='display:inline-block; background:rgba(0,0,0,0.55); color:#FFFFFF; border-radius:999px; padding:12px 30px; font-size:26px; font-weight:700;'>🎥 {{creatorHandle}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 640,
          "width": 900,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.4,
          "enterEnd": 0.7,
          "enterAnimation": "circleopen",
          "exitBegin": 3.7,
          "exitEnd": 4,
          "exitAnimation": "fade",
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:64px; line-height:1.15; font-weight:800; text-shadow:0 4px 24px rgba(0,0,0,0.85);'>{{hookCaption}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 640,
          "width": 900,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 4.1,
          "enterEnd": 4.4,
          "enterAnimation": "circleopen",
          "exitBegin": 7.7,
          "exitEnd": 8,
          "exitAnimation": "fade",
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:64px; line-height:1.15; font-weight:800; text-shadow:0 4px 24px rgba(0,0,0,0.85);'>{{caption2}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 640,
          "width": 900,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 8.1,
          "enterEnd": 8.4,
          "enterAnimation": "circleopen",
          "exitEnd": 12,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:64px; line-height:1.15; font-weight:800; text-shadow:0 4px 24px rgba(0,0,0,0.85);'>{{caption3}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1600,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 8.6,
          "enterEnd": 9,
          "enterAnimation": "smoothup",
          "exitEnd": 12,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='display:inline-block; background:#FFFFFF; color:#000000; border-radius:999px; padding:20px 48px; font-size:32px; font-weight:800;'>{{productName}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showDiscount}}",
          "x": 540,
          "y": 1730,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 9.2,
          "enterEnd": 9.6,
          "enterAnimation": "fade",
          "exitEnd": 12,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='display:inline-block; background:rgba(0,0,0,0.6); border:1.5px dashed rgba(255,255,255,0.7); color:#FFE24A; border-radius:14px; padding:12px 30px; font-size:28px; font-weight:800; letter-spacing:2px;'>{{discount}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.2
    }
  ]
}
