{
  "name": "market-price-drop",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#120611",
  "outputFormat": "mp4",
  "variables": {
    "marketName": "DROPZONE",
    "alertLabel": "PRICE DROP",
    "itemTitle": "Sony WH-1000XM5 Headphones",
    "itemSub": "Wireless · Noise Cancelling · Sealed",
    "oldPrice": "$399",
    "newPrice": "$249",
    "saveAmount": "Save $150 · 38% off",
    "urgencyLine": "Only 3 left at this price",
    "showDisclaimer": true,
    "disclaimer": "Price valid while stock lasts. No holds.",
    "ctaText": "Grab the deal",
    "ctaHandle": "dropzone.deals/xm5",
    "accentColor": "#FF3D77",
    "heroImage": "https://images.pexels.com/photos/6237886/pexels-photo-6237886.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "hook",
      "duration": 4,
      "backgroundColor": "#120611",
      "transition": "wipeleft",
      "transitionId": "drop",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{heroImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.55,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='pdShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#120611' stop-opacity='0.85'/><stop offset='0.5' stop-color='#120611' stop-opacity='0.5'/><stop offset='1' stop-color='#120611' stop-opacity='0.96'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#pdShade)'/><rect x='-40' y='560' width='1160' height='120' fill='#FF3D77' opacity='0.16' transform='rotate(-4 540 620)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 150,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:26px; font-weight:700; letter-spacing:9px;'>{{marketName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 560,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.35,
          "enterEnd": 0.85,
          "enterAnimation": "circleopen",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#FFFFFF; border-radius:14px; padding:18px 44px; font-size:46px; font-weight:700; letter-spacing:6px;'>{{alertLabel}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 760,
          "width": 920,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.55,
          "enterEnd": 1.05,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:76px; line-height:1.06; font-weight:700; letter-spacing:-2px;'>{{itemTitle}}</div><div style='margin-top:24px; text-align:center; color:#D6A8C4; font-size:30px; font-weight:500;'>{{itemSub}}</div>"
        }
      ]
    },
    {
      "id": "drop",
      "duration": 5,
      "backgroundColor": "#120611",
      "transition": "smoothup",
      "transitionId": "cta",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 5,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='pdGlow' cx='0.5' cy='0.42' r='0.9'><stop offset='0' stop-color='#2A0A22'/><stop offset='1' stop-color='#120611'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#pdGlow)'/><rect x='90' y='560' width='900' height='720' rx='40' fill='rgba(255,61,119,0.06)' stroke='rgba(255,61,119,0.45)' stroke-width='1.5'/><path d='M540 500 V430 M540 500 l-34 -40 M540 500 l34 -40' stroke='#FF3D77' stroke-width='8' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 300,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 5,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#D6A8C4; font-size:30px; font-weight:700; letter-spacing:6px;'>WAS → NOW</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 620,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 5,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#8A6A7C; font-size:72px; font-weight:700; text-decoration:line-through; letter-spacing:-1px;'>{{oldPrice}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 740,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.6,
          "enterEnd": 1.05,
          "enterAnimation": "circleopen",
          "exitEnd": 5,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:200px; line-height:0.9; font-weight:700; letter-spacing:-8px;'>{{newPrice}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1050,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.9,
          "enterEnd": 1.35,
          "enterAnimation": "smoothup",
          "exitEnd": 5,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:#FFFFFF; color:#120611; border-radius:999px; padding:16px 42px; font-size:36px; font-weight:700;'>{{saveAmount}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1180,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 1.15,
          "enterEnd": 1.6,
          "enterAnimation": "fade",
          "exitEnd": 5,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:34px; font-weight:700; letter-spacing:1px;'>⚡ {{urgencyLine}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showDisclaimer}}",
          "x": 540,
          "y": 1400,
          "width": 820,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 1.4,
          "enterEnd": 1.85,
          "enterAnimation": "fade",
          "exitEnd": 5,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#6E5464; font-size:24px; font-weight:500; letter-spacing:1px;'>{{disclaimer}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 4,
      "backgroundColor": "#120611",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='pdCta' cx='0.5' cy='0.42' r='0.95'><stop offset='0' stop-color='#2A0A22'/><stop offset='1' stop-color='#120611'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#pdCta)'/><circle cx='540' cy='660' r='150' fill='none' stroke='rgba(255,61,119,0.75)' stroke-width='2.5'/><path d='M540 600 l14 40 l42 0 l-34 26 l13 40 l-35 -25 l-35 25 l13 -40 l-34 -26 l42 0 z' fill='#FF3D77'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 900,
          "width": 920,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:72px; line-height:1.08; font-weight:700; letter-spacing:-1px;'>This price won't<br>last long.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1230,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#FFFFFF; border-radius:999px; padding:28px 68px; font-size:40px; font-weight:700;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1390,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1,
          "enterEnd": 1.4,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#8A6A7C; font-size:28px; font-weight:600; letter-spacing:1px;'>{{ctaHandle}}</div>"
        }
      ]
    }
  ],
  "audios": [
    { "src": "{{musicUrl}}", "volume": 0.18 }
  ]
}
