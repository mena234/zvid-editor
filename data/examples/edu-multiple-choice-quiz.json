          "html": "<div style='color:#EDECFF; font-size:32px; font-weight:700; letter-spacing:3px;'>Answer in 3… 2… 1…</div>"
        }
      ]
    },
    {
      "id": "reveal",
      "duration": 4.6,
      "backgroundColor": "#1B1B45",
