          "html": "<div style='display:inline-block; background:rgba(12,18,32,0.85); border-left:6px solid #58A6FF; color:#FFFFFF; border-radius:14px; padding:22px 34px; font-size:32px; font-weight:600;'>② {{callout2}}</div>"
