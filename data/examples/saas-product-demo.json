        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 850,
          "width": 900,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 4.9,
          "enterEnd": 5.3,
          "enterAnimation": "smoothleft",
