{
  "name": "local-event-night",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0E0A14",
  "outputFormat": "mp4",
  "variables": {
    "venueName": "THE VELVET ROOM",
    "eventName": "Vinyl & Vermouth Night",
    "eventDate": "Friday, July 11",
    "eventTime": "Doors 20:00 · Live set 21:30",
    "lineupNote": "Live jazz trio + guest DJ till late",
    "entryNote": "Free entry before 21:00",
    "showEntry": true,
    "ctaText": "Reserve a booth",
    "phone": "(555) 774-3121",
    "musicImage": "https://images.pexels.com/photos/1717079/pexels-photo-1717079.jpeg?auto=compress&cs=tinysrgb&w=1620",
    "crowdImage": "https://images.pexels.com/photos/28054799/pexels-photo-28054799.jpeg?auto=compress&cs=tinysrgb&w=1620",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "vibe",
      "duration": 4.4,
      "backgroundColor": "#0E0A14",
      "transition": "fade",
      "transitionId": "details",
      "transitionDuration": 0.6,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{musicImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='lenShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0E0A14' stop-opacity='0.55'/><stop offset='0.45' stop-color='#0E0A14' stop-opacity='0.2'/><stop offset='1' stop-color='#0E0A14' stop-opacity='0.88'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#lenShade)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 165,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Righteous" },
          "html": "<div style='text-align:center; color:#E9A6FF; font-size:28px; letter-spacing:9px;'>{{venueName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 80,
          "y": 1380,
          "width": 920,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Righteous" },
          "html": "<div style='color:#FFFFFF; font-size:88px; line-height:1.02;'>{{eventName}}</div><div style='margin-top:18px; font-family:DM Sans, sans-serif; color:#CBB3D9; font-size:30px; font-weight:600;'>🎷 {{lineupNote}}</div>"
        }
      ]
    },
    {
      "id": "details",
      "duration": 6,
      "backgroundColor": "#0E0A14",
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{crowdImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "opacity": 0.35,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='rgba(14,10,20,0.62)'/><rect x='90' y='480' width='900' height='830' rx='40' fill='rgba(14,10,20,0.88)' stroke='rgba(233,166,255,0.45)' stroke-width='1.5'/><path d='M90 730 H990' stroke='rgba(233,166,255,0.25)' stroke-width='1'/><circle cx='540' cy='380' r='7' fill='#E9A6FF'/><path d='M420 380 H500 M580 380 H660' stroke='rgba(233,166,255,0.5)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 545,
          "width": 800,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 6,
          "style": { "fontFamily": "Righteous" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:56px;'>{{eventDate}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 800,
          "width": 800,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.6,
          "enterEnd": 1.05,
          "enterAnimation": "smoothup",
          "exitEnd": 6,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='text-align:center; color:#E4D6EC; font-size:34px; line-height:1.7; font-weight:600;'>🕗 {{eventTime}}<br>🎶 {{lineupNote}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showEntry}}",
          "x": 540,
          "y": 1070,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 1.1,
          "enterEnd": 1.5,
          "enterAnimation": "circleopen",
          "exitEnd": 6,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='display:inline-block; background:rgba(233,166,255,0.16); border:1.5px dashed rgba(233,166,255,0.6); color:#F2D6FF; border-radius:18px; padding:18px 40px; font-size:29px; font-weight:700;'>🎟 {{entryNote}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1420,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 1.6,
          "enterEnd": 2,
          "enterAnimation": "smoothup",
          "exitEnd": 6,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='display:inline-block; background:#E9A6FF; color:#0E0A14; border-radius:999px; padding:26px 62px; font-size:34px; font-weight:800;'>{{ctaText}} · {{phone}}</div><div style='margin-top:16px; text-align:center; color:#8E7B9C; font-size:24px; letter-spacing:6px; font-family:Righteous, sans-serif;'>{{venueName}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.2
    }
  ]
}
