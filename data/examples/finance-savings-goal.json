        },
        {
          "type": "TEXT",
          "condition": "{{showBadge}}",
          "x": 540,
          "y": 1500,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.3,
          "enterEnd": 1.7,
          "enterAnimation": "circleopen",
          "exitEnd": 5.2,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='display:inline-block; background:rgba(18,184,134,0.14); border:1.5px solid rgba(18,184,134,0.5); color:{{accentDeep}}; border-radius:999px; padding:14px 40px; font-size:30px; font-weight:800;'>{{badgeText}}</div>"
