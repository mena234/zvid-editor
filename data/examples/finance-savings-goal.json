          "type": "TEXT",
          "x": 200,
          "y": 640,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "smoothup",
          "exitEnd": 5.2,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='color:#4E6B78; font-size:28px; font-weight:700; letter-spacing:2px;'>SAVED SO FAR</div><div style='margin-top:6px; color:{{ink}}; font-size:120px; line-height:1; font-weight:800; letter-spacing:-3px;'>{{saved}}</div><div style='margin-top:8px; color:#4E6B78; font-size:34px; font-weight:600;'>of {{target}} goal</div>"
        },
        {
          "type": "TEXT",
          "x": 812,
          "y": 780,
          "anchor": "center-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "circleopen",
          "exitEnd": 5.2,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='display:inline-block; background:{{accent}}; color:#FFFFFF; border-radius:999px; padding:10px 28px; font-size:34px; font-weight:800;'>{{percentLabel}}</div>"
        },
        {
          "type": "TEXT",
          "x": 300,
          "y": 1230,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.9,
          "enterEnd": 1.35,
          "enterAnimation": "smoothup",
          "exitEnd": 5.2,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='text-align:center; color:#4E6B78; font-size:24px; font-weight:700; letter-spacing:2px;'>THIS MONTH</div><div style='margin-top:8px; text-align:center; color:{{accentDeep}}; font-size:44px; line-height:1.1; font-weight:800;'>{{monthlyLine}}</div>"
