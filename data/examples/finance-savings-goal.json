      "backgroundColor": "#0E2A3A",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='sgOut' cx='0.5' cy='0.4' r='0.9'><stop offset='0' stop-color='#123B4E'/><stop offset='1' stop-color='#0E2A3A'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#sgOut)'/><circle cx='540' cy='700' r='150' fill='none' stroke='rgba(18,184,134,0.7)' stroke-width='3'/><path d='M470 700 L520 750 L620 640' fill='none' stroke='#12B886' stroke-width='12' stroke-linecap='round' stroke-linejoin='round'/></svg>"
