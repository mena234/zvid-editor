          "type": "TEXT",
          "x": 540,
          "y": 1230,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.7,
          "enterEnd": 1.1,
          "enterAnimation": "fade",
          "exitEnd": 3.4,
          "style": {
            "fontFamily": "Poppins"
