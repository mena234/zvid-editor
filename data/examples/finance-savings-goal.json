{
  "name": "finance-savings-goal",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#EAF6F0",
  "outputFormat": "mp4",
  "variables": {
    "appName": "NESTEGG",
    "userName": "Jordan",
    "goalName": "Emergency Fund",
    "hookLine": "You're almost there.",
    "saved": "$8,400",
    "target": "$10,000",
    "percentLabel": "84% funded",
    "monthlyLine": "+$650 saved this month",
    "etaLine": "On track to finish by September",
    "showBadge": true,
    "badgeText": "🎉 3 months ahead",
    "closingLine": "Keep going — the finish line is close.",
    "ink": "#0E2A3A",
    "accent": "#12B886",
    "accentDeep": "#0C8F6B",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "cover",
      "duration": 4,
      "backgroundColor": "#EAF6F0",
      "transition": "smoothup",
      "transitionId": "progress",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='sgCov' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#F2FBF7'/><stop offset='1' stop-color='#DDF0E8'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#sgCov)'/><circle cx='870' cy='400' r='260' fill='rgba(18,184,134,0.1)'/><circle cx='200' cy='1560' r='200' fill='rgba(18,184,134,0.08)'/><rect x='60' y='60' width='960' height='1800' rx='40' fill='none' stroke='rgba(14,42,58,0.12)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 170,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='display:inline-block; background:{{ink}}; color:#EAF6F0; border-radius:999px; padding:12px 30px; font-size:23px; font-weight:700; letter-spacing:5px;'>{{appName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 720,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": {
            "fontFamily": "Poppins"
          },
          "html": "<div style='color:{{accentDeep}}; font-size:32px; font-weight:700; letter-spacing:2px;'>Hey {{userName}} 👋</div><div style='margin-top:16px; color:{{ink}}; font-size:104px; line-height:1.02; font-weight:800; letter-spacing:-2px;'>{{hookLine}}</div><div style='margin-top:24px; color:#4E6B78; font-size:36px; font-weight:500;'>Goal · {{goalName}}</div>"
        }
      ]
    },
    {
      "id": "progress",
      "duration": 5.2,
      "backgroundColor": "#EAF6F0",
      "transition": "fade",
      "transitionId": "outro",
      "transitionDuration": 0.5,
