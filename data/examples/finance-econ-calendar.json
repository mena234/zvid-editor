{
  "name": "finance-econ-calendar",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0D0A05",
  "outputFormat": "mp4",
  "variables": {
    "brandTag": "THE MACRO WEEK",
    "weekLabel": "Week of Jul 7",
    "hookLine": "Mark your calendar.",
    "subLine": "The data that moves markets this week.",
    "accent": "#F2C14E",
    "accentHi": "#FF8A5B",
    "events": [
      {
        "day": "MON",
        "date": "Jul 7",
        "event": "Consumer Credit",
        "impact": "LOW",
        "time": "3:00 PM ET"
      },
      {
        "day": "WED",
        "date": "Jul 9",
        "event": "FOMC Minutes",
        "impact": "HIGH",
        "time": "2:00 PM ET"
      },
      {
        "day": "THU",
        "date": "Jul 10",
        "event": "CPI Inflation",
        "impact": "HIGH",
        "time": "8:30 AM ET"
      },
      {
        "day": "FRI",
        "date": "Jul 11",
        "event": "PPI + Jobless Claims",
        "impact": "MED",
        "time": "8:30 AM ET"
      }
    ],
    "closingLine": "Trade the reaction, not the number.",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
