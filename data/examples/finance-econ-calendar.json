        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 300,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 2.9,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='color:#8C7C5C; font-size:24px; font-weight:700; letter-spacing:6px;'>UP NEXT · {{weekLabel}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 600,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "smoothup",
          "exitEnd": 2.9,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:{{accent}}; font-size:56px; font-weight:700; letter-spacing:6px;'>{{e.day}} · {{e.date}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 790,
          "width": 840,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.75,
          "enterAnimation": "smoothup",
          "exitEnd": 2.9,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:88px; line-height:1.06; font-weight:700; letter-spacing:-2px;'>{{e.event}}</div><div style='margin-top:30px; text-align:center; color:#B7A88C; font-size:36px; font-weight:500;'>{{e.time}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1170,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.5,
          "enterEnd": 0.95,
          "enterAnimation": "circleopen",
          "exitEnd": 2.9,
          "style": {
            "fontFamily": "Space Grotesk"
          },
