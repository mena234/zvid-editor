        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 170,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 3.6,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='display:inline-block; border:1.5px solid rgba(242,193,78,0.55); border-radius:999px; padding:14px 34px; color:{{accent}}; font-size:24px; font-weight:700; letter-spacing:6px;'>{{brandTag}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 950,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='text-align:center; color:{{accent}}; font-size:30px; font-weight:700; letter-spacing:4px;'>{{weekLabel}}</div><div style='margin-top:18px; text-align:center; color:#FFFFFF; font-size:96px; line-height:1.02; font-weight:700; letter-spacing:-2px;'>{{hookLine}}</div><div style='margin-top:26px; text-align:center; color:#B7A88C; font-size:34px; line-height:1.4; font-weight:500;'>{{subLine}}</div>"
        }
      ]
    },
    {
      "id": "event",
      "iterate": "events",
      "iterateAs": "e",
      "duration": 2.9,
      "backgroundColor": "#0D0A05",
      "transition": "smoothleft",
      "transitionId": "outro",
      "transitionDuration": 0.45,
