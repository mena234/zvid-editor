        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 950,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": {
            "fontFamily": "Space Grotesk"
          },
