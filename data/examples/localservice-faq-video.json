      {
        "q": "Do you charge for call-outs?",
        "a": "No hidden fees. You get a flat quote before we lift a wrench."
      },
      {
        "q": "How fast can you come out?",
        "a": "Most local jobs are booked same-day, often within 2 hours."
      },
      {
        "q": "Are your plumbers licensed?",
        "a": "Every tech is fully licensed, insured and background-checked."
      }
    ],
    "ctaText": "Ask us anything",
    "ctaPhone": "(555) 771-3300",
    "accentColor": "#F59E0B",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
