        },
        {
          "type": "TEXT",
          "x": 230,
          "y": 470,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "smoothright",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:88px; font-weight:800; letter-spacing:-2px;'>{{fromCode}}</div><div style='text-align:center; color:#7F93B8; font-size:26px; font-weight:600;'>{{fromCity}}</div>"
        },
        {
          "type": "TEXT",
          "x": 850,
          "y": 470,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.75,
          "enterAnimation": "smoothleft",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:88px; font-weight:800; letter-spacing:-2px;'>{{toCode}}</div><div style='text-align:center; color:#7F93B8; font-size:26px; font-weight:600;'>{{toCity}}</div>"
        },
        {
          "type": "TEXT",
