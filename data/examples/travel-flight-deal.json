{
  "name": "travel-flight-deal",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#05070F",
  "outputFormat": "mp4",
  "variables": {
    "brandName": "FARE ALERT",
    "alertLabel": "PRICE DROP DETECTED",
    "fromCode": "LON",
    "fromCity": "London",
    "toCode": "TYO",
    "toCity": "Tokyo",
    "price": "$412",
    "priceWas": "was $980",
    "showBadge": true,
    "badgeText": "−58% · MISTAKE FARE",
    "deadline": "Book before Fri 11:59pm",
    "airlineLine": "Return · direct · Aug–Oct dates",
    "ctaText": "See the fare",
    "ctaHandle": "farealert.io",
    "accentColor": "#4DA3FF",
    "heroImage": "https://images.unsplash.com/photo-1565444007614-6b38c78224df?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3MDgwMTZ8MHwxfHNlYXJjaHw0fHxhaXJwbGFuZSUyMHRyYXZlbCUyMGZsaWdodCUyMHNreXxlbnwwfHx8fDE3ODMyNjg1NzB8MA&ixlib=rb-4.1.0&q=80&w=1080",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "alert",
      "duration": 4,
      "backgroundColor": "#05070F",
      "transition": "smoothup",
      "transitionId": "route",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{heroImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.55,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='tfdAlert' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#05070F' stop-opacity='0.78'/><stop offset='0.5' stop-color='#05070F' stop-opacity='0.42'/><stop offset='1' stop-color='#05070F' stop-opacity='0.94'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#tfdAlert)'/><circle cx='540' cy='760' r='150' fill='none' stroke='rgba(77,163,255,0.7)' stroke-width='2'/><circle cx='540' cy='760' r='172' fill='none' stroke='rgba(77,163,255,0.2)' stroke-width='1'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 150,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "smoothdown",
          "exitEnd": 4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='display:inline-block; background:#4DA3FF; color:#05070F; border-radius:999px; padding:13px 34px; font-size:24px; font-weight:800; letter-spacing:4px;'>{{brandName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 720,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.85,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='text-align:center; color:#4DA3FF; font-size:96px;'>✈</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 980,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.55,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='text-align:center; color:#7FBFFF; font-size:27px; font-weight:800; letter-spacing:5px;'>{{alertLabel}}</div><div style='margin-top:20px; text-align:center; color:#FFFFFF; font-size:70px; line-height:1.05; font-weight:800; letter-spacing:-1px;'>Someone's about to<br>book this cheap.</div>"
        }
      ]
    },
    {
      "id": "route",
      "duration": 5.4,
      "backgroundColor": "#05070F",
      "transition": "fade",
      "transitionId": "cta",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 5.4,
