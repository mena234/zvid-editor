          "x": 540,
          "y": 700,
          "anchor": "center-center",
          "track": 11,
          "enterBegin": 0.5,
          "enterEnd": 0.9,
          "enterAnimation": "circleopen",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='display:inline-block; background:#4DA3FF; color:#05070F; border-radius:999px; padding:14px 36px; font-size:28px; font-weight:800; letter-spacing:1px;'>{{badgeText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.7,
          "enterEnd": 1.2,
          "enterAnimation": "smoothup",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='text-align:center; color:#4DA3FF; font-size:172px; line-height:1; font-weight:800; letter-spacing:-6px;'>{{price}}</div><div style='margin-top:6px; text-align:center; color:#7F93B8; font-size:34px; font-weight:600; text-decoration:line-through;'>{{priceWas}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1340,
          "width": 820,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.95,
          "enterEnd": 1.4,
          "enterAnimation": "fade",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='text-align:center; color:#C6D4EC; font-size:32px; font-weight:500;'>{{airlineLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1470,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.2,
          "enterEnd": 1.6,
          "enterAnimation": "smoothup",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Outfit" },
          "html": "<div style='display:inline-block; background:rgba(77,163,255,0.14); border:1.5px solid rgba(77,163,255,0.5); color:#7FBFFF; border-radius:999px; padding:15px 36px; font-size:29px; font-weight:700;'>⏳ {{deadline}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 3.6,
      "backgroundColor": "#05070F",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='tfdCta' cx='0.5' cy='0.42' r='0.9'><stop offset='0' stop-color='#0C1428'/><stop offset='1' stop-color='#05070F'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#tfdCta)'/><path d='M340 720 L720 720 M650 655 L720 720 L650 785' fill='none' stroke='#4DA3FF' stroke-width='12' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 900,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.75,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:78px; line-height:1.05; font-weight:800; letter-spacing:-1px;'>Fares like this<br>vanish fast.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1200,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.1,
          "enterAnimation": "circleopen",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#05070F; border-radius:999px; padding:27px 66px; font-size:40px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1370,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.05,
          "enterEnd": 1.45,
          "enterAnimation": "fade",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Outfit" },
