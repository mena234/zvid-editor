{
  "name": "local-new-dish-launch",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#F6EFE4",
  "outputFormat": "mp4",
  "variables": {
    "brandName": "MAISON VERT",
    "badgeText": "JUST LANDED",
    "showBadge": true,
    "teaserLine": "Something new is on the pass.",
    "dishName": "Charred Fig & Burrata",
    "dishTagline": "Sweet roasted figs, torn burrata, aged balsamic and toasted hazelnut.",
    "pairingLabel": "PAIRS WITH",
    "pairing": "A chilled glass of Provençal rosé",
    "availLabel": "ON THE MENU FROM",
    "availDate": "This Friday",
    "ctaText": "Reserve a table",
    "ctaUrl": "maisonvert.co / book",
    "accentColor": "#C65A34",
    "heroImage": "https://images.unsplash.com/photo-1564759296729-771e78c26df7?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3MDgwMTZ8MHwxfHNlYXJjaHwyfHxnb3VybWV0JTIwZm9vZCUyMHBsYXRlZCUyMHJlc3RhdXJhbnR8ZW58MHx8fHwxNzgzMjY4NTczfDA&ixlib=rb-4.1.0&q=80&w=1080",
    "dishImage": "https://images.unsplash.com/photo-1627858034922-72a657d6b3c2?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3MDgwMTZ8MHwxfHNlYXJjaHw3fHxnb3VybWV0JTIwZm9vZCUyMHBsYXRlZCUyMHJlc3RhdXJhbnR8ZW58MHx8fHwxNzgzMjY4NTczfDA&ixlib=rb-4.1.0&q=80&w=1080",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "teaser",
      "duration": 4,
      "backgroundColor": "#F6EFE4",
      "transition": "fade",
      "transitionId": "reveal",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{heroImage}}",
          "x": 540,
          "y": 760,
          "width": 1080,
          "height": 1200,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='ndlShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#F6EFE4' stop-opacity='0.3'/><stop offset='0.5' stop-color='#241C14' stop-opacity='0.1'/><stop offset='0.78' stop-color='#F6EFE4' stop-opacity='0.6'/><stop offset='1' stop-color='#F6EFE4' stop-opacity='1'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#ndlShade)'/></svg>"
        },
        {
          "type": "TEXT",
          "condition": "{{showBadge}}",
          "x": 540,
          "y": 150,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.75,
          "enterAnimation": "smoothdown",
          "exitEnd": 4,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#F6EFE4; border-radius:999px; padding:14px 38px; font-size:26px; font-weight:700; letter-spacing:6px;'>{{badgeText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1300,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.6,
          "enterEnd": 1.1,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Fraunces" },
          "html": "<div style='text-align:center; color:#8A7B66; font-size:28px; letter-spacing:8px; font-weight:600; font-family:DM Sans, sans-serif;'>{{brandName}}</div><div style='margin-top:22px; text-align:center; color:#241C14; font-size:78px; line-height:1.08; font-weight:600; font-style:italic;'>{{teaserLine}}</div>"
        }
      ]
    },
    {
      "id": "reveal",
      "duration": 5.4,
      "backgroundColor": "#F6EFE4",
      "transition": "smoothleft",
      "transitionId": "cta",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 5.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><rect width='1080' height='1920' fill='#F6EFE4'/><circle cx='860' cy='250' r='220' fill='rgba(198,90,52,0.08)'/><circle cx='170' cy='1660' r='180' fill='rgba(198,90,52,0.07)'/></svg>"
        },
        {
          "type": "IMAGE",
          "src": "{{dishImage}}",
          "x": 540,
          "y": 660,
          "width": 720,
          "height": 900,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "radius": { "tl": 360, "tr": 360, "bl": 360, "br": 360 },
          "track": 1,
          "enterBegin": 0,
          "enterEnd": 0.6,
          "enterAnimation": "circleopen",
          "exitEnd": 5.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 5.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><circle cx='540' cy='660' r='372' fill='none' stroke='rgba(198,90,52,0.55)' stroke-width='3'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1210,
          "width": 920,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Fraunces" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:26px; letter-spacing:5px; font-weight:700; font-family:DM Sans, sans-serif;'>NOW SERVING</div><div style='margin-top:14px; text-align:center; color:#241C14; font-size:82px; line-height:1.02; font-weight:600;'>{{dishName}}</div><div style='margin-top:22px; text-align:center; color:#5C5142; font-size:32px; line-height:1.45; font-weight:500; font-family:DM Sans, sans-serif;'>{{dishTagline}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1620,
          "width": 900,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.85,
          "enterEnd": 1.3,
          "enterAnimation": "fade",
          "exitEnd": 5.4,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='display:inline-flex; gap:20px;'><span style='background:rgba(36,28,20,0.06); border:1.5px solid rgba(198,90,52,0.4); color:#241C14; border-radius:16px; padding:14px 28px; font-size:26px; font-weight:600;'><b style='color:#C65A34;'>{{pairingLabel}}:</b> {{pairing}}</span></div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 4.4,
      "backgroundColor": "#241C14",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='ndlCta' cx='0.5' cy='0.4' r='0.9'><stop offset='0' stop-color='#3A2C1E'/><stop offset='1' stop-color='#241C14'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#ndlCta)'/><rect x='48' y='48' width='984' height='1824' rx='36' fill='none' stroke='rgba(198,90,52,0.4)' stroke-width='2'/><path d='M420 560 H660' stroke='#C65A34' stroke-width='4'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 660,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='text-align:center; color:#B6A488; font-size:26px; letter-spacing:5px; font-weight:700;'>{{availLabel}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 720,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.55,
          "enterEnd": 1.05,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Fraunces" },
          "html": "<div style='text-align:center; color:#F6EFE4; font-size:96px; line-height:1.02; font-weight:600; font-style:italic;'>{{availDate}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1080,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.95,
          "enterEnd": 1.4,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#F6EFE4; border-radius:999px; padding:28px 70px; font-size:40px; font-weight:700;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1250,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.3,
          "enterEnd": 1.7,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "DM Sans" },
          "html": "<div style='text-align:center; color:#8A7B66; font-size:28px; font-weight:600; letter-spacing:2px;'>{{ctaUrl}}</div>"
        }
      ]
    }
  ],
  "audios": [
    { "src": "{{musicUrl}}", "volume": 0.15 }
  ]
}
