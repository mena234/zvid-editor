{
  "name": "sports-transfer-news",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0C0407",
  "outputFormat": "mp4",
  "variables": {
    "breakingLabel": "TRANSFER ALERT",
    "playerName": "FLORIAN WIRTZ",
    "position": "Attacking Midfielder · 22",
    "fromClub": "Bayer Leverkusen",
    "toClub": "REAL MADRID",
    "accentColor": "#FF2E4D",
    "fee": "€130M",
    "showFee": true,
    "contractLine": "Signs a 6-year deal until 2032",
    "showBadge": true,
    "badgeText": "HERE WE GO",
    "quoteLine": "\"A dream move — I'm ready to fight for every trophy.\"",
    "sourceLine": "Source: club official statement",
    "bgVideo": "https://videos.pexels.com/video-files/34576602/14651995_1080_1920_30fps.mp4",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "breaking",
      "duration": 3.6,
      "backgroundColor": "#0C0407",
      "transition": "fadeblack",
      "transitionId": "deal",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{bgVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='tnHook' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0C0407' stop-opacity='0.8'/><stop offset='0.5' stop-color='#0C0407' stop-opacity='0.4'/><stop offset='1' stop-color='#0C0407' stop-opacity='0.96'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#tnHook)'/><rect x='0' y='900' width='1080' height='120' fill='#FF2E4D'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 960,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.6,
          "enterAnimation": "smoothleft",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#FFFFFF; font-size:66px; font-weight:900; letter-spacing:10px;'>{{breakingLabel}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1080,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 0.95,
          "enterAnimation": "fade",
          "exitEnd": 3.6,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#D7C2C7; font-size:30px; font-weight:600; letter-spacing:4px;'>{{sourceLine}}</div>"
        }
      ]
    },
    {
      "id": "deal",
      "duration": 5.4,
      "backgroundColor": "#0C0407",
      "transition": "smoothup",
      "transitionId": "quote",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 5.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='tnDeal' cx='0.5' cy='0.35' r='0.95'><stop offset='0' stop-color='#2A0710'/><stop offset='1' stop-color='#0C0407'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#tnDeal)'/><rect x='70' y='760' width='940' height='620' rx='40' fill='rgba(255,255,255,0.03)' stroke='rgba(255,46,77,0.45)' stroke-width='1.5'/><path d='M540 900 l60 60 l-60 60 l-60 -60 Z' fill='#FF2E4D'/><path d='M180 1030 H900' stroke='rgba(255,255,255,0.12)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "condition": "{{showBadge}}",
          "x": 540,
          "y": 220,
          "anchor": "top-center",
          "track": 12,
          "enterBegin": 0.15,
          "enterEnd": 0.6,
          "enterAnimation": "circleopen",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Archivo" },
