          "type": "TEXT",
          "x": 540,
          "y": 400,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:96px; line-height:0.95; font-weight:900; letter-spacing:-3px;'>{{playerName}}</div><div style='margin-top:18px; text-align:center; color:#E79AA6; font-size:32px; font-weight:600; letter-spacing:2px;'>{{position}}</div>"
        },
        {
          "type": "TEXT",
          "x": 300,
          "y": 830,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.6,
          "enterEnd": 1.05,
          "enterAnimation": "smoothright",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#8E7A7E; font-size:26px; font-weight:700; letter-spacing:4px;'>FROM</div><div style='margin-top:10px; text-align:center; color:#FFFFFF; font-size:48px; font-weight:600;'>{{fromClub}}</div>"
        },
        {
          "type": "TEXT",
          "x": 780,
          "y": 830,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.75,
          "enterEnd": 1.2,
          "enterAnimation": "smoothleft",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:26px; font-weight:700; letter-spacing:4px;'>TO</div><div style='margin-top:10px; text-align:center; color:#FFFFFF; font-size:48px; font-weight:800;'>{{toClub}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showFee}}",
          "x": 540,
          "y": 1080,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.95,
          "enterEnd": 1.4,
          "enterAnimation": "smoothup",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#8E7A7E; font-size:26px; font-weight:800; letter-spacing:6px;'>FEE</div><div style='margin-top:6px; text-align:center; color:{{accentColor}}; font-size:150px; line-height:0.9; font-weight:900; letter-spacing:-3px;'>{{fee}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1440,
          "width": 880,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 1.2,
          "enterEnd": 1.65,
          "enterAnimation": "fade",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#D7C2C7; font-size:36px; font-weight:600;'>{{contractLine}}</div>"
        }
      ]
    },
    {
      "id": "quote",
      "duration": 4,
      "backgroundColor": "#0C0407",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='tnQuote' cx='0.5' cy='0.4' r='0.9'><stop offset='0' stop-color='#2A0710'/><stop offset='1' stop-color='#0C0407'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#tnQuote)'/><path d='M300 640 q0 -70 70 -70 v40 q-30 0 -30 30 h30 v70 h-70 Z' fill='#FF2E4D'/><path d='M470 640 q0 -70 70 -70 v40 q-30 0 -30 30 h30 v70 h-70 Z' fill='#FF2E4D'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 820,
          "width": 880,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:52px; line-height:1.3; font-weight:600; font-style:italic;'>{{quoteLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1200,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.1,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:{{accentColor}}; font-size:34px; font-weight:900; letter-spacing:4px;'>{{playerName}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.16
    }
  ]
}
