        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1360,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.05,
          "enterEnd": 1.5,
          "enterAnimation": "circleopen",
          "exitEnd": 4.8,
          "style": {
            "fontFamily": "Manrope"
