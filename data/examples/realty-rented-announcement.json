        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 800,
          "width": 920,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 4.8,
          "style": {
            "fontFamily": "Fraunces"
          },
          "html": "<div style='text-align:center; color:#FBF8F0; font-size:82px; line-height:1.05; font-weight:600; letter-spacing:-1px;'>{{closingHead}}</div>"
