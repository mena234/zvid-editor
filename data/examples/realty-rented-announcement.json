        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1300,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 4.6,
          "style": {
            "fontFamily": "Manrope"
          },
          "html": "<div style='color:#FBF8F0; font-size:60px; font-weight:800; letter-spacing:-1px;'>{{rentLine}}</div><div style='margin-top:14px; color:#CFC8B6; font-size:34px; font-weight:500;'>{{specLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1560,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.85,
          "enterEnd": 1.3,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.6,
          "style": {
            "fontFamily": "Manrope"
          },
          "html": "<div style='display:inline-block; background:{{accent}}; color:#14231D; border-radius:999px; padding:20px 44px; font-size:32px; font-weight:800;'>{{tenantLine}}</div>"
        }
      ]
    },
    {
      "id": "close",
      "duration": 4.8,
      "backgroundColor": "#14231D",
