        },
        {
          "type": "IMAGE",
          "src": "{{roomImage}}",
          "x": 540,
          "y": 660,
          "width": 900,
          "height": 900,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "radius": {
            "tl": 40,
            "tr": 40,
            "bl": 40,
            "br": 40
          },
          "track": 1,
          "enterBegin": 0,
          "enterEnd": 0.55,
          "enterAnimation": "smoothdown",
          "exitEnd": 4.6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.6,
