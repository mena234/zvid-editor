{
  "name": "agency-competitor-alt-ad",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#04110F",
  "outputFormat": "mp4",
  "variables": {
    "kicker": "LOOKING FOR AN ALTERNATIVE?",
    "competitorName": "BloatSuite",
    "hookLine": "The smarter<br>alternative to<br>{{competitorName}}.",
    "hookSub": "Same power. Half the price. None of the 6-month contracts.",
    "compareLabel": "WHY TEAMS SWITCH",
    "themName": "BloatSuite",
    "usName": "Nimbus",
    "rows": [
      { "point": "Pricing", "them": "$499/mo, annual lock-in", "us": "$149/mo, cancel anytime" },
      { "point": "Onboarding", "them": "3-week setup call queue", "us": "Live in under 10 minutes" },
      { "point": "Support", "them": "Ticket in 48h", "us": "Real human in 5 min" }
    ],
    "migrationBadge": "Free migration + 30-day money back",
    "showBadge": true,
    "ctaText": "Make the switch",
    "ctaUrl": "nimbus.example/switch",
    "accentColor": "#2FE6C4",
    "bgImage": "https://images.pexels.com/photos/9665181/pexels-photo-9665181.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "hook",
      "duration": 4.2,
      "backgroundColor": "#04110F",
      "transition": "smoothleft",
      "transitionId": "compare",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{bgImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.5,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.2
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='caShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#04110F' stop-opacity='0.78'/><stop offset='0.45' stop-color='#04110F' stop-opacity='0.4'/><stop offset='1' stop-color='#04110F' stop-opacity='0.96'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#caShade)'/><rect x='96' y='1180' width='8' height='440' rx='4' fill='#2FE6C4'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 108,
          "y": 200,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:rgba(47,230,196,0.14); border:1.5px solid rgba(47,230,196,0.5); color:{{accentColor}}; border-radius:8px; padding:12px 26px; font-size:24px; font-weight:800; letter-spacing:4px;'>{{kicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 122,
          "y": 1200,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1.05,
          "enterAnimation": "smoothup",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:#EAFDF8; font-size:94px; line-height:0.98; font-weight:800; letter-spacing:-2px;'>{{hookLine}}</div><div style='margin-top:30px; color:#9CC4BB; font-size:33px; line-height:1.42; font-weight:500;'>{{hookSub}}</div>"
        }
      ]
    },
    {
      "id": "compare",
      "duration": 5.2,
      "backgroundColor": "#04110F",
      "transition": "smoothup",
      "transitionId": "cta",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 5.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='caCmp' cx='0.5' cy='0.3' r='0.95'><stop offset='0' stop-color='#0A2019'/><stop offset='1' stop-color='#04110F'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#caCmp)'/><rect x='80' y='470' width='440' height='1180' rx='36' fill='rgba(255,255,255,0.03)' stroke='rgba(255,120,120,0.3)' stroke-width='1.5'/><rect x='560' y='430' width='440' height='1220' rx='36' fill='rgba(47,230,196,0.06)' stroke='rgba(47,230,196,0.5)' stroke-width='2'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 200,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "smoothup",
          "exitEnd": 5.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:26px; font-weight:800; letter-spacing:6px;'>{{compareLabel}}</div>"
        },
        {
          "type": "TEXT",
          "x": 300,
          "y": 510,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.8,
          "enterAnimation": "fade",
          "exitEnd": 5.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#F0A0A0; font-size:34px; font-weight:800;'>{{themName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 780,
          "y": 470,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.8,
          "enterAnimation": "fade",
          "exitEnd": 5.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#04110F; border-radius:10px; padding:8px 24px; text-align:center; font-size:34px; font-weight:800;'>{{usName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 640,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.55,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 5.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:flex; flex-direction:column; gap:26px;'><div style='display:flex;'><div style='width:440px; text-align:center; color:#B98F8F; font-size:26px; font-weight:500;'>{{rows.0.them}}</div><div style='width:60px;'></div><div style='width:440px; text-align:center; color:#EAFDF8; font-size:26px; font-weight:700;'>{{rows.0.us}}</div></div><div style='display:flex;'><div style='width:440px; text-align:center; color:#B98F8F; font-size:26px; font-weight:500;'>{{rows.1.them}}</div><div style='width:60px;'></div><div style='width:440px; text-align:center; color:#EAFDF8; font-size:26px; font-weight:700;'>{{rows.1.us}}</div></div><div style='display:flex;'><div style='width:440px; text-align:center; color:#B98F8F; font-size:26px; font-weight:500;'>{{rows.2.them}}</div><div style='width:60px;'></div><div style='width:440px; text-align:center; color:#EAFDF8; font-size:26px; font-weight:700;'>{{rows.2.us}}</div></div></div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 620,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.55,
          "enterEnd": 1,
          "enterAnimation": "fade",
          "exitEnd": 5.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:flex; gap:60px;'><div style='width:440px; text-align:center; color:#7C6060; font-size:22px; font-weight:800; letter-spacing:3px;'>{{rows.0.point}}</div></div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 4.4,
      "backgroundColor": "#04110F",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='caCta' cx='0.5' cy='0.4' r='0.95'><stop offset='0' stop-color='#0B2620'/><stop offset='1' stop-color='#04110F'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#caCta)'/><rect x='50' y='50' width='980' height='1820' rx='38' fill='none' stroke='rgba(47,230,196,0.32)' stroke-width='1.5'/><path d='M470 640 L600 640 M540 580 L620 640 L540 700' fill='none' stroke='#2FE6C4' stroke-width='9' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 860,
          "width": 920,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#EAFDF8; font-size:76px; line-height:1.06; font-weight:800; letter-spacing:-1px;'>Switch in a<br>coffee break.</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showBadge}}",
          "x": 540,
          "y": 1130,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.1,
          "enterAnimation": "circleopen",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:rgba(47,230,196,0.12); border:1.5px solid rgba(47,230,196,0.5); color:{{accentColor}}; border-radius:999px; padding:14px 34px; font-size:27px; font-weight:700;'>{{migrationBadge}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1270,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.95,
          "enterEnd": 1.4,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#04110F; border-radius:999px; padding:26px 66px; font-size:40px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1440,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.3,
          "enterEnd": 1.7,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#6E938B; font-size:27px; font-weight:600; letter-spacing:2px;'>{{ctaUrl}}</div>"
        }
      ]
    }
  ],
  "audios": [
    { "src": "{{musicUrl}}", "volume": 0.16 }
  ]
}
