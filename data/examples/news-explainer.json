        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1780,
          "anchor": "center-center",
          "track": 11,
          "enterBegin": 1,
          "enterEnd": 1.4,
          "enterAnimation": "smoothup",
          "exitEnd": 5,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#071414; border-radius:999px; padding:18px 46px; font-size:30px; font-weight:800;'>{{handle}}</div>"
        }
      ]
