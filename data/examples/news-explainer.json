          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 4.6,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='color:#FFFFFF; font-size:52px; line-height:1.32; font-weight:600;'>{{whatHappened}}</div>"
