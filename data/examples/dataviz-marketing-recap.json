    "metrics": [
      {
        "label": "CLICK-THROUGH RATE",
        "value": "3.9%",
        "delta": "▲ 0.8 pts",
        "note": "Creative refresh lifted engagement",
        "fill": "78"
      },
      {
        "label": "COST PER ACQUISITION",
        "value": "$21.40",
        "delta": "▼ 16% cheaper",
        "note": "Lowest CPA in four quarters",
        "fill": "42"
      },
      {
        "label": "RETURN ON AD SPEND",
        "value": "5.2×",
        "delta": "▲ from 4.1×",
        "note": "Every $1 returned $5.20",
