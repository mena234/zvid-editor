{
  "name": "ai-result-hero",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#06070A",
  "outputFormat": "mp4",
  "variables": {
    "brandName": "RENDER AI",
    "kicker": "GENERATED FOR YOU",
    "heroLine1": "This video",
    "heroLine2": "made itself.",
    "heroSub": "You wrote one line. RENDER did the rest — script, visuals, motion.",
    "statsTitle1": "The numbers",
    "statsTitle2": "behind it.",
    "closeTitle1": "Now make one",
    "closeTitle2": "with your idea.",
    "stat1Value": "0",
    "stat1Label": "EDITS BY YOU",
    "stat2Value": "38s",
    "stat2Label": "TIME TO RENDER",
    "showPrice": true,
    "priceText": "FROM $0.10 / VIDEO",
    "ctaText": "Generate yours",
    "ctaHandle": "render.ai/new",
    "accentColor": "#B6FF3C",
    "heroVideo": "https://videos.pexels.com/video-files/7639588/7639588-hd_1080_1920_30fps.mp4",
    "closeVideo": "https://videos.pexels.com/video-files/29798500/12802156_1080_1920_30fps.mp4",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "hero",
      "duration": 4.6,
      "backgroundColor": "#06070A",
      "transition": "fade",
      "transitionId": "stats",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{heroVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='rhShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#06070A' stop-opacity='0.62'/><stop offset='0.45' stop-color='#06070A' stop-opacity='0.15'/><stop offset='1' stop-color='#06070A' stop-opacity='0.95'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#rhShade)'/><rect x='72' y='1240' width='6' height='420' rx='3' fill='#B6FF3C'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 150,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 4.6,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:rgba(182,255,60,0.16); border:1.5px solid rgba(182,255,60,0.55); color:#B6FF3C; border-radius:999px; padding:14px 32px; font-size:23px; font-weight:800; letter-spacing:5px;'>{{kicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 118,
          "y": 1260,
          "width": 900,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.5,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 4.6,
          "style": { "fontFamily": "Syne" },
          "html": "<div style='color:#FFFFFF; font-size:108px; line-height:0.98; font-weight:800; letter-spacing:-4px;'>{{heroLine1}}<br>{{heroLine2}}</div><div style='margin-top:24px; color:#C7D8AE; font-size:31px; line-height:1.4; font-weight:500; font-family:Space Grotesk, sans-serif;'>{{heroSub}}</div>"
        }
      ]
    },
    {
      "id": "stats",
      "duration": 4,
      "backgroundColor": "#06070A",
      "transition": "smoothup",
      "transitionId": "cta",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='rhStats' cx='0.5' cy='0.36' r='0.95'><stop offset='0' stop-color='#0E140A'/><stop offset='1' stop-color='#06070A'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#rhStats)'/><rect x='90' y='700' width='420' height='520' rx='36' fill='rgba(182,255,60,0.05)' stroke='rgba(182,255,60,0.4)' stroke-width='1.5'/><rect x='570' y='700' width='420' height='520' rx='36' fill='rgba(182,255,60,0.05)' stroke='rgba(182,255,60,0.4)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 360,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Syne" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:64px; line-height:1.06; font-weight:800; letter-spacing:-1px;'>{{statsTitle1}}<br>{{statsTitle2}}</div>"
        },
        {
          "type": "TEXT",
          "x": 300,
          "y": 820,
          "anchor": "center-center",
          "track": 11,
          "enterBegin": 0.45,
          "enterEnd": 0.9,
          "enterAnimation": "circleopen",
          "exitEnd": 4,
          "style": { "fontFamily": "Syne" },
          "html": "<div style='text-align:center; color:#B6FF3C; font-size:130px; line-height:1; font-weight:800; letter-spacing:-4px;'>{{stat1Value}}</div><div style='margin-top:10px; text-align:center; color:#9DB086; font-size:24px; font-weight:700; letter-spacing:3px; font-family:Space Grotesk, sans-serif;'>{{stat1Label}}</div>"
        },
        {
          "type": "TEXT",
          "x": 780,
          "y": 820,
          "anchor": "center-center",
          "track": 11,
          "enterBegin": 0.65,
          "enterEnd": 1.1,
          "enterAnimation": "circleopen",
          "exitEnd": 4,
          "style": { "fontFamily": "Syne" },
          "html": "<div style='text-align:center; color:#B6FF3C; font-size:130px; line-height:1; font-weight:800; letter-spacing:-4px;'>{{stat2Value}}</div><div style='margin-top:10px; text-align:center; color:#9DB086; font-size:24px; font-weight:700; letter-spacing:3px; font-family:Space Grotesk, sans-serif;'>{{stat2Label}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showPrice}}",
          "x": 540,
          "y": 1320,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1,
          "enterEnd": 1.45,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#06070A; border-radius:999px; padding:18px 44px; font-size:32px; font-weight:800; letter-spacing:1px;'>{{priceText}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 4.4,
      "backgroundColor": "#06070A",
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{closeVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "opacity": 0.5,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='rhEnd' cx='0.5' cy='0.4' r='0.9'><stop offset='0' stop-color='#06070A' stop-opacity='0.55'/><stop offset='1' stop-color='#06070A' stop-opacity='0.94'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#rhEnd)'/><circle cx='540' cy='620' r='140' fill='none' stroke='rgba(182,255,60,0.8)' stroke-width='2.5'/><path d='M505 620 H575 M545 585 L580 620 L545 655' fill='none' stroke='#B6FF3C' stroke-width='9' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 850,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#B6FF3C; font-size:24px; font-weight:800; letter-spacing:6px;'>{{brandName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 920,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.45,
          "enterEnd": 0.95,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Syne" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:80px; line-height:1.02; font-weight:800; letter-spacing:-2px;'>{{closeTitle1}}<br>{{closeTitle2}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1240,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.85,
          "enterEnd": 1.3,
          "enterAnimation": "circleopen",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#06070A; border-radius:999px; padding:26px 64px; font-size:38px; font-weight:800;'>{{ctaText}} · {{ctaHandle}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.16
    }
  ]
}
