{
  "name": "apppersonal-year-in-review",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#120414",
  "outputFormat": "mp4",
  "variables": {
    "appName": "SOUNDLOOP",
    "userName": "Jordan",
    "year": "2026",
    "introKicker": "Your year in sound",
    "outroLine": "Thanks for a loud year.",
    "ctaText": "Get your full Rewind",
    "handle": "@soundloop",
    "accent": "#FF3D9A",
    "accent2": "#FFB020",
    "bgVideo": "https://cdn.pixabay.com/video/2025/07/20/292476_medium.mp4",
    "stats": [
      {
        "big": "62,400",
        "unit": "minutes streamed",
        "sub": "You out-listened 94% of the world"
      },
      {
        "big": "1,038",
        "unit": "different tracks",
        "sub": "From lo-fi mornings to Friday chaos"
      },
      {
        "big": "#1 fan",
        "unit": "of Midnight Static",
        "sub": "You played them 214 times"
      },
      {
        "big": "7 genres",
        "unit": "in heavy rotation",
        "sub": "Hyperpop was your surprise obsession"
      }
    ],
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "intro",
      "duration": 3.8,
      "backgroundColor": "#120414",
      "transition": "slideup",
      "transitionId": "stat",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{bgVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "opacity": 0.5,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.8
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='yrIntro' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#120414' stop-opacity='0.7'/><stop offset='0.5' stop-color='#120414' stop-opacity='0.35'/><stop offset='1' stop-color='#120414' stop-opacity='0.95'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#yrIntro)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 720,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "fade",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:{{accent2}}; font-size:30px; font-weight:800; letter-spacing:7px;'>{{introKicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 800,
          "width": 960,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.45,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Syne" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:260px; line-height:0.9; font-weight:800; letter-spacing:-6px;'>{{year}}</div><div style='margin-top:10px; text-align:center; color:{{accent}}; font-size:56px; font-weight:800; letter-spacing:-1px;'>{{userName}}'s Rewind</div>"
        }
      ]
    },
    {
      "id": "stat",
      "iterate": "stats",
      "iterateAs": "s",
      "duration": 3,
      "backgroundColor": "#120414",
      "transition": "slideup",
      "transitionId": "outro",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='yrStat' x1='0' y1='0' x2='1' y2='1'><stop offset='0' stop-color='#2A0620'/><stop offset='0.55' stop-color='#1A0518'/><stop offset='1' stop-color='#120414'/></linearGradient><linearGradient id='yrBar' x1='0' y1='0' x2='1' y2='0'><stop offset='0' stop-color='#FF3D9A'/><stop offset='1' stop-color='#FFB020'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#yrStat)'/><rect x='0' y='0' width='1080' height='18' fill='url(#yrBar)'/><rect x='0' y='1902' width='1080' height='18' fill='url(#yrBar)'/><rect x='120' y='560' width='260' height='16' rx='8' fill='url(#yrBar)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 120,
          "y": 640,
          "width": 860,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.6,
          "enterAnimation": "smoothleft",
          "exitEnd": 3,
          "style": { "fontFamily": "Syne" },
          "html": "<div style='color:#FFFFFF; font-size:180px; line-height:0.92; font-weight:800; letter-spacing:-6px;'>{{s.big}}</div>"
        },
        {
          "type": "TEXT",
          "x": 120,
          "y": 940,
          "width": 840,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 3,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:#FFB020; font-size:46px; font-weight:800; letter-spacing:-1px;'>{{s.unit}}</div><div style='margin-top:22px; color:#D9AEC8; font-size:34px; line-height:1.4; font-weight:500;'>{{s.sub}}</div>"
        },
        {
          "type": "TEXT",
          "x": 120,
          "y": 1780,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0,
          "exitEnd": 3,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='color:rgba(255,255,255,0.55); font-size:24px; font-weight:800; letter-spacing:5px;'>{{appName}} {{year}}</div>"
        }
      ]
    },
    {
      "id": "outro",
      "duration": 4.4,
      "backgroundColor": "#120414",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='yrOut' cx='0.5' cy='0.4' r='0.95'><stop offset='0' stop-color='#39082A'/><stop offset='0.55' stop-color='#1D0619'/><stop offset='1' stop-color='#120414'/></radialGradient><linearGradient id='yrRing' x1='0' y1='0' x2='1' y2='1'><stop offset='0' stop-color='#FF3D9A'/><stop offset='1' stop-color='#FFB020'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#yrOut)'/><circle cx='540' cy='640' r='176' fill='none' stroke='url(#yrRing)' stroke-width='5'/><circle cx='540' cy='640' r='210' fill='none' stroke='rgba(255,61,154,0.25)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 596,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "circleopen",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Syne" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:96px; font-weight:800;'>{{year}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 940,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Syne" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:76px; line-height:1.05; font-weight:800; letter-spacing:-2px;'>{{outroLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1210,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.8,
          "enterEnd": 1.25,
          "enterAnimation": "circleopen",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:#FF3D9A; color:#FFFFFF; border-radius:999px; padding:28px 64px; font-size:38px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1360,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.1,
          "enterEnd": 1.5,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#B88AA6; font-size:28px; font-weight:700; letter-spacing:3px;'>{{handle}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.2
    }
  ]
}
