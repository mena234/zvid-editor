    "bonusValue": "+$1,500",
    "bonusLabel": "Loyalty bonus on top of appraisal",
    "showBonus": true,
    "stepOne": "Bring it in or send photos",
    "stepTwo": "We appraise on the spot",
    "stepThree": "Apply it to any car — or cash out",
