{
  "name": "localservice-seasonal-reminder",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#EAF6FF",
  "outputFormat": "mp4",
  "variables": {
    "clinicName": "NORTHSIDE DENTAL",
    "seasonKicker": "BACK-TO-SCHOOL SEASON",
    "hookLine": "Time for the<br>whole family's<br>check-up.",
    "hookSub": "Beat the September rush — book now.",
    "reasonTitle": "Why now?",
    "reason1": "Calendars fill fast once school starts",
    "reason2": "Catch small issues before they hurt",
    "reason3": "Fresh, confident smiles for photo day",
    "showDiscount": true,
    "discountText": "Family bookings get 15% off",
    "ctaText": "Reserve your slot",
    "ctaSite": "northsidedental.co",
    "accentColor": "#22C55E",
    "skyColor": "#38BDF8",
    "seasonImage": "https://images.pexels.com/photos/19476290/pexels-photo-19476290.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "hook",
      "duration": 4,
      "backgroundColor": "#EAF6FF",
      "transition": "smoothleft",
      "transitionId": "reasons",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{seasonImage}}",
          "x": 540,
          "y": 620,
          "width": 1080,
          "height": 1000,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='srHook' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0C3B5E' stop-opacity='0.35'/><stop offset='0.5' stop-color='#0C3B5E' stop-opacity='0'/><stop offset='0.58' stop-color='#EAF6FF' stop-opacity='0'/><stop offset='0.7' stop-color='#EAF6FF' stop-opacity='1'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#srHook)'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 150,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "smoothdown",
          "exitEnd": 4,
          "style": { "fontFamily": "Manrope" },
          "html": "<div style='display:inline-block; background:{{skyColor}}; color:#052B44; border-radius:999px; padding:14px 34px; font-size:24px; font-weight:800; letter-spacing:4px;'>{{seasonKicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1120,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Manrope" },
          "html": "<div style='text-align:center; color:#052B44; font-size:88px; line-height:1.02; font-weight:800; letter-spacing:-2px;'>{{hookLine}}</div><div style='margin-top:22px; text-align:center; color:#2E6E8E; font-size:34px; font-weight:600;'>{{hookSub}}</div>"
        }
      ]
    },
    {
      "id": "reasons",
      "duration": 4.8,
      "backgroundColor": "#EAF6FF",
      "transition": "smoothleft",
      "transitionId": "cta",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='srReasons' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#F1FAFF'/><stop offset='1' stop-color='#DCEFFB'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#srReasons)'/><circle cx='880' cy='260' r='210' fill='rgba(56,189,248,0.14)'/><circle cx='170' cy='1660' r='230' fill='rgba(34,197,94,0.12)'/><rect x='100' y='620' width='880' height='170' rx='28' fill='#FFFFFF' stroke='rgba(34,197,94,0.35)' stroke-width='1.5'/><rect x='100' y='820' width='880' height='170' rx='28' fill='#FFFFFF' stroke='rgba(34,197,94,0.35)' stroke-width='1.5'/><rect x='100' y='1020' width='880' height='170' rx='28' fill='#FFFFFF' stroke='rgba(34,197,94,0.35)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 380,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "smoothup",
          "exitEnd": 4.8,
          "style": { "fontFamily": "Manrope" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:28px; font-weight:800; letter-spacing:5px;'>{{reasonTitle}}</div>"
        },
        {
          "type": "TEXT",
          "x": 150,
          "y": 660,
          "width": 800,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.4,
          "enterEnd": 0.85,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.8,
          "style": { "fontFamily": "Manrope" },
          "html": "<div style='color:#0B3B57; font-size:38px; font-weight:700; line-height:1.3;'><span style='color:{{accentColor}}; font-weight:800;'>✓</span> {{reason1}}</div>"
        },
        {
          "type": "TEXT",
          "x": 150,
          "y": 860,
          "width": 800,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.6,
          "enterEnd": 1.05,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.8,
          "style": { "fontFamily": "Manrope" },
          "html": "<div style='color:#0B3B57; font-size:38px; font-weight:700; line-height:1.3;'><span style='color:{{accentColor}}; font-weight:800;'>✓</span> {{reason2}}</div>"
        },
        {
          "type": "TEXT",
          "x": 150,
          "y": 1060,
          "width": 800,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.8,
          "enterEnd": 1.25,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.8,
          "style": { "fontFamily": "Manrope" },
          "html": "<div style='color:#0B3B57; font-size:38px; font-weight:700; line-height:1.3;'><span style='color:{{accentColor}}; font-weight:800;'>✓</span> {{reason3}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showDiscount}}",
          "x": 540,
          "y": 1300,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.05,
          "enterEnd": 1.5,
          "enterAnimation": "circleopen",
          "exitEnd": 4.8,
          "style": { "fontFamily": "Manrope" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#04240F; border-radius:999px; padding:20px 46px; font-size:36px; font-weight:800;'>🎒 {{discountText}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 3.8,
      "backgroundColor": "#052B44",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='srCta' cx='0.5' cy='0.4' r='0.95'><stop offset='0' stop-color='#0C425F'/><stop offset='1' stop-color='#052B44'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#srCta)'/><circle cx='540' cy='640' r='140' fill='none' stroke='#22C55E' stroke-width='3'/><path d='M486 640 l34 34 l70 -78' fill='none' stroke='#22C55E' stroke-width='14' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 890,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Manrope" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:72px; line-height:1.08; font-weight:800; letter-spacing:-1px;'>Book before<br>the rush.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1180,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.65,
          "enterEnd": 1.1,
          "enterAnimation": "smoothup",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Manrope" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#04240F; border-radius:999px; padding:26px 60px; font-size:40px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1360,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1,
          "enterEnd": 1.45,
          "enterAnimation": "fade",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Manrope" },
          "html": "<div style='text-align:center; color:#9CC7DE; font-size:30px; font-weight:700; letter-spacing:2px;'>{{ctaSite}} · {{clinicName}}</div>"
        }
      ]
    }
  ],
  "audios": [
    { "src": "{{musicUrl}}", "volume": 0.14 }
  ]
}
