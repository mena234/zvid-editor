{
  "name": "travel-hotel-deal-alert",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#07130F",
  "outputFormat": "mp4",
  "variables": {
    "brandName": "STAY SMART",
    "kicker": "FLASH RATE",
    "hotelName": "Villa Serena, Santorini",
    "roomType": "Caldera-view suite · 2 nights",
    "priceNow": "$219",
    "priceUnit": "/ night",
    "priceWas": "$465",
    "discountText": "SAVE 53%",
    "deadline": "Rate ends midnight Sunday",
    "disclaimer": "Non-refundable. Taxes included. Subject to availability.",
    "showDisclaimer": true,
    "ctaText": "Lock this rate",
    "ctaHandle": "staysmart.deals",
    "accentColor": "#E4C25C",
    "heroImage": "https://images.unsplash.com/photo-1578898886225-c7c894047899?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3MDgwMTZ8MHwxfHNlYXJjaHwyfHxsdXh1cnklMjBob3RlbCUyMHJvb20lMjBpbnRlcmlvcnxlbnwwfHx8fDE3ODMyNjg1NjZ8MA&ixlib=rb-4.1.0&q=80&w=1080",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "hook",
      "duration": 4,
      "backgroundColor": "#07130F",
      "transition": "smoothup",
      "transitionId": "deal",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{heroImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='thdHook' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#07130F' stop-opacity='0.62'/><stop offset='0.46' stop-color='#07130F' stop-opacity='0.12'/><stop offset='1' stop-color='#07130F' stop-opacity='0.94'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#thdHook)'/><rect x='88' y='1230' width='140' height='6' rx='3' fill='#E4C25C'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 150,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "smoothdown",
          "exitEnd": 4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='display:inline-block; background:#E4C25C; color:#07130F; border-radius:999px; padding:13px 34px; font-size:24px; font-weight:800; letter-spacing:4px;'>{{brandName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 88,
          "y": 1270,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.45,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Playfair Display" },
          "html": "<div style='color:{{accentColor}}; font-size:26px; font-weight:700; letter-spacing:5px; font-family:Sora, sans-serif;'>{{kicker}}</div><div style='margin-top:16px; color:#F4F0E6; font-size:82px; line-height:1.02; font-weight:600; letter-spacing:-2px;'>{{hotelName}}</div><div style='margin-top:20px; color:#BFCFC6; font-size:32px; font-weight:400; font-family:Sora, sans-serif;'>{{roomType}}</div>"
        }
      ]
    },
    {
      "id": "deal",
      "duration": 5.2,
      "backgroundColor": "#07130F",
      "transition": "fade",
      "transitionId": "cta",
      "transitionDuration": 0.5,
