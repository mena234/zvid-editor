          "x": 540,
          "y": 1560,
          "width": 820,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.2,
          "enterEnd": 1.6,
          "enterAnimation": "fade",
          "exitEnd": 5.2,
