        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 720,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 5.2,
          "style": { "fontFamily": "Playfair Display" },
          "html": "<div style='text-align:center; color:#8FA89C; font-size:38px; font-weight:500; text-decoration:line-through; font-family:Sora, sans-serif;'>{{priceWas}}</div><div style='margin-top:8px; text-align:center;'><span style='color:{{accentColor}}; font-size:190px; font-weight:600; letter-spacing:-6px; vertical-align:middle;'>{{priceNow}}</span><span style='color:#BFCFC6; font-size:44px; font-weight:400; vertical-align:middle; font-family:Sora, sans-serif;'> {{priceUnit}}</span></div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1300,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.85,
          "enterEnd": 1.3,
          "enterAnimation": "fade",
          "exitEnd": 5.2,
          "style": { "fontFamily": "Sora" },
