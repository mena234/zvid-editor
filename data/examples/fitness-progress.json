{
  "name": "fitness-progress",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#04120F",
  "outputFormat": "mp4",
  "variables": {
    "appName": "PULSE · 12-week recap",
    "userName": "Marcus",
    "introLine": "12 weeks of showing up.<br>Here's what changed.",
    "metrics": [
      {
        "label": "Body weight",
        "value": "184 lb",
        "delta": "▼ 11 lb",
        "note": "down from 195 · lean phase on track"
      },
      {
        "label": "Resting heart rate",
        "value": "54 bpm",
        "delta": "▼ 9 bpm",
        "note": "your engine got noticeably more efficient"
      },
      {
        "label": "Back squat 1RM",
        "value": "315 lb",
        "delta": "▲ 45 lb",
        "note": "new lifetime best — legs are answering"
      },
      {
        "label": "Sessions logged",
        "value": "48",
        "delta": "▲ 92% consistency",
        "note": "the streak did most of the heavy lifting"
      }
    ],
    "outroHeadline": "Progress isn't loud.<br>It's just consistent.",
    "outroSub": "Next block starts Monday, {{userName}}.",
    "accent": "#2EE6A6",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "intro",
      "duration": 3.8,
      "backgroundColor": "#04120F",
      "transition": "smoothup",
      "transitionId": "metric",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.8,
