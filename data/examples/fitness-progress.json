        {
          "type": "TEXT",
          "x": 540,
          "y": 1180,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.85,
          "enterEnd": 1.25,
          "enterAnimation": "circleopen",
          "exitEnd": 4.2,
          "style": {
            "fontFamily": "Space Grotesk"
          },
          "html": "<div style='display:inline-block; background:{{accent}}; color:#04120F; border-radius:999px; padding:24px 54px; font-size:32px; font-weight:800;'>{{outroSub}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.15
