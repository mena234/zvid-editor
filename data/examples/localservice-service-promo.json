        {
          "type": "TEXT",
          "x": 90,
          "y": 1240,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='color:{{accentColor}}; font-size:24px; font-weight:700; letter-spacing:5px;'>OUR SERVICE</div><div style='margin-top:16px; color:#FFFFFF; font-size:70px; line-height:1.04; font-weight:800; letter-spacing:-1px;'>{{serviceName}}</div><div style='margin-top:22px; color:#B8C6E4; font-size:33px; line-height:1.4; font-weight:500;'>{{serviceSub}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showPrice}}",
          "x": 90,
          "y": 1660,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.9,
          "enterEnd": 1.35,
          "enterAnimation": "smoothleft",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='display:inline-block; background:#FFFFFF; color:#0A1631; border-radius:18px; padding:18px 40px; font-size:40px; font-weight:800;'>{{priceLine}}</div>"
        }
