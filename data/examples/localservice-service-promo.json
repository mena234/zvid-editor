        {
          "type": "IMAGE",
          "src": "{{proImage}}",
          "x": 540,
          "y": 640,
          "width": 984,
          "height": 1000,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "radius": { "tl": 40, "tr": 40, "bl": 40, "br": 40 },
          "track": 1,
          "enterBegin": 0,
          "enterEnd": 0.55,
          "enterAnimation": "fade",
          "exitEnd": 4.2
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.2,
