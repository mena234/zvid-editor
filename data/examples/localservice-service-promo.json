{
  "name": "localservice-service-promo",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0A1631",
  "outputFormat": "mp4",
  "variables": {
    "brandName": "BLUEFLOW PLUMBING",
    "kicker": "LICENSED & INSURED",
    "hookLine": "Leaky pipes?<br>We're on the way.",
    "serviceName": "Same-Day Pipe & Drain Repair",
    "serviceSub": "Fast, tidy, guaranteed work from local pros.",
    "benefits": [
      {
        "title": "Same-day service",
        "detail": "Book before noon, fixed by dinner."
      },
      {
        "title": "Upfront pricing",
        "detail": "Flat quotes — zero surprise fees."
      },
      {
        "title": "Clean & respectful",
        "detail": "Boot covers on, mess cleaned up."
      }
    ],
    "priceLine": "From $89 call-out",
    "showPrice": true,
    "ctaText": "Book your visit",
    "ctaPhone": "(555) 018-2020",
    "accentColor": "#3B82F6",
    "heroVideo": "https://videos.pexels.com/video-files/9462941/9462941-uhd_1440_2560_24fps.mp4",
    "proImage": "https://images.pexels.com/photos/8488035/pexels-photo-8488035.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "hook",
      "duration": 4.2,
      "backgroundColor": "#0A1631",
      "transition": "smoothup",
      "transitionId": "service",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{heroVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.2
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='spHook' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0A1631' stop-opacity='0.72'/><stop offset='0.45' stop-color='#0A1631' stop-opacity='0.12'/><stop offset='1' stop-color='#0A1631' stop-opacity='0.94'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#spHook)'/><rect x='48' y='48' width='984' height='1824' rx='40' fill='none' stroke='rgba(59,130,246,0.4)' stroke-width='2'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 150,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.7,
          "enterAnimation": "fade",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#FFFFFF; border-radius:999px; padding:14px 34px; font-size:24px; font-weight:700; letter-spacing:4px;'>{{brandName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1240,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.55,
          "enterEnd": 1.1,
          "enterAnimation": "smoothup",
          "exitEnd": 4.2,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='color:{{accentColor}}; font-size:26px; font-weight:700; letter-spacing:5px;'>{{kicker}}</div><div style='margin-top:20px; color:#FFFFFF; font-size:96px; line-height:1.02; font-weight:800; letter-spacing:-2px;'>{{hookLine}}</div><div style='margin-top:26px; width:130px; height:8px; border-radius:4px; background:{{accentColor}};'></div>"
        }
      ]
    },
    {
      "id": "service",
      "duration": 4.2,
      "backgroundColor": "#0A1631",
      "transition": "smoothleft",
      "transitionId": "benefit",
      "transitionDuration": 0.55,
