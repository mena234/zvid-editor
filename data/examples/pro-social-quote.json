        {
          "type": "TEXT",
          "x": 540,
          "y": 1330,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.25,
          "enterEnd": 1.6,
          "enterAnimation": "fade",
          "exitEnd": 5,
          "style": {
            "fontFamily": "Sora"
          },
          "html": "<div style='text-align:center; color:rgba(232,213,176,0.55); font-size:24px; letter-spacing:4px;'>{{website}}</div>"
