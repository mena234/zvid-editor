        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 3,
          "enterBegin": 0.15,
          "exitEnd": 5,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><circle cx='540' cy='560' r='140' fill='none' stroke='#D4AF37' stroke-width='3'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 780,
          "width": 860,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 5,
          "style": {
            "fontFamily": "Instrument Serif"
          },
          "html": "<div style='text-align:center; color:{{champagneColor}}; font-size:64px; font-style:italic;'>{{author}}</div>"
