  "variables": {
    "channelName": "@midnight.mind",
    "kicker": "WORDS TO SIT WITH",
    "quote": "The wound is the place where the light enters you.",
    "author": "Rumi",
    "authorNote": "Poet & mystic",
    "showAuthorNote": true,
    "avatarImage": "https://images.unsplash.com/photo-1560250097-0b93528c311a?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3MDgwMTZ8MHwxfHNlYXJjaHwxfHxwcm9mZXNzaW9uYWwlMjBwb3J0cmFpdCUyMGJ1c2luZXNzJTIwcGVyc29ufGVufDB8fHx8MTc4MzI2ODYyOHww&ixlib=rb-4.1.0&q=80&w=1080",
    "ctaText": "Follow for daily wisdom",
    "website": "@midnight.mind",
    "goldColor": "#D4AF37",
    "champagneColor": "#E8D5B0",
    "inkColor": "#101418",
    "charcoalColor": "#1A2026",
    "bgVideo": "https://videos.pexels.com/video-files/15168374/15168374-hd_1080_1920_24fps.mp4",
