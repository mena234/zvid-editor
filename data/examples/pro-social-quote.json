          "x": 540,
          "y": 640,
          "width": 860,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1.1,
          "enterAnimation": "smoothup",
          "exitEnd": 8.4,
          "style": {
