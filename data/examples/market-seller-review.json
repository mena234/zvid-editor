{
  "name": "market-seller-review",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0B1230",
  "outputFormat": "mp4",
  "variables": {
    "marketName": "TRUSTMARKET",
    "kicker": "VERIFIED REVIEW",
    "quote": "Item was exactly as described, packed with care and shipped same day. Best seller I've bought from.",
    "reviewerName": "Marcus D.",
    "reviewerMeta": "Verified buyer · Bought a road bike",
    "ratingText": "5.0",
    "sellerLine": "Reviewing: Pedal & Chain Cyclery",
    "showAvatar": true,
    "ctaText": "Read all reviews",
    "ctaHandle": "trustmarket.co/pedal-chain",
    "accentColor": "#E8B457",
    "avatarImage": "https://images.pexels.com/photos/6152745/pexels-photo-6152745.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2025/04/21/audio_ed6f0ed574.mp3"
  },
  "scenes": [
    {
      "id": "quote",
      "duration": 5.4,
      "backgroundColor": "#0B1230",
      "transition": "fade",
      "transitionId": "rating",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 5.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='srBg' cx='0.5' cy='0.34' r='0.95'><stop offset='0' stop-color='#141E48'/><stop offset='1' stop-color='#0B1230'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#srBg)'/><rect x='60' y='60' width='960' height='1800' rx='40' fill='none' stroke='rgba(232,180,87,0.3)' stroke-width='1.5'/><text x='140' y='620' font-family='Georgia' font-size='320' fill='rgba(232,180,87,0.35)'>&#8220;</text></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 140,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "fade",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:#7C87B8; font-size:24px; font-weight:800; letter-spacing:8px;'>{{marketName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 230,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.7,
          "enterAnimation": "fade",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:26px; font-weight:800; letter-spacing:7px;'>{{kicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 640,
          "width": 880,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.45,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Fraunces" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:66px; line-height:1.25; font-weight:600; font-style:italic;'>{{quote}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1240,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.9,
          "enterEnd": 1.35,
          "enterAnimation": "fade",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='display:inline-block; color:{{accentColor}}; font-size:52px; letter-spacing:8px;'>★★★★★</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1370,
          "width": 820,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 1.1,
          "enterEnd": 1.55,
          "enterAnimation": "smoothup",
          "exitEnd": 5.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:40px; font-weight:700;'>{{reviewerName}}</div><div style='margin-top:10px; text-align:center; color:#9BA6CC; font-size:28px; font-weight:500;'>{{reviewerMeta}}</div>"
        }
      ]
    },
    {
      "id": "rating",
      "duration": 4.4,
      "backgroundColor": "#0B1230",
      "transition": "smoothleft",
      "transitionId": "cta",
