          "src": "{{avatarImage}}",
          "x": 540,
          "y": 560,
          "width": 400,
          "height": 400,
          "anchor": "center-center",
          "resize": "cover",
          "zoom": true,
          "radius": { "tl": 200, "tr": 200, "bl": 200, "br": 200 },
          "track": 1,
          "enterBegin": 0.15,
          "enterEnd": 0.65,
          "enterAnimation": "circleopen",
          "exitEnd": 4.4
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 860,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Fraunces" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:180px; line-height:1; font-weight:600; letter-spacing:-4px;'>{{ratingText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1120,
          "width": 860,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.65,
          "enterEnd": 1.1,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:48px; letter-spacing:8px;'>★★★★★</div><div style='margin-top:26px; text-align:center; color:#FFFFFF; font-size:40px; line-height:1.3; font-weight:600;'>{{sellerLine}}</div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 3.8,
      "backgroundColor": "#0B1230",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='srCta' cx='0.5' cy='0.42' r='0.9'><stop offset='0' stop-color='#161F4C'/><stop offset='1' stop-color='#0B1230'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#srCta)'/><path d='M540 560 l24 60 l64 4 l-50 42 l16 62 l-54 -36 l-54 36 l16 -62 l-50 -42 l64 -4 z' fill='{{accentColor}}'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 820,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Fraunces" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:68px; line-height:1.15; font-weight:600;'>Buy from sellers<br>buyers rave about.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1180,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "circleopen",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#0B1230; border-radius:999px; padding:26px 62px; font-size:36px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1340,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1,
          "enterEnd": 1.4,
          "enterAnimation": "fade",
          "exitEnd": 3.8,
          "style": { "fontFamily": "Inter" },
          "html": "<div style='text-align:center; color:#9BA6CC; font-size:27px; font-weight:600; letter-spacing:1px;'>{{ctaHandle}}</div>"
