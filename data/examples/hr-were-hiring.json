{
  "name": "hr-were-hiring",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0E0F14",
  "outputFormat": "mp4",
  "variables": {
    "companyName": "NORTHWIND",
    "kicker": "WE'RE HIRING",
    "roleTitle": "Senior Product Designer",
    "teamLine": "Join a team that ships fast and cares deeply.",
    "location": "Remote · UK / EU",
    "employmentType": "Full-time",
    "ctaText": "Apply now",
    "ctaUrl": "careers.northwind.co",
    "badgeText": "12 open roles",
    "showBadge": true,
    "accentColor": "#FF6B57",
    "heroVideo": "https://videos.pexels.com/video-files/7844862/7844862-hd_1080_1920_30fps.mp4",
    "roleImage": "https://images.pexels.com/photos/7644081/pexels-photo-7644081.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "hook",
      "duration": 4,
      "backgroundColor": "#0E0F14",
      "transition": "smoothup",
      "transitionId": "role",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{heroVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='hwShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0E0F14' stop-opacity='0.72'/><stop offset='0.42' stop-color='#0E0F14' stop-opacity='0.15'/><stop offset='0.74' stop-color='#0E0F14' stop-opacity='0.4'/><stop offset='1' stop-color='#0E0F14' stop-opacity='0.94'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#hwShade)'/><rect x='44' y='44' width='992' height='1832' rx='44' fill='none' stroke='rgba(255,255,255,0.16)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 140,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.7,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='color:#FFFFFF; font-size:28px; font-weight:700; letter-spacing:10px;'>{{companyName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1200,
          "width": 900,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.4,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#0E0F14; border-radius:999px; padding:14px 34px; font-size:28px; font-weight:800; letter-spacing:4px;'>{{kicker}}</div><div style='margin-top:26px; color:#FFFFFF; font-size:118px; line-height:0.98; font-weight:800; letter-spacing:-4px;'>{{roleTitle}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showBadge}}",
          "x": 90,
          "y": 1660,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.9,
          "enterEnd": 1.35,
          "enterAnimation": "smoothleft",
          "exitEnd": 4,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='display:inline-block; background:rgba(255,255,255,0.12); border:1.5px solid rgba(255,255,255,0.35); color:#FFFFFF; border-radius:999px; padding:14px 32px; font-size:28px; font-weight:600;'>● {{badgeText}}</div>"
        }
      ]
    },
    {
      "id": "role",
      "duration": 4.6,
      "backgroundColor": "#0E0F14",
      "transition": "fade",
      "transitionId": "cta",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{roleImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='hwRole' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0E0F14' stop-opacity='0.35'/><stop offset='0.5' stop-color='#0E0F14' stop-opacity='0.2'/><stop offset='1' stop-color='#0E0F14' stop-opacity='0.95'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#hwRole)'/><rect x='90' y='1150' width='7' height='560' rx='3.5' fill='#FF6B57'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 132,
          "y": 1180,
          "width": 860,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 4.6,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='color:{{accentColor}}; font-size:26px; font-weight:800; letter-spacing:6px;'>WHO WE WANT</div><div style='margin-top:18px; color:#FFFFFF; font-size:62px; line-height:1.12; font-weight:700; letter-spacing:-1px;'>{{teamLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 132,
          "y": 1560,
          "anchor": "top-left",
          "track": 11,
          "enterBegin": 0.85,
          "enterEnd": 1.3,
          "enterAnimation": "fade",
          "exitEnd": 4.6,
          "style": { "fontFamily": "Poppins" },
          "html": "<div><span style='display:inline-block; background:rgba(255,255,255,0.1); border:1.5px solid rgba(255,255,255,0.28); color:#FFFFFF; border-radius:14px; padding:12px 26px; font-size:28px; font-weight:600; margin-right:14px;'>{{location}}</span><span style='display:inline-block; background:rgba(255,255,255,0.1); border:1.5px solid rgba(255,255,255,0.28); color:#FFFFFF; border-radius:14px; padding:12px 26px; font-size:28px; font-weight:600;'>{{employmentType}}</span></div>"
        }
      ]
    },
    {
      "id": "cta",
      "duration": 4.4,
      "backgroundColor": "#0E0F14",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='hwGlow' cx='0.5' cy='0.4' r='0.9'><stop offset='0' stop-color='#2A140F'/><stop offset='1' stop-color='#0E0F14'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#hwGlow)'/><rect x='44' y='44' width='992' height='1832' rx='44' fill='none' stroke='rgba(255,107,87,0.35)' stroke-width='1.5'/><circle cx='540' cy='600' r='150' fill='none' stroke='rgba(255,107,87,0.85)' stroke-width='2.5'/><path d='M492 600 L528 636 L596 560' fill='none' stroke='#FF6B57' stroke-width='9' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 850,
          "width": 920,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:78px; line-height:1.06; font-weight:800; letter-spacing:-2px;'>Your next role<br>is right here.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1180,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#0E0F14; border-radius:999px; padding:28px 70px; font-size:42px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1360,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.1,
          "enterEnd": 1.5,
          "enterAnimation": "fade",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Poppins" },
          "html": "<div style='text-align:center; color:#8B8D98; font-size:28px; font-weight:600; letter-spacing:2px;'>{{ctaUrl}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.16
    }
  ]
}
