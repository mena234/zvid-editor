{
  "name": "agency-offer-stack-ad",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0C0F07",
  "outputFormat": "mp4",
  "variables": {
    "kicker": "THE COMPLETE OFFER",
    "mainOffer": "The Creator Growth System",
    "mainValue": "$1,200 value",
    "hookSub": "Everything you need to hit 100k — plus the bonuses that make it stick.",
    "bonusTitle": "PLUS THESE BONUSES",
    "bonuses": [
      { "name": "90-Day Content Calendar", "worth": "$300", "detail": "Done-for-you, ready to post" },
      { "name": "Viral Hook Vault", "worth": "$250", "detail": "500 hooks that actually convert" },
      { "name": "1:1 Strategy Call", "worth": "$400", "detail": "Map your first 30 days live" }
    ],
    "totalLine": "Total value: $2,150",
    "todayPrice": "Yours today: $197",
    "deadlineText": "Bonuses expire Friday at midnight",
    "showDeadline": true,
    "ctaText": "Claim the full stack",
    "ctaUrl": "creatoros.example/stack",
    "accentColor": "#C6FF3D",
    "bgImage": "https://images.pexels.com/photos/8490673/pexels-photo-8490673.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "hook",
      "duration": 4,
      "backgroundColor": "#0C0F07",
      "transition": "slideleft",
      "transitionId": "bonus",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{bgImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.5,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='osShade' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0C0F07' stop-opacity='0.72'/><stop offset='0.45' stop-color='#0C0F07' stop-opacity='0.35'/><stop offset='1' stop-color='#0C0F07' stop-opacity='0.96'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#osShade)'/><path d='M-60 480 L1140 410 L1140 436 L-60 506 Z' fill='#C6FF3D' opacity='0.9'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 185,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#0C0F07; border-radius:8px; padding:12px 28px; font-size:24px; font-weight:800; letter-spacing:4px;'>{{kicker}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 760,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.45,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:86px; line-height:1.02; font-weight:800; letter-spacing:-2px;'>{{mainOffer}}</div><div style='margin-top:20px; text-align:center; color:{{accentColor}}; font-size:36px; font-weight:800; letter-spacing:2px;'>{{mainValue}}</div><div style='margin-top:24px; text-align:center; color:#B9C4A4; font-size:32px; line-height:1.4; font-weight:500;'>{{hookSub}}</div>"
        }
      ]
    },
    {
      "id": "bonus",
      "iterate": "bonuses",
      "iterateAs": "bonus",
      "duration": 3.2,
      "backgroundColor": "#0C0F07",
      "transition": "slideleft",
      "transitionId": "close",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='osBon' cx='0.5' cy='0.34' r='0.95'><stop offset='0' stop-color='#161C0D'/><stop offset='1' stop-color='#0C0F07'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#osBon)'/><rect x='90' y='690' width='900' height='540' rx='44' fill='rgba(198,255,61,0.06)' stroke='rgba(198,255,61,0.45)' stroke-width='2'/><path d='M150 760 L180 790 L240 730' fill='none' stroke='#C6FF3D' stroke-width='10' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 340,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "smoothup",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:{{accentColor}}; font-size:26px; font-weight:800; letter-spacing:6px;'>{{bonusTitle}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 500,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.7,
          "enterAnimation": "circleopen",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:rgba(198,255,61,0.12); border:1.5px solid rgba(198,255,61,0.5); color:{{accentColor}}; border-radius:999px; padding:12px 34px; font-size:34px; font-weight:800;'>Worth {{bonus.worth}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 800,
          "width": 780,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.45,
          "enterEnd": 0.9,
          "enterAnimation": "smoothup",
          "exitEnd": 3.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:64px; line-height:1.08; font-weight:800; letter-spacing:-1px;'>{{bonus.name}}</div><div style='margin-top:24px; text-align:center; color:#AEB99A; font-size:32px; line-height:1.4; font-weight:500;'>{{bonus.detail}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 130,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 3.2,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='color:rgba(185,196,164,0.7); font-size:24px; font-weight:800; letter-spacing:5px;'>{{mainOffer}}</div>"
        }
      ]
    },
    {
      "id": "close",
      "duration": 4.8,
      "backgroundColor": "#0C0F07",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.8,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='osCls' cx='0.5' cy='0.36' r='0.95'><stop offset='0' stop-color='#18200D'/><stop offset='1' stop-color='#0C0F07'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#osCls)'/><rect x='50' y='50' width='980' height='1820' rx='38' fill='none' stroke='rgba(198,255,61,0.32)' stroke-width='1.5'/><path d='M150 760 H930' stroke='rgba(255,255,255,0.14)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 300,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 4.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#8E9A78; font-size:44px; font-weight:600; text-decoration:line-through;'>{{totalLine}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 420,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.45,
          "enterEnd": 0.9,
          "enterAnimation": "circleopen",
          "exitEnd": 4.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:96px; line-height:1; font-weight:800; letter-spacing:-2px;'>{{todayPrice}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showDeadline}}",
          "x": 540,
          "y": 850,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.7,
          "enterEnd": 1.15,
          "enterAnimation": "smoothup",
          "exitEnd": 4.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:rgba(198,255,61,0.12); border:1.5px solid rgba(198,255,61,0.5); color:{{accentColor}}; border-radius:999px; padding:16px 40px; font-size:30px; font-weight:800;'>{{deadlineText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1120,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.95,
          "enterEnd": 1.4,
          "enterAnimation": "smoothup",
          "exitEnd": 4.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='display:inline-block; background:{{accentColor}}; color:#0C0F07; border-radius:999px; padding:28px 68px; font-size:42px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1300,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1.3,
          "enterEnd": 1.7,
          "enterAnimation": "fade",
          "exitEnd": 4.8,
          "style": { "fontFamily": "Archivo" },
          "html": "<div style='text-align:center; color:#7E8A68; font-size:27px; font-weight:600; letter-spacing:2px;'>{{ctaUrl}}</div>"
        }
      ]
    }
  ],
  "audios": [
    { "src": "{{musicUrl}}", "volume": 0.16 }
  ]
}
