{
  "name": "apppersonal-monthly-recap",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#0A0A12",
  "outputFormat": "mp4",
  "variables": {
    "appName": "PULSE",
    "userName": "Maya",
    "period": "June",
    "introLine": "Your month, wrapped.",
    "outroHeadline": "See you in July,<br>{{userName}}.",
    "ctaText": "Share your recap",
    "accent": "#8B5CF6",
    "accent2": "#22D3A6",
    "bgVideo": "https://videos.pexels.com/video-files/34576602/14651995_1080_1920_30fps.mp4",
    "stats": [
      {
        "label": "Sessions this month",
        "value": "312",
        "delta": "+18% vs May",
        "note": "You showed up almost every day"
      },
      {
        "label": "Total focus time",
        "value": "47h",
        "delta": "Top 8% of users",
        "note": "That's nearly two full days"
      },
      {
        "label": "Streak record",
        "value": "21 days",
        "delta": "New personal best",
        "note": "Longest run you've ever logged"
      }
    ],
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "intro",
      "duration": 4,
      "backgroundColor": "#0A0A12",
      "transition": "smoothup",
      "transitionId": "stat",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{bgVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "opacity": 0.55,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='mrIntro' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#0A0A12' stop-opacity='0.85'/><stop offset='0.5' stop-color='#0A0A12' stop-opacity='0.4'/><stop offset='1' stop-color='#0A0A12' stop-opacity='0.95'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#mrIntro)'/><rect x='56' y='56' width='968' height='1808' rx='44' fill='none' stroke='rgba(139,92,246,0.35)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 700,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.7,
          "enterAnimation": "fade",
          "exitEnd": 4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; border:1.5px solid rgba(34,211,166,0.6); color:{{accent2}}; border-radius:999px; padding:14px 36px; font-size:26px; font-weight:700; letter-spacing:6px;'>{{appName}} · {{period}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 850,
          "width": 920,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1.05,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:118px; line-height:0.98; font-weight:800; letter-spacing:-4px;'>{{userName}}'s<br>Recap</div><div style='margin-top:34px; text-align:center; color:#B7B3C9; font-size:34px; font-weight:500;'>{{introLine}}</div>"
        }
      ]
    },
    {
      "id": "stat",
      "iterate": "stats",
      "iterateAs": "stat",
      "duration": 3.4,
      "backgroundColor": "#0A0A12",
      "transition": "smoothup",
      "transitionId": "outro",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='mrStat' cx='0.5' cy='0.36' r='0.95'><stop offset='0' stop-color='#1B1330'/><stop offset='0.6' stop-color='#120E22'/><stop offset='1' stop-color='#0A0A12'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#mrStat)'/><circle cx='540' cy='690' r='330' fill='none' stroke='rgba(139,92,246,0.28)' stroke-width='2'/><circle cx='540' cy='690' r='400' fill='none' stroke='rgba(34,211,166,0.16)' stroke-width='1.5'/><rect x='96' y='1200' width='888' height='330' rx='36' fill='rgba(255,255,255,0.04)' stroke='rgba(139,92,246,0.35)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 460,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "fade",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='text-align:center; color:#22D3A6; font-size:30px; font-weight:700; letter-spacing:5px;'>{{stat.label}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 560,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.75,
          "enterAnimation": "circleopen",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:250px; line-height:1; font-weight:800; letter-spacing:-8px;'>{{stat.value}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1250,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.6,
          "enterEnd": 1.05,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:rgba(34,211,166,0.16); border:1.5px solid rgba(34,211,166,0.55); color:#22D3A6; border-radius:999px; padding:14px 34px; font-size:32px; font-weight:700;'>{{stat.delta}}</div><div style='margin-top:26px; text-align:center; color:#B7B3C9; font-size:32px; line-height:1.4; font-weight:500;'>{{stat.note}}</div>"
        }
      ]
    },
    {
      "id": "outro",
      "duration": 4.4,
      "backgroundColor": "#0A0A12",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='mrOut' cx='0.5' cy='0.42' r='0.95'><stop offset='0' stop-color='#241547'/><stop offset='0.55' stop-color='#140E28'/><stop offset='1' stop-color='#0A0A12'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#mrOut)'/><circle cx='540' cy='640' r='150' fill='none' stroke='rgba(34,211,166,0.8)' stroke-width='3'/><path d='M486 640 L524 682 L600 596' fill='none' stroke='#22D3A6' stroke-width='12' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 900,
          "width": 940,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.3,
          "enterEnd": 0.8,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Sora" },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:84px; line-height:1.05; font-weight:800; letter-spacing:-2px;'>{{outroHeadline}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1240,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.8,
          "enterEnd": 1.25,
          "enterAnimation": "circleopen",
          "exitEnd": 4.4,
          "style": { "fontFamily": "Space Grotesk" },
          "html": "<div style='display:inline-block; background:{{accent}}; color:#0A0A12; border-radius:999px; padding:28px 66px; font-size:40px; font-weight:800;'>{{ctaText}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.18
    }
  ]
}
