{
  "name": "finance-watchlist",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#050A18",
  "outputFormat": "mp4",
  "variables": {
    "appName": "SIGNAL",
    "userName": "your",
    "hookLine": "This week's watchlist.",
    "subLine": "4 tickers worth watching into next week.",
    "accent": "#37D0FF",
    "accentUp": "#43E3A0",
    "accentDown": "#FF6382",
    "assets": [
      {
        "symbol": "AMZN",
        "name": "Amazon",
        "level": "Watch $205 breakout",
        "bias": "+ Bullish",
        "dir": "up"
      },
      {
        "symbol": "PLTR",
        "name": "Palantir",
        "level": "Holding $28 support",
        "bias": "+ Bullish",
        "dir": "up"
      },
      {
        "symbol": "AMD",
        "name": "Adv. Micro",
        "level": "Range-bound $158-172",
        "bias": "~ Neutral",
        "dir": "up"
      },
      {
        "symbol": "BA",
        "name": "Boeing",
        "level": "Below $180 = weak",
        "bias": "- Bearish",
        "dir": "down"
      }
    ],
    "showDisclaimer": true,
    "disclaimer": "For education only. Not a recommendation.",
    "ctaText": "Save your watchlist 🔖",
    "bgImage": "https://images.pexels.com/photos/9665181/pexels-photo-9665181.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
    "musicUrl": "https://cdn.pixabay.com/audio/2026/02/24/audio_3f375fdf97.mp3"
  },
  "scenes": [
    {
      "id": "cover",
      "duration": 3.6,
      "backgroundColor": "#050A18",
      "transition": "smoothleft",
      "transitionId": "asset",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "IMAGE",
          "src": "{{bgImage}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "zoom": true,
          "opacity": 0.4,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.6
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 3.6,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='wlCov' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#050A18' stop-opacity='0.78'/><stop offset='0.5' stop-color='#050A18' stop-opacity='0.4'/><stop offset='1' stop-color='#050A18' stop-opacity='0.96'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#wlCov)'/><rect x='48' y='48' width='984' height='1824' rx='38' fill='none' stroke='rgba(55,208,255,0.28)' stroke-width='1.5'/><path d='M90 1220 L250 1160 L360 1195 L520 1080 L660 1120 L820 990 L990 1040' fill='none' stroke='rgba(55,208,255,0.5)' stroke-width='4' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 160,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.6,
          "enterAnimation": "fade",
          "exitEnd": 3.6,
          "style": {
            "fontFamily": "Manrope"
          },
          "html": "<div style='display:inline-block; border:1.5px solid rgba(55,208,255,0.5); border-radius:999px; padding:12px 32px; color:{{accent}}; font-size:24px; font-weight:800; letter-spacing:6px;'>{{appName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 900,
          "width": 920,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.35,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 3.6,
          "style": {
            "fontFamily": "Manrope"
          },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:98px; line-height:1.02; font-weight:800; letter-spacing:-2px;'>{{hookLine}}</div><div style='margin-top:26px; text-align:center; color:#8DA0C4; font-size:34px; line-height:1.4; font-weight:500;'>{{subLine}}</div>"
        }
      ]
    },
    {
      "id": "asset",
      "iterate": "assets",
      "iterateAs": "a",
      "duration": 2.9,
      "backgroundColor": "#050A18",
      "transition": "smoothleft",
      "transitionId": "outro",
      "transitionDuration": 0.45,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 2.9,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='wlAst' cx='0.5' cy='0.34' r='0.95'><stop offset='0' stop-color='#0B142B'/><stop offset='1' stop-color='#050A18'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#wlAst)'/><rect x='80' y='600' width='920' height='720' rx='44' fill='rgba(255,255,255,0.03)' stroke='rgba(55,208,255,0.3)' stroke-width='1.5'/><rect x='80' y='600' width='920' height='14' rx='7' fill='{{accent}}'/><path d='M140 1160 L280 1110 L400 1140 L540 1050 L680 1090 L820 980 L940 1020' fill='none' stroke='rgba(55,208,255,0.35)' stroke-width='4' stroke-linecap='round' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 340,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 2.9,
          "style": {
            "fontFamily": "Manrope"
          },
          "html": "<div style='color:#5D6F94; font-size:24px; font-weight:800; letter-spacing:6px;'>WATCHLIST · {{index}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 680,
          "width": 820,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.15,
          "enterEnd": 0.6,
          "enterAnimation": "smoothup",
          "exitEnd": 2.9,
          "style": {
            "fontFamily": "Manrope"
          },
          "html": "<div style='text-align:center; color:{{accent}}; font-size:40px; font-weight:800; letter-spacing:4px;'>{{a.symbol}}</div><div style='margin-top:12px; text-align:center; color:#FFFFFF; font-size:92px; line-height:1; font-weight:800; letter-spacing:-2px;'>{{a.name}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 990,
          "width": 780,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.4,
          "enterEnd": 0.85,
          "enterAnimation": "fade",
          "exitEnd": 2.9,
          "style": {
            "fontFamily": "Manrope"
          },
          "html": "<div style='text-align:center; color:#AEBDD6; font-size:36px; line-height:1.3; font-weight:600;'>{{a.level}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{a.dir}}",
          "x": 540,
          "y": 1140,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.6,
          "enterEnd": 1.05,
          "enterAnimation": "circleopen",
          "exitEnd": 2.9,
          "style": {
            "fontFamily": "Manrope"
          },
          "html": "<div style='display:inline-block; background:rgba(67,227,160,0.13); border:1.5px solid rgba(67,227,160,0.5); color:{{accentUp}}; border-radius:999px; padding:12px 40px; font-size:34px; font-weight:800;'>{{a.bias}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1820,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 2.9,
          "style": {
            "fontFamily": "Manrope"
          },
          "html": "<div style='color:rgba(141,160,196,0.6); font-size:22px; font-weight:800; letter-spacing:4px;'>{{appName}} · {{userName}} watchlist</div>"
        }
      ]
    },
    {
      "id": "outro",
      "duration": 3.4,
      "backgroundColor": "#050A18",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='wlOut' cx='0.5' cy='0.4' r='0.9'><stop offset='0' stop-color='#0B142B'/><stop offset='1' stop-color='#050A18'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#wlOut)'/><path d='M470 620 L470 800 L540 750 L610 800 L610 620 Z' fill='none' stroke='#37D0FF' stroke-width='8' stroke-linejoin='round'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 920,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.25,
          "enterEnd": 0.7,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": {
            "fontFamily": "Manrope"
          },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:66px; line-height:1.12; font-weight:800;'>Set your alerts<br>before the open.</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1200,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.65,
          "enterEnd": 1.05,
          "enterAnimation": "circleopen",
          "exitEnd": 3.4,
          "style": {
            "fontFamily": "Manrope"
          },
          "html": "<div style='display:inline-block; background:{{accent}}; color:#050A18; border-radius:999px; padding:20px 52px; font-size:32px; font-weight:800;'>{{ctaText}}</div>"
        },
        {
          "type": "TEXT",
          "condition": "{{showDisclaimer}}",
          "x": 540,
          "y": 1400,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 1,
          "enterEnd": 1.4,
          "enterAnimation": "fade",
          "exitEnd": 3.4,
          "style": {
            "fontFamily": "Manrope"
          },
          "html": "<div style='display:inline-block; background:rgba(255,255,255,0.05); border:1px solid rgba(141,160,196,0.3); color:#8DA0C4; border-radius:999px; padding:12px 28px; font-size:22px; font-weight:600;'>{{disclaimer}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.16
    }
  ]
}
