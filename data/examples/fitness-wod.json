{
  "name": "fitness-wod",
  "resolution": "instagram-reel",
  "frameRate": 30,
  "backgroundColor": "#07080A",
  "outputFormat": "mp4",
  "variables": {
    "boxName": "IRONHAUS ATHLETIC",
    "wodLabel": "WORKOUT OF THE DAY",
    "wodTitle": "Engine Builder",
    "wodSubtitle": "AMRAP · 18 minutes · scale as needed",
    "timerLabel": "TOTAL TIME CAP",
    "timerValue": "18:00",
    "closingHeadline": "Clock starts<br>the second you do.",
    "closingSub": "Log your rounds. Tag the box.",
    "accent": "#C6FF3D",
    "heroVideo": "https://videos.pexels.com/video-files/6454274/6454274-uhd_1440_2560_24fps.mp4",
    "exercises": [
      {
        "reps": "12",
        "name": "Wall Balls",
        "detail": "20 / 14 lb · to the 10 ft target"
      },
      {
        "reps": "10",
        "name": "Toes-to-Bar",
        "detail": "scale: knee raises · stay hollow"
      },
      {
        "reps": "8",
        "name": "Power Cleans",
        "detail": "95 / 65 lb · full hip extension"
      },
      {
        "reps": "200m",
        "name": "Row Sprint",
        "detail": "reset breathing before round 2"
      }
    ],
    "musicUrl": "https://cdn.pixabay.com/audio/2025/03/19/audio_56ae1dae5f.mp3"
  },
  "scenes": [
    {
      "id": "hook",
      "duration": 4,
      "backgroundColor": "#07080A",
      "transition": "smoothup",
      "transitionId": "exercise",
      "transitionDuration": 0.55,
      "visuals": [
        {
          "type": "VIDEO",
          "src": "{{heroVideo}}",
          "width": 1080,
          "height": 1920,
          "position": "center-center",
          "resize": "cover",
          "volume": 0,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4
        },
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 2,
          "enterBegin": 0,
          "exitEnd": 4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><linearGradient id='wodHook' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='#07080A' stop-opacity='0.72'/><stop offset='0.42' stop-color='#07080A' stop-opacity='0.15'/><stop offset='1' stop-color='#07080A' stop-opacity='0.94'/></linearGradient></defs><rect width='1080' height='1920' fill='url(#wodHook)'/><rect x='0' y='1290' width='1080' height='8' fill='#C6FF3D'/><rect x='56' y='56' width='968' height='1808' rx='28' fill='none' stroke='rgba(198,255,61,0.28)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 120,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.65,
          "enterAnimation": "smoothright",
          "exitEnd": 4,
          "style": {
            "fontFamily": "Archivo"
          },
          "html": "<div style='display:inline-block; background:#C6FF3D; color:#07080A; padding:12px 26px; font-size:24px; font-weight:800; letter-spacing:5px;'>{{boxName}}</div>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 1360,
          "width": 900,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0.5,
          "enterEnd": 1.05,
          "enterAnimation": "smoothup",
          "exitEnd": 4,
          "style": {
            "fontFamily": "Archivo"
          },
          "html": "<div style='color:{{accent}}; font-size:26px; font-weight:800; letter-spacing:7px;'>{{wodLabel}}</div><div style='margin-top:14px; color:#FFFFFF; font-size:118px; line-height:0.92; font-weight:900; letter-spacing:-3px; text-transform:uppercase;'>{{wodTitle}}</div><div style='margin-top:22px; color:#B7BDC4; font-size:32px; font-weight:600;'>{{wodSubtitle}}</div>"
        }
      ]
    },
    {
      "id": "exercise",
      "iterate": "exercises",
      "iterateAs": "ex",
      "duration": 3.4,
      "backgroundColor": "#07080A",
      "transition": "smoothup",
      "transitionId": "timer",
      "transitionDuration": 0.5,
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='wodItem' cx='0.5' cy='0.32' r='0.95'><stop offset='0' stop-color='#12160D'/><stop offset='1' stop-color='#07080A'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#wodItem)'/><rect x='80' y='700' width='920' height='560' rx='36' fill='rgba(198,255,61,0.05)' stroke='rgba(198,255,61,0.4)' stroke-width='1.5'/><rect x='80' y='700' width='920' height='10' rx='5' fill='#C6FF3D'/><path d='M150 470 H930' stroke='rgba(255,255,255,0.14)' stroke-width='2'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 90,
          "y": 300,
          "anchor": "top-left",
          "track": 10,
          "enterBegin": 0,
          "exitEnd": 3.4,
          "style": {
            "fontFamily": "Archivo"
          },
          "html": "<div style='color:rgba(255,255,255,0.55); font-size:24px; font-weight:800; letter-spacing:6px;'>{{boxName}} · WOD</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 560,
          "anchor": "center-center",
          "track": 10,
          "enterBegin": 0.15,
          "enterEnd": 0.55,
          "enterAnimation": "smoothright",
          "exitEnd": 3.4,
          "style": {
            "fontFamily": "Archivo"
          },
          "html": "<div style='color:{{accent}}; font-size:200px; line-height:0.9; font-weight:900; letter-spacing:-6px;'>{{ex.reps}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 800,
          "width": 840,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.4,
          "enterEnd": 0.85,
          "enterAnimation": "smoothup",
          "exitEnd": 3.4,
          "style": {
            "fontFamily": "Archivo"
          },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:82px; line-height:1; font-weight:900; letter-spacing:-2px; text-transform:uppercase;'>{{ex.name}}</div><div style='margin-top:26px; text-align:center; color:#B7BDC4; font-size:32px; line-height:1.4; font-weight:600;'>{{ex.detail}}</div>"
        }
      ]
    },
    {
      "id": "timer",
      "duration": 4.4,
      "backgroundColor": "#07080A",
      "visuals": [
        {
          "type": "SVG",
          "width": 1080,
          "height": 1920,
          "track": 0,
          "enterBegin": 0,
          "exitEnd": 4.4,
          "svg": "<svg width='1080' height='1920' viewBox='0 0 1080 1920' xmlns='http://www.w3.org/2000/svg'><defs><radialGradient id='wodEnd' cx='0.5' cy='0.36' r='0.95'><stop offset='0' stop-color='#141A0C'/><stop offset='1' stop-color='#07080A'/></radialGradient></defs><rect width='1080' height='1920' fill='url(#wodEnd)'/><circle cx='540' cy='620' r='250' fill='none' stroke='rgba(198,255,61,0.85)' stroke-width='4'/><circle cx='540' cy='620' r='280' fill='none' stroke='rgba(198,255,61,0.22)' stroke-width='2'/><rect x='56' y='56' width='968' height='1808' rx='28' fill='none' stroke='rgba(198,255,61,0.25)' stroke-width='1.5'/></svg>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 560,
          "width": 520,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.2,
          "enterEnd": 0.7,
          "enterAnimation": "circleopen",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "Archivo"
          },
          "html": "<div style='text-align:center; color:{{accent}}; font-size:26px; font-weight:800; letter-spacing:6px;'>{{timerLabel}}</div><div style='margin-top:10px; text-align:center; color:#FFFFFF; font-size:150px; line-height:1; font-weight:900; letter-spacing:-4px;'>{{timerValue}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1010,
          "width": 900,
          "anchor": "top-center",
          "track": 10,
          "enterBegin": 0.55,
          "enterEnd": 1,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "Archivo"
          },
          "html": "<div style='text-align:center; color:#FFFFFF; font-size:72px; line-height:1.02; font-weight:900; letter-spacing:-2px; text-transform:uppercase;'>{{closingHeadline}}</div>"
        },
        {
          "type": "TEXT",
          "x": 540,
          "y": 1280,
          "anchor": "top-center",
          "track": 11,
          "enterBegin": 0.9,
          "enterEnd": 1.3,
          "enterAnimation": "smoothup",
          "exitEnd": 4.4,
          "style": {
            "fontFamily": "Archivo"
          },
          "html": "<div style='display:inline-block; background:{{accent}}; color:#07080A; border-radius:999px; padding:24px 58px; font-size:34px; font-weight:900; letter-spacing:1px;'>{{closingSub}}</div>"
        }
      ]
    }
  ],
  "audios": [
    {
      "src": "{{musicUrl}}",
      "volume": 0.18
    }
  ]
}
