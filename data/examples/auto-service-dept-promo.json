    "introSub": "Certified techs · OEM parts · Same-day slots.",
    "offers": [
      {
        "icon": "OIL",
        "name": "Synthetic Oil Change",
        "detail": "Full synthetic + filter + 21-point check",
        "price": "$49",
        "was": "was $79"
      },
      {
        "icon": "TIRE",
        "name": "Tire Rotation & Align",
        "detail": "Balance, rotate & 4-wheel alignment",
        "price": "$89",
        "was": "was $129"
      },
      {
        "icon": "CHECK",
